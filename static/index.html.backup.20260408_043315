}

/* ── Candlestick plugin — draws OHLC bars over the price line ── */
const candlestickPlugin = {
  id: 'candlestick',
  afterDatasetsDraw(chart) {
    if (!chartOHLC) return;
    const { ctx, scales: { x: xAx, y: yAx }, chartArea } = chart;
    if (!xAx || !yAx) return;
    const { opens, highs, lows, closes } = chartOHLC;
    const n = closes.length;
    if (!n) return;

    // Bar width: gap between two adjacent bar centres × 0.72 gives natural spacing
    const x0 = xAx.getPixelForValue(0);
    const x1 = xAx.getPixelForValue(Math.min(1, n - 1));
    const barW = Math.max(2, Math.abs(x1 - x0) * 0.72);
    const halfW = barW / 2;

    ctx.save();
    ctx.beginPath();
    ctx.rect(chartArea.left, chartArea.top, chartArea.right - chartArea.left, chartArea.bottom - chartArea.top);
    ctx.clip();

    for (let i = 0; i < n; i++) {
      const o = opens[i], h = highs[i], l = lows[i], c = closes[i];
      if (o == null || h == null || l == null || c == null) continue;

      const x  = xAx.getPixelForValue(i);
      const yH = yAx.getPixelForValue(h);
      const yL = yAx.getPixelForValue(l);
      const yO = yAx.getPixelForValue(o);
      const yC = yAx.getPixelForValue(c);

      const isBull = c >= o;
      const bodyColor  = isBull ? 'rgba(0,210,130,0.88)'  : 'rgba(255,60,70,0.88)';
      const wickColor  = isBull ? 'rgba(0,210,130,0.70)'  : 'rgba(255,60,70,0.70)';
      const bodyTop    = Math.min(yO, yC);
      const bodyHeight = Math.max(1.5, Math.abs(yC - yO));

      // Wick
      ctx.beginPath();
      ctx.strokeStyle = wickColor;
      ctx.lineWidth = Math.max(0.8, barW * 0.12);
      ctx.moveTo(x, yH);
      ctx.lineTo(x, bodyTop);
      ctx.moveTo(x, bodyTop + bodyHeight);
      ctx.lineTo(x, yL);
      ctx.stroke();

      // Body
      ctx.fillStyle = bodyColor;
      ctx.fillRect(x - halfW, bodyTop, barW, bodyHeight);
    }
    ctx.restore();
  }
};

const levelLinesPlugin = {
  id: 'levelLines',
  afterDraw(chart) {
    const ctx  = chart.ctx;
    const yAx  = chart.scales.y;
    const xAx  = chart.scales.x;
    if (!yAx || !xAx) return;

    // ── Level lines (Entry / SL / TPs) ──
    if (chartLevels) {
      const lvls = [
        { val: chartLevels.entry,     color: '#f5a623', label: 'Entry', dash: [7,3] },
        { val: chartLevels.stop_loss, color: '#ff4459', label: 'SL',    dash: [4,4] },
        { val: chartLevels.tp1,       color: '#00c98d', label: 'TP1',   dash: [6,3] },
        { val: chartLevels.tp2,       color: '#009d6f', label: 'TP2',   dash: [6,3] },
        { val: chartLevels.tp3,       color: '#006e4e', label: 'TP3',   dash: [6,3] },
      ];
      ctx.save();
      lvls.forEach(({ val, color, label, dash }) => {
        if (val == null) return;
        const y = yAx.getPixelForValue(val);
        if (y < yAx.top - 2 || y > yAx.bottom + 2) return;
        ctx.beginPath();
        ctx.setLineDash(dash);
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.3;
        ctx.globalAlpha = 0.72;
        ctx.moveTo(xAx.left, y);
        ctx.lineTo(xAx.right, y);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.globalAlpha = 1;
        const txt = `${label} ${fmt(val)}`;
        ctx.font = 'bold 9px JetBrains Mono,monospace';
        const tw  = ctx.measureText(txt).width;
        ctx.fillStyle = 'rgba(8,8,8,0.85)';
        ctx.fillRect(xAx.right - tw - 10, y - 9, tw + 8, 14);
        ctx.fillStyle = color;
        ctx.textAlign = 'right';
        ctx.fillText(txt, xAx.right - 3, y + 3.5);
      });
      ctx.restore();
    }

    // ── Signal arrows (RSI crossover/under markers) ──
    // Clear in-place (NOT reassign) so the event-listener closure keeps its reference
    _priceHits.length = 0;
    if (chartSignals && chartOverlays.SIG) {
      const prices = chartSignals.prices || [];
      const highs  = chartSignals.highs  || prices;
      const lows   = chartSignals.lows   || prices;
      ctx.save();

      const drawArrow = (barIdx, price, isBuy) => {
        if (barIdx < 0 || barIdx >= prices.length) return;
        // Anchor arrows to wick tips for cleaner look on candlestick chart
        const anchorPrice = isBuy ? (lows[barIdx] || price) : (highs[barIdx] || price);
        const x = xAx.getPixelForValue(barIdx);
        const y = yAx.getPixelForValue(anchorPrice);
        if (x == null || y == null) return;
        const color  = isBuy ? '#f5a623' : '#ff524a';
        const offset = isBuy ? 18 : -18;
        const ay     = y + offset;

        // Triangle arrow
        ctx.beginPath();
        if (isBuy) {
          ctx.moveTo(x,     ay - 8);
          ctx.lineTo(x - 5, ay);
          ctx.lineTo(x + 5, ay);
        } else {
          ctx.moveTo(x,     ay + 8);
          ctx.lineTo(x - 5, ay);
          ctx.lineTo(x + 5, ay);
        }
        ctx.closePath();
        ctx.fillStyle = color;
        ctx.globalAlpha = 0.9;
        ctx.fill();

        // Label
        ctx.globalAlpha = 1;
        ctx.font = 'bold 8px JetBrains Mono,monospace';
        ctx.fillStyle = color;
        ctx.textAlign = 'center';
        ctx.fillText(isBuy ? 'B' : 'S', x, isBuy ? ay + 12 : ay - 4);

        // Register hit target for tooltip
        _priceHits.push({ x, y: ay, type: isBuy ? 'buy' : 'sell', price });
      };

      (chartSignals.buys  || []).forEach(i => drawArrow(i, prices[i], true));
      (chartSignals.sells || []).forEach(i => drawArrow(i, prices[i], false));
      ctx.restore();
    }

    // ── RSI Divergence lines on price chart ──
    if (chartDivergence && chartOverlays.RSI && chartDivergence.priceBars.length >= 2) {
      const div   = chartDivergence;
      const color = div.isBull ? '#00c98d' : '#ff524a';
      const pb    = div.priceBars, pv = div.priceVals;
      ctx.save();
      const b0 = Math.max(0, pb[0]), b1 = Math.max(0, pb[1]);
      const x0 = xAx.getPixelForValue(b0), x1 = xAx.getPixelForValue(b1);
      const y0 = yAx.getPixelForValue(pv[0] || 0), y1 = yAx.getPixelForValue(pv[1] || 0);
      if (x0 && x1 && y0 && y1) {
        // Dashed divergence line
        ctx.beginPath();
        ctx.setLineDash([5, 4]);
        ctx.strokeStyle = color;
        ctx.lineWidth   = 1.6;
        ctx.globalAlpha = 0.75;
        ctx.moveTo(x0, y0); ctx.lineTo(x1, y1);
        ctx.stroke();
        ctx.setLineDash([]);
        // Dot markers
        [{ x:x0, y:y0 }, { x:x1, y:y1 }].forEach(pt => {
          ctx.beginPath();
          ctx.arc(pt.x, pt.y, 4, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.globalAlpha = 0.9;
          ctx.fill();
          // Register hit target (larger radius — 10px in hit test)
          _priceHits.push({ x: pt.x, y: pt.y, type: 'div', div });
        });
        // Label near second pivot
        ctx.globalAlpha = 1;
        ctx.font = 'bold 8px JetBrains Mono,monospace';
        ctx.fillStyle = color;
        ctx.textAlign = 'center';
        ctx.fillText(div.isBull ? '▲ DIV' : '▼ DIV', x1, y1 + (div.isBull ? 14 : -6));
      }
      ctx.restore();
    }
  }
};

const crosshairPlugin = {
  id: 'crosshair',
  afterEvent(chart, args) {
    const t = args.event.type;
    if (t === 'mousemove') { chart._xhX = args.event.x; }
    else if (t === 'mouseout') { chart._xhX = null; }
    else { return; }
    args.changed = true;
  },
  afterDraw(chart) {
    if (chart._xhX == null) return;
    const { ctx, chartArea: { top, bottom, left, right } } = chart;
    const x = chart._xhX;
    if (x < left || x > right) return;
    ctx.save();
    ctx.beginPath();
    ctx.setLineDash([3, 3]);
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.lineWidth = 1;
    ctx.moveTo(x, top);
    ctx.lineTo(x, bottom);
    ctx.stroke();
    ctx.restore();
  }
};

function renderChart(d) {
  // Store levels for the plugin
  chartLevels = (d.entry || d.stop_loss || d.tp1)
    ? { entry: d.entry, stop_loss: d.stop_loss, tp1: d.tp1, tp2: d.tp2, tp3: d.tp3 }
    : null;

  // Store OHLC for candlestick plugin
  chartOHLC = (d.chart_opens && d.chart_opens.length)
    ? { opens: d.chart_opens, highs: d.chart_highs, lows: d.chart_lows, closes: d.chart_prices }
    : null;

  // Store signal bars — use highs/lows for precise arrow placement on candles
  chartSignals = (d.chart_prices && d.chart_prices.length)
    ? {
        buys:   d.chart_buy_signals  || [],
        sells:  d.chart_sell_signals || [],
        prices: d.chart_prices,
        highs:  d.chart_highs  || d.chart_prices,
        lows:   d.chart_lows   || d.chart_prices,
      }
    : null;

  // Store divergence pivot data for overlay lines
  const div = d.rsi_divergence || {};
  chartDivergence = (div.type && div.type !== 'none' && (div.chart_price_pivot_bars || []).length >= 2)
    ? {
        type:       div.type,
        label:      div.label || div.type,
        desc:       div.desc  || '',
        strength:   div.strength || 0,
        priceBars:  div.chart_price_pivot_bars || [],
        priceVals:  div.price_pivot_vals || [],
        rsiBars:    div.chart_rsi_pivot_bars   || [],
        rsiVals:    div.rsi_pivots || [],
        isBull:     div.type === 'bullish' || div.type === 'hidden_bullish',
      }
    : null;

  // Toggle candle vs price-line legend label
  const _legPrice   = document.getElementById('legendPriceLine');
  const _legCandles = document.getElementById('legendCandles');
  const _hasCandlesNow = !!(d.chart_opens && d.chart_opens.length);
  if (_legPrice)   _legPrice.style.display   = _hasCandlesNow ? 'none' : '';
  if (_legCandles) _legCandles.style.display = _hasCandlesNow ? ''     : 'none';

  // Show/hide legend level indicators
  document.getElementById('legendEntry').style.display = d.entry     ? '' : 'none';
  document.getElementById('legendSL').style.display    = d.stop_loss ? '' : 'none';
  document.getElementById('legendTP').style.display    = d.tp1       ? '' : 'none';

  // ── RSI Divergence badges: update button label + RSI chart badge ──
  const _divData   = d.rsi_divergence || {};
  const _divType   = _divData.type;
  const _divLabel  = _divData.label || '';
  const _hasDivNow = _divType && _divType !== 'none';
  const _divIsBull = _divType === 'bullish' || _divType === 'hidden_bullish';
  const _divColor  = _divIsBull ? '#00c98d' : '#ff524a';
  const _divBg     = _divIsBull ? 'rgba(0,201,141,.14)' : 'rgba(255,82,74,.14)';
  const _divBorder = _divIsBull ? 'rgba(0,201,141,.3)'  : 'rgba(255,82,74,.3)';

  // Button inline tag (e.g. "Regular Bearish")
  const _divTypeEl = document.getElementById('indDivType');
  if (_divTypeEl) {
    if (_hasDivNow) {
      _divTypeEl.textContent = _divLabel;
      _divTypeEl.style.display     = '';
      _divTypeEl.style.color       = _divColor;
      _divTypeEl.style.background  = _divBg;
      _divTypeEl.style.border      = `1px solid ${_divBorder}`;
    } else {
      _divTypeEl.style.display = 'none';
    }
  }

  // RSI chart corner badge
  const _rsiDivBadge = document.getElementById('rsiDivBadge');
  if (_rsiDivBadge) {
    if (_hasDivNow) {
      _rsiDivBadge.textContent        = (_divIsBull ? '▲ ' : '▼ ') + _divLabel;
      _rsiDivBadge.style.display      = '';
      _rsiDivBadge.style.color        = _divColor;
      _rsiDivBadge.style.background   = _divBg;
      _rsiDivBadge.style.border       = `1px solid ${_divBorder}`;
    } else {
      _rsiDivBadge.style.display = 'none';
    }
  }

  const labels  = d.chart_dates    || [], prices = d.chart_prices || [];
  const ema20   = d.chart_ema20    || [], ema50  = d.chart_ema50  || [];
  const vols    = d.chart_volumes  || [];
  const bbUpper = d.chart_bb_upper || [], bbLower = d.chart_bb_lower || [];
  const rsiData = d.chart_rsi      || [];

  const tvEmbed   = document.getElementById('tvChartEmbed');
  const canvasPC  = document.getElementById('priceChart');
  const canvasVC  = document.getElementById('volChart');
  const ovrRow    = document.getElementById('chartOvrRow');
  const rsiWrap   = document.getElementById('rsiChartWrap');

  // ── When no OHLC history: show key-levels chart (never show TradingView embed) ──
  if (prices.length === 0) {
    chartOHLC = null;
    tvMode = false;
    if (tvEmbed) tvEmbed.style.display = 'none';
    if (volChartInst) { volChartInst.destroy(); volChartInst = null; }

    // Show price canvas, hide volume, keep RSI hidden (no data)
    canvasPC.parentElement.style.display = '';
    canvasVC.parentElement.style.display = 'none';
    if (rsiWrap) rsiWrap.style.display = 'none';

    // Build a levels-only chart so Entry / SL / TP lines are visible
    const allLvls = [d.entry, d.stop_loss, d.tp1, d.tp2, d.tp3, d.price]
      .filter(v => v != null).map(Number);
    const spread = allLvls.length ? (Math.max(...allLvls) - Math.min(...allLvls)) : 0;
    const yPad   = spread * 0.3 || (allLvls.length ? Math.min(...allLvls) * 0.02 : 1);
    const yMin   = allLvls.length ? Math.min(...allLvls) - yPad : 0;
    const yMax   = allLvls.length ? Math.max(...allLvls) + yPad : 100;

    const N           = 60;
    const dummyLabels = Array.from({length:N}, (_,i) => i);
    const isDark      = document.documentElement.getAttribute('data-theme') !== 'light';
    const gridCol     = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
    const lblCol      = isDark ? '#666' : '#7a9ab5';

    const pCtx = document.getElementById('priceChart').getContext('2d');
    if (priceChartInst) priceChartInst.destroy();

    priceChartInst = new Chart(pCtx, {
      type: 'line',
      plugins: [levelLinesPlugin, {
        id: 'noDataMsg',
        afterDraw(chart) {
          const { ctx, chartArea: { left, top, right, bottom } } = chart;
          if (!ctx) return;
          ctx.save();
          const mx = (left + right) / 2, my = top + 22;
          ctx.fillStyle = 'rgba(255,255,255,0.25)';
          ctx.font = '600 11px system-ui,sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('Trade Levels — ' + (d.ticker || '') + ' ' + (d.timeframe || '').toUpperCase(), mx, my);
          ctx.fillStyle = 'rgba(255,255,255,0.14)';
          ctx.font = '10px system-ui,sans-serif';
          ctx.fillText('No OHLC candle data · Showing Entry / SL / TP levels', mx, my + 16);
          ctx.restore();
        }
      }],
      data: {
        labels: dummyLabels,
        datasets: [{ data: Array(N).fill(null), borderColor:'transparent', backgroundColor:'transparent', pointRadius:0 }]
      },
      options: {
        responsive:true, maintainAspectRatio:false, animation:false,
        scales: {
          x: { display:false },
          y: {
            min: yMin, max: yMax, position:'right',
            ticks: { color:lblCol, font:{family:'monospace',size:10}, maxTicksLimit:8, callback: v => fmt(v) },
            grid: { color: gridCol }
          }
        },
        plugins: { legend:{display:false}, tooltip:{enabled:false} }
      }
    });

    // Restore overlay/indicator button rows, hide TV hint
    if (ovrRow) ovrRow.style.display = 'flex';
    const _indRow2 = document.getElementById('chartIndicatorRow');
    if (_indRow2) _indRow2.style.display = 'flex';
    const _tvHint2 = document.getElementById('chartTVHint');
    if (_tvHint2) _tvHint2.style.display = 'none';
    _syncIndButtons('SIG', chartOverlays.SIG);
    _syncIndButtons('RSI', chartOverlays.RSI);

    document.getElementById('chartTitle').textContent =
      d.ticker + ' \u00b7 ' + d.timeframe.toUpperCase() + (d.ema_trend ? ' \u00b7 ' + d.ema_trend : '');
    const _sb = document.getElementById('synthWarnBadge');
    if (_sb) _sb.style.display = 'none';
    if (typeof _updateDeltaLayer === 'function') _updateDeltaLayer(d);
    return;
  }

  // ── OHLC data available — use Chart.js ──
  tvMode = false;
  tvEmbed.style.display = 'none';
  canvasPC.parentElement.style.display = '';
  canvasVC.parentElement.style.display = '';
  // Restore Chart.js overlay button labels
  const _bbBtn  = document.getElementById('ovrBB');
  const _rsiBtn = document.getElementById('ovrRSI');
  const _sigBtn = document.getElementById('ovrSIG');
  const _volBtn = document.getElementById('ovrVOL');
  if (_bbBtn)  _bbBtn.textContent  = 'BB Bands';
  if (_rsiBtn) _rsiBtn.textContent = 'RSI';
  if (_sigBtn) _sigBtn.textContent = 'Signals';
  if (_volBtn) { _volBtn.textContent = 'Volume'; _volBtn.style.display = ''; _volBtn.classList.toggle('active', chartOverlays.VOL); }
  if (ovrRow) ovrRow.style.display = 'flex';
  // Show bottom indicator buttons, hide TV hint
  const _indRow = document.getElementById('chartIndicatorRow');
  if (_indRow) _indRow.style.display = 'flex';
  const _tvHint = document.getElementById('chartTVHint');
  if (_tvHint) _tvHint.style.display = 'none';
  _syncIndButtons('SIG', chartOverlays.SIG);
  _syncIndButtons('RSI', chartOverlays.RSI);

  const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
  const gridColor  = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
  const labelColor = isDark ? '#484848' : '#7a9ab5';

  const pCtx = document.getElementById('priceChart').getContext('2d');
  if (priceChartInst) priceChartInst.destroy();

  // Candlestick mode: hide price line; otherwise show a blue line as fallback
  const hasCandleData = !!(chartOHLC && chartOHLC.closes && chartOHLC.closes.length);
  const priceLineColor = hasCandleData ? 'transparent' : '#4d9fff';
  const priceLineBg    = hasCandleData ? 'transparent' : (() => {
    const g = pCtx.createLinearGradient(0, 0, 0, 240);
    g.addColorStop(0, 'rgba(77,159,255,0.18)'); g.addColorStop(1, 'rgba(77,159,255,0.00)');
    return g;
  })();
  const priceLineFill  = !hasCandleData;

  // BB band fill
  const bbGrad = pCtx.createLinearGradient(0, 0, 0, 240);
  bbGrad.addColorStop(0, 'rgba(255,255,255,0.035)');
  bbGrad.addColorStop(1, 'rgba(255,255,255,0.035)');

  // y-axis anchors so high/low wicks don't clip when candles are drawn
  const yMinData = hasCandleData ? chartOHLC.lows  : prices;
  const yMaxData = hasCandleData ? chartOHLC.highs : prices;

  priceChartInst = new Chart(pCtx, {
    type: 'line',
    plugins: [candlestickPlugin, levelLinesPlugin, crosshairPlugin],
    data: { labels, datasets: [
      // 0 — Price close line (visible as fallback when no OHLC; hidden when candles draw)
      { label:'Price', data:prices,
        borderColor: priceLineColor, backgroundColor: priceLineBg,
        borderWidth: hasCandleData ? 0 : 2,
        pointRadius:0, fill: priceLineFill, tension:0.1, order:10 },
      // 1 — Y-axis low anchor (always invisible — just widens y-scale for wick room)
      { label:'_low',  data: yMinData,
        borderColor:'transparent', backgroundColor:'transparent',
        borderWidth:0, pointRadius:0, fill:false, tension:0, order:11 },
      // 2 — Y-axis high anchor
      { label:'_high', data: yMaxData,
        borderColor:'transparent', backgroundColor:'transparent',
        borderWidth:0, pointRadius:0, fill:false, tension:0, order:12 },
      // 3 — EMA20
      { label:'EMA20', data:ema20, borderColor:'rgba(255,195,70,0.88)',
        borderWidth:1.4, pointRadius:0, fill:false, tension:0.1, order:2 },
      // 4 — EMA50
      { label:'EMA50', data:ema50, borderColor:'rgba(167,139,250,0.88)',
        borderWidth:1.4, pointRadius:0, fill:false, tension:0.1, order:3 },
      // 5 — BB Upper
      { label:'BB Upper', data:bbUpper, borderColor:'rgba(255,255,255,0.15)',
        borderWidth:1, borderDash:[3,3], pointRadius:0, fill:'+1',
        backgroundColor: bbGrad, tension:0.1, order:4, hidden:!chartOverlays.BB },
      // 6 — BB Lower
      { label:'BB Lower', data:bbLower, borderColor:'rgba(255,255,255,0.15)',
        borderWidth:1, borderDash:[3,3], pointRadius:0, fill:false,
        tension:0.1, order:5, hidden:!chartOverlays.BB },
    ]},
    options: {
      responsive:true, maintainAspectRatio:false,
      interaction:{ mode:'index', intersect:false },
      plugins:{ legend:{ display:false }, tooltip:{
        backgroundColor:'rgba(20,20,20,.96)', borderColor:'rgba(245,166,35,.2)', borderWidth:1,
        titleColor:'#888', bodyColor:'#f2f2f2', padding:12,
        filter: item => ['Price','EMA20','EMA50'].includes(item.dataset.label),
        callbacks:{
          title: items => labels[items[0]?.dataIndex] || '',
          label: ctx => {
            if (ctx.dataset.label === 'Price' && hasCandleData) {
              const i = ctx.dataIndex;
              const o = chartOHLC.opens[i],  h = chartOHLC.highs[i],
                    l = chartOHLC.lows[i],   c = chartOHLC.closes[i];
              return [` O: ${fmt(o)}  H: ${fmt(h)}`, ` L: ${fmt(l)}  C: ${fmt(c)}`];
            }
            return ` ${ctx.dataset.label}: ${fmt(ctx.raw)}`;
          }
        }
      }},
      scales:{
        x:{ grid:{color:gridColor}, ticks:{color:labelColor, maxTicksLimit:8, font:{size:10}} },
        y:{ grid:{color:gridColor}, ticks:{color:labelColor, font:{size:10}, callback:v=>fmt(v)}, position:'right' }
      }
    }
  });

  // ── RSI sub-chart ──
  if (rsiWrap) rsiWrap.style.display = chartOverlays.RSI && rsiData.length ? '' : 'none';
  if (rsiData.length) {
    const rCtx = document.getElementById('rsiChart').getContext('2d');
    if (rsiChartInst) rsiChartInst.destroy();

    // Colour RSI line: green when < 40, red when > 60, else muted
    const rsiColors = rsiData.map(v => v == null ? '#888' : v < 40 ? '#00c98d' : v > 60 ? '#ff524a' : '#aaa');
    const rsiGrad   = rCtx.createLinearGradient(0, 0, 0, 72);
    rsiGrad.addColorStop(0, 'rgba(255,82,74,0.12)');
    rsiGrad.addColorStop(0.5, 'rgba(255,255,255,0.0)');
    rsiGrad.addColorStop(1, 'rgba(0,201,141,0.12)');

    // RSI divergence overlay plugin
    const rsiDivPlugin = {
      id: 'rsiDiv',
      afterDraw(chart) {
        // Clear in-place (NOT reassign) so the event-listener closure keeps its reference
        _rsiHits.length = 0;
        if (!chartDivergence || !chartOverlays.RSI) return;
        const div = chartDivergence;
        if (!div.rsiBars || div.rsiBars.length < 2) return;
        const { ctx, scales: { x: xAx, y: yAx } } = chart;
        if (!xAx || !yAx) return;
        const color = div.isBull ? '#00c98d' : '#ff524a';
        const rb = div.rsiBars, rv = div.rsiVals;
        const b0 = Math.max(0, rb[0]), b1 = Math.max(0, rb[1]);
        const x0 = xAx.getPixelForValue(b0), x1 = xAx.getPixelForValue(b1);
        const y0 = yAx.getPixelForValue(rv[0] || 50), y1 = yAx.getPixelForValue(rv[1] || 50);
        if (!x0 || !x1) return;
        ctx.save();
        // Dashed line between the two RSI pivots
        ctx.beginPath();
        ctx.setLineDash([4, 3]);
        ctx.strokeStyle = color;
        ctx.lineWidth   = 1.8;
        ctx.globalAlpha = 0.85;
        ctx.moveTo(x0, y0); ctx.lineTo(x1, y1);
        ctx.stroke();
        ctx.setLineDash([]);
        // Filled circles at pivots + register hit targets
        [{ x:x0, y:y0, v:rv[0] }, { x:x1, y:y1, v:rv[1] }].forEach(pt => {
          ctx.beginPath();
          ctx.arc(pt.x, pt.y, 3.5, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.globalAlpha = 1;
          ctx.fill();
          // RSI value label
          ctx.font = 'bold 7px JetBrains Mono,monospace';
          ctx.fillStyle = color;
          ctx.textAlign = 'center';
          ctx.fillText(pt.v != null ? pt.v.toFixed(1) : '', pt.x, pt.y - 6);
          // Register hit target
          _rsiHits.push({ x: pt.x, y: pt.y, type: 'div', div });
        });
        // Badge label in centre
        const mx = (x0 + x1) / 2, my = (y0 + y1) / 2 - 10;
        ctx.font = 'bold 8px JetBrains Mono,monospace';
        const lbl = div.label || (div.isBull ? 'Bull Div' : 'Bear Div');
        const tw  = ctx.measureText(lbl).width;
        ctx.fillStyle = 'rgba(8,8,12,0.82)';
        ctx.fillRect(mx - tw/2 - 3, my - 9, tw + 6, 12);
        ctx.fillStyle = color;
        ctx.textAlign = 'center';
        ctx.fillText(lbl, mx, my);
        // Register hit target on the badge too
        _rsiHits.push({ x: mx, y: my, type: 'div', div });
        ctx.restore();
      }
    };

    rsiChartInst = new Chart(rCtx, {
      type: 'line',
      plugins: [crosshairPlugin, rsiDivPlugin, {
        id: 'rsiZones',
        beforeDraw(chart) {
          const { ctx, chartArea: {left,right,top,bottom}, scales:{y} } = chart;
          if (!y) return;
          ctx.save();
          // Overbought zone (60–100) — red tint
          const y60 = y.getPixelForValue(60), y100 = y.getPixelForValue(100);
          ctx.fillStyle = 'rgba(255,82,74,0.06)';
          ctx.fillRect(left, Math.min(y60,y100), right-left, Math.abs(y100-y60));
          // Oversold zone (0–40) — green tint
          const y0  = y.getPixelForValue(0),  y40  = y.getPixelForValue(40);
          ctx.fillStyle = 'rgba(0,201,141,0.06)';
          ctx.fillRect(left, Math.min(y0,y40), right-left, Math.abs(y40-y0));
          // Reference lines at 30, 40, 60, 70
          [[70,'rgba(255,82,74,0.3)'],[60,'rgba(255,82,74,0.5)'],
           [40,'rgba(0,201,141,0.5)'],[30,'rgba(0,201,141,0.3)']].forEach(([v,c]) => {
            const yp = y.getPixelForValue(v);
            ctx.beginPath();
            ctx.setLineDash([3,3]);
            ctx.strokeStyle = c;
            ctx.lineWidth = 0.8;
            ctx.moveTo(left, yp); ctx.lineTo(right, yp);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.font = '7px monospace';
            ctx.fillStyle = c;
            ctx.textAlign = 'right';
            ctx.fillText(v, right - 2, yp - 2);
          });
          ctx.restore();
        }
      }],
      data:{
        labels,
        datasets:[{
          label:'RSI', data:rsiData,
          borderColor: '#aaaaaa',
          segment:{ borderColor: ctx => {
            const v = ctx.p1.parsed.y;
            return v < 40 ? '#00c98d' : v > 60 ? '#ff524a' : 'rgba(255,255,255,0.35)';
          }},
          borderWidth:1.5, pointRadius:0, fill:false, tension:0.2,
        }]
      },
      options:{
        responsive:true, maintainAspectRatio:false,
        animation:{duration:0},
        interaction:{mode:'index',intersect:false},
        plugins:{legend:{display:false}, tooltip:{
          backgroundColor:'rgba(20,20,20,.96)', borderColor:'rgba(245,166,35,.2)', borderWidth:1,
          titleColor:'#888', bodyColor:'#f2f2f2', padding:8,
          callbacks:{label:ctx=>`RSI: ${ctx.raw != null ? ctx.raw.toFixed(1) : '—'}`}
        }},
        scales:{
          x:{display:false},
          y:{min:0, max:100, position:'right',
             grid:{color:gridColor},
             ticks:{color:labelColor, font:{size:8}, maxTicksLimit:3,
                    callback:v => v===50?'50':''}}
        }
      }
    });
  }

  const vCtx = document.getElementById('volChart').getContext('2d');
  if (volChartInst) volChartInst.destroy();
  const maxVol = Math.max(...vols.filter(v=>v>0)) || 1;
  const volColors = prices.map((p,i)=> i===0 ? 'rgba(245,166,35,.35)' : p>=(prices[i-1]||p) ? 'rgba(0,201,141,.5)' : 'rgba(255,68,89,.5)');

  volChartInst = new Chart(vCtx, {
    type:'bar',
    data:{labels,datasets:[{label:'Volume',data:vols,backgroundColor:volColors,borderWidth:0,borderRadius:1}]},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{
        backgroundColor:'rgba(20,20,20,.96)',borderColor:'rgba(245,166,35,.2)',borderWidth:1,
        callbacks:{label:ctx=>` Vol: ${fmtBig(ctx.raw)}`}
      }},
      scales:{x:{display:false},y:{display:false,max:maxVol*2}}
    }
  });

  document.getElementById('chartTitle').textContent = `${d.ticker} · ${d.timeframe.toUpperCase()} · ${d.ema_trend}`;

  // ── Synthetic data warning badge ──
  const _synthBadge = document.getElementById('synthWarnBadge');
  if (_synthBadge) _synthBadge.style.display = d.chart_synthetic ? '' : 'none';

  // ── Wire footprint + delta layer ──
  if (typeof _updateDeltaLayer === 'function') _updateDeltaLayer(d);
}

/* ════════════════════════════════════════════
   TRADE LEVELS
════════════════════════════════════════════ */
function renderLevels(d) {
  const entry = d.entry, sl = d.stop_loss;
  const isBuy = d.signal === 'BUY';

  // Rule tags shown per level
  const ruleTags = {
    tp1: `<span class="level-rule-tag close-half">Close 50%</span><span class="level-rule-tag move-be">SL → BE</span>`,
    tp2: `<span class="level-rule-tag close-qtr">Close 25%</span>`,
    tp3: `<span class="level-rule-tag close-rem">Close 25%</span>`,
  };

  const rows = [
    {name:'Entry',     cls:'entry', val:d.entry,     rr:null,  color:'var(--orange)', tag:''},
    {name:'Stop Loss', cls:'sl',    val:d.stop_loss, rr:null,  color:'var(--red)',    tag:''},
    {name:'TP1',       cls:'tp1',   val:d.tp1,       rr:d.rr1, color:'var(--green)', tag:ruleTags.tp1},
    {name:'TP2',       cls:'tp2',   val:d.tp2,       rr:d.rr2, color:'var(--green)', tag:ruleTags.tp2},
    {name:'TP3',       cls:'tp3',   val:d.tp3,       rr:d.rr3, color:'var(--green)', tag:ruleTags.tp3},
  ];
  document.getElementById('levelsTbody').innerHTML = rows.map(r => {
    if (r.val == null) return '';
    const distRaw = entry ? ((r.val - entry) / entry * 100) : null;
    const dist = r.cls === 'entry' ? 'Current' : (distRaw !== null ? distRaw.toFixed(2) + '%' : '—');
    const rrW  = r.rr ? Math.min(r.rr / 5 * 100, 100) : 0;
    const rrCell = r.cls === 'sl'
      ? `<span style="font-size:10px;font-weight:700;color:var(--red);">Max risk</span>`
      : `<span class="level-rr">${r.rr ? r.rr+':1' : '—'}</span>`;
    return `<tr>
      <td><span class="level-name ${r.cls}">${r.name}</span>${r.tag}</td>
      <td><span class="level-val">${fmt(r.val)}</span></td>
      <td><span class="stat-value" style="color:${r.cls==='entry'?'rgba(255,255,255,.35)':r.val>=(entry||0)?'var(--green)':'var(--red)'}">${dist}</span></td>
      <td>${rrCell}</td>
      <td><div class="rr-bar-wrap"><div class="rr-bar" style="width:${rrW}%;background:${r.color}"></div></div></td>
    </tr>`;
  }).join('');

  // Render trade management plan below table
  renderMgmtPlan(d);
}

