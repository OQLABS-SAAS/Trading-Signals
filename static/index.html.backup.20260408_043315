async function loadMarketPulse() {
  const el = document.getElementById('mktPulseContent');
  if (!el) return;
  try {
    const r = await fetch('https://api.alternative.me/fng/?limit=1');
    const j = await r.json();
    const item  = j.data[0];
    const val   = parseInt(item.value);
    const label = item.value_classification;
    const color = val <= 25 ? '#ff4459'
                : val <= 45 ? '#f5a623'
                : val <= 55 ? '#f0b429'
                : '#00c98d';
    const emoji = val <= 25 ? '😱'
                : val <= 45 ? '😟'
                : val <= 55 ? '😐'
                : val <= 75 ? '😊'
                : '🤑';
    const updated = new Date(parseInt(item.timestamp) * 1000)
      .toLocaleDateString(undefined, { month:'short', day:'numeric' });
    el.innerHTML = `
      <div class="pulse-gauge">
        <div class="pulse-num" style="color:${color}">${val} <span style="font-size:22px;">${emoji}</span></div>
        <div class="pulse-label" style="color:${color}">${label}</div>
        <div class="pulse-bar-wrap">
          <div class="pulse-bar">
            <div class="pulse-bar-dot" style="left:${val}%"></div>
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;width:100%;padding:0 2px;font-size:9px;color:var(--muted);">
          <span>Fear</span><span>Greed</span>
        </div>
        <div class="pulse-updated">Updated ${updated}</div>
      </div>`;
  } catch(e) {
    if (document.getElementById('mktPulseContent'))
      document.getElementById('mktPulseContent').innerHTML =
        '<div class="pulse-loading">Unavailable</div>';
  }
}

function fmt(v) {
  if (v==null) return '—';
  const n = parseFloat(v); if (isNaN(n)) return '—';
  if (n >= 10000) return n.toLocaleString(undefined,{maximumFractionDigits:2});
  if (n >= 100)   return n.toFixed(2);
  if (n >= 10)    return n.toFixed(3);
  if (n >= 1) {
    // Forex pairs (EUR/USD ~1.16xxx) need 4-5 dp; stocks in this range get trailing zeros stripped.
    // Show up to 5 decimal places, remove trailing zeros, always keep minimum 2 dp.
    return n.toFixed(5).replace(/(\.\d{2,}?)0+$/, '$1');
  }
  if (n >= 0.01)  return n.toFixed(5);
  return n.toFixed(6);
}
function fmtBig(v) {
  if (!v) return '0';
  if (v >= 1e9) return (v/1e9).toFixed(2)+'B';
  if (v >= 1e6) return (v/1e6).toFixed(2)+'M';
  if (v >= 1e3) return (v/1e3).toFixed(1)+'K';
  return v.toFixed(0);
}

