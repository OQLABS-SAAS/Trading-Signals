.calc-go-btn:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 4px 16px rgba(245,166,35,.35);}
.calc-result{margin-top:9px;background:rgba(0,201,141,.07);border:1px solid rgba(0,201,141,.18);border-radius:var(--radius-sm);padding:11px 13px;}
.calc-res-row{display:flex;justify-content:space-between;align-items:baseline;}
.calc-res-lbl{font-size:10px;font-weight:700;letter-spacing:.9px;text-transform:uppercase;color:rgba(0,201,141,.52);}
.calc-res-val{font-family:var(--mono);font-size:16px;font-weight:800;color:#00c98d;}
.calc-res-sub{font-size:10.5px;color:var(--text2);margin-top:5px;}
/* pip breakdown table */
.pip-section{margin-top:11px;border-top:1px solid var(--border);padding-top:11px;}
.pip-title{font-size:9.5px;font-weight:700;letter-spacing:1.3px;text-transform:uppercase;color:rgba(245,190,80,0.5);margin-bottom:9px;display:flex;align-items:center;gap:7px;}
.pip-title::after{content:'';flex:1;height:1px;background:var(--border);}
.pip-tbl{width:100%;border-collapse:collapse;}
.pip-tbl th{text-align:left;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(245,190,80,.42);padding:0 0 6px;}
.pip-tbl th:not(:first-child){text-align:right;}
.pip-tbl td{padding:6px 0;border-top:1px solid rgba(255,255,255,.04);vertical-align:middle;}
.pip-tbl td:not(:first-child){text-align:right;}
.pip-name{font-size:11.5px;font-weight:600;color:var(--text2);display:flex;align-items:center;gap:6px;}
.pip-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.pip-dot.entry{background:#00c98d;}
.pip-dot.sl{background:#ff4459;}
.pip-dot.tp{background:#4d9fff;}
.pip-px{font-family:var(--mono);font-size:11.5px;font-weight:700;}
.pip-dist{font-family:var(--mono);font-size:11.5px;font-weight:700;}
.pip-dist.dn{color:#ff6b7a;}
.pip-dist.up{color:#4d9fff;}
.pip-dist.ref{color:rgba(255,255,255,.25);font-size:10px;}
.pip-val{font-family:var(--mono);font-size:11.5px;font-weight:700;}
.pip-val.loss{color:#ff6b7a;}
.pip-val.profit{color:#00c98d;}
.pip-val.ref{color:rgba(255,255,255,.25);font-size:10px;}
.pip-rr{font-size:10.5px;font-weight:700;padding:2px 6px;border-radius:4px;}
.pip-rr.sl-rr{background:rgba(255,68,89,.1);color:#ff6b7a;}
.pip-rr.tp-rr{background:rgba(0,201,141,.1);color:#00c98d;}
.pip-rr.ref{color:rgba(255,255,255,.2);font-size:10px;}
.pip-note{margin-top:8px;padding:8px 10px;background:rgba(77,159,255,.06);border:1px solid rgba(77,159,255,.14);border-radius:7px;font-size:10.5px;color:rgba(255,255,255,.5);line-height:1.6;}
.pip-note strong{color:rgba(77,159,255,.85);}
/* ── Trade Summary (earn / lose) ── */
.trade-summary{border:1px solid rgba(255,255,255,.1);border-radius:9px;overflow:hidden;margin:10px 0;}
.trade-summary-title{font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(245,190,80,0.6);padding:7px 12px 6px;border-bottom:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.03);}
.trade-summary-row{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.05);}
.trade-summary-row:last-child{border-bottom:none;}
.trade-summary-row.loss-row{background:rgba(255,68,89,.05);}
.trade-summary-row.tp-row{background:rgba(0,201,141,.04);}
.ts-lhs{display:flex;align-items:center;gap:8px;}
.ts-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.ts-dot.sl{background:#ff4459;}
.ts-dot.tp{background:#00c98d;}
.ts-label{font-size:11px;font-weight:600;color:var(--text2);}
.ts-price{font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:1px;}
.ts-rhs{text-align:right;}
.ts-usd{font-family:var(--mono);font-size:14px;font-weight:800;}
.ts-usd.loss{color:#ff6b7a;}
.ts-usd.gain{color:#00c98d;}
.ts-rr{font-size:9.5px;font-weight:600;color:var(--muted);margin-top:2px;}
/* ── Calculator lot breakdown grid ── */
.calc-lots-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin:8px 0 10px;}
.calc-lot-cell{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:8px 6px;text-align:center;}
.calc-lot-type{font-size:8.5px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase;color:rgba(245,190,80,0.5);margin-bottom:4px;}
.calc-lot-val{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--text);}
.calc-lot-unit{font-size:8.5px;color:var(--muted);margin-top:2px;line-height:1.3;}
.calc-lot-cell.recommended{border-color:rgba(245,166,35,.55);background:rgba(245,166,35,.08);}
.calc-lot-cell.recommended .calc-lot-val{color:var(--orange);}
.calc-lot-cell.recommended .calc-lot-type{color:rgba(245,190,80,0.85);}
/* 5% cap warning */
.calc-cap-warn{background:rgba(255,68,89,.07);border:1px solid rgba(255,68,89,.22);border-radius:7px;padding:8px 11px;font-size:10.5px;color:rgba(255,110,100,.85);line-height:1.5;margin-bottom:8px;display:flex;gap:7px;align-items:flex-start;}
.calc-cap-warn-icon{font-size:13px;flex-shrink:0;margin-top:1px;}
/* Pip distance grid (SL + TP1/2/3) */
.calc-pipdist-title{font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(245,190,80,0.5);margin:10px 0 6px;display:flex;align-items:center;gap:7px;}
.calc-pipdist-title::after{content:'';flex:1;height:1px;background:var(--border);}
.calc-pipdist-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px;}
.calc-pipdist-cell{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:8px 10px;}
.calc-pipdist-cell.sl-cell{border-color:rgba(255,68,89,.25);background:rgba(255,68,89,.04);}
.calc-pipdist-cell.tp-cell{border-color:rgba(0,201,141,.18);background:rgba(0,201,141,.04);}
.calc-pipdist-lbl{font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;margin-bottom:3px;}
.calc-pipdist-lbl.sl{color:rgba(255,100,110,.75);}
.calc-pipdist-lbl.tp{color:rgba(0,201,141,.75);}
.calc-pipdist-pips{font-family:var(--mono);font-size:13px;font-weight:700;}
.calc-pipdist-pips.sl{color:#ff6b7a;}
.calc-pipdist-pips.tp{color:#00c98d;}
.calc-pipdist-sub{font-size:9px;color:var(--muted);margin-top:2px;}
.calc-sp.BUY{background:rgba(0,201,141,.14);color:#00c98d;border:1px solid rgba(0,201,141,.26);}
.calc-sp.SELL{background:rgba(255,68,89,.14);color:#ff4459;border:1px solid rgba(255,68,89,.26);}
.calc-st{font-weight:700;font-family:var(--mono);font-size:12px;}
.calc-stf{color:var(--muted);font-size:10px;}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════
     PASSWORD GATE (shown until login succeeds)
══════════════════════════════════════════ -->
<div id="passwordGate">
  <div class="gate-card">
    <div class="gate-logo">
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="gate-glow" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="3" result="blur"/>
