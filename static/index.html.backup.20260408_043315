// ═══════════════════════════════════════════════════════════
//  SIGNALS AUTO-REFRESH + STATE PERSISTENCE
// ═══════════════════════════════════════════════════════════
let _sigRefreshTimer    = null;
let _sigRefreshSecs     = 0;
let _sigLastRunTime     = null;
let _sigCountdownTimer  = null;

function sigSetRefresh(secs) {
  _sigRefreshSecs = secs;
  [0, 60, 300, 900].forEach(s => {
    const btn = document.getElementById('sigRef' + s);
    if (btn) btn.className = 'se-ref-btn' + (s === secs ? ' se-ref-active' : '');
  });
  if (_sigRefreshTimer)   { clearInterval(_sigRefreshTimer);   _sigRefreshTimer   = null; }
  if (_sigCountdownTimer) { clearInterval(_sigCountdownTimer); _sigCountdownTimer = null; }
  const lu = document.getElementById('sigLastUpdated');
  if (secs === 0) {
    if (lu) lu.style.display = 'none';
    localStorage.setItem('sigRefreshSecs', '0');
    return;
  }
  localStorage.setItem('sigRefreshSecs', String(secs));
  if (lu) lu.style.display = 'inline';
  // Run immediately then on interval
  runAnalyze();
  _sigRefreshTimer = setInterval(() => runAnalyze(), secs * 1000);
  // Countdown ticker
  _sigCountdownTimer = setInterval(() => {
    if (!_sigLastRunTime || !lu) return;
    const elapsed   = Math.round((Date.now() - _sigLastRunTime) / 1000);
    const remaining = Math.max(0, secs - elapsed);
    const mm = String(Math.floor(remaining / 60)).padStart(2, '0');
    const ss = String(remaining % 60).padStart(2, '0');
    lu.textContent = `🕐 Updated ${elapsed}s ago · next in ${mm}:${ss}`;
  }, 1000);
}

function _sigSaveState() {
  const state = {
    ticker:    (document.getElementById('tickerInput')?.value || '').trim().toUpperCase(),
    assetType: document.getElementById('assetType')?.value  || 'crypto',
    timeframe: document.getElementById('timeframe')?.value  || '1d',
  };
  localStorage.setItem('sigState', JSON.stringify(state));
}

function _sigRestoreState() {
  const saved = JSON.parse(localStorage.getItem('sigState') || '{}');
  if (saved.ticker) {
    const el = document.getElementById('tickerInput');
    if (el) el.value = saved.ticker;
  }
  if (saved.assetType) {
    const el = document.getElementById('assetType');
    if (el) el.value = saved.assetType;
    // Sync pill highlight
    document.querySelectorAll('[data-sel="assetType"]').forEach(b => {
      b.classList.toggle('active', b.dataset.val === saved.assetType);
    });
  }
  if (saved.timeframe) {
    const el = document.getElementById('timeframe');
    if (el) el.value = saved.timeframe;
    document.querySelectorAll('[data-sel="timeframe"]').forEach(b => {
      b.classList.toggle('active', b.dataset.val === saved.timeframe);
    });
  }
  // Restore refresh rate button highlight (don't auto-start — user decides)
  const savedSecs = parseInt(localStorage.getItem('sigRefreshSecs') || '0', 10);
  [0, 60, 300, 900].forEach(s => {
    const btn = document.getElementById('sigRef' + s);
    if (btn) btn.className = 'se-ref-btn' + (s === savedSecs ? ' se-ref-active' : '');
  });
  _sigRefreshSecs = savedSecs;
}

function runAnalyze() {
  const t = document.getElementById('tickerInput').value.trim().toUpperCase();
  if (!t) { showToast('Enter a ticker symbol'); return; }
  doAnalyze(t, document.getElementById('assetType').value, document.getElementById('timeframe').value);
}
function quickLoad(ticker, assetType, timeframe) {
  document.getElementById('tickerInput').value = ticker;
  document.getElementById('assetType').value   = assetType;
  document.getElementById('timeframe').value   = timeframe;
  doAnalyze(ticker, assetType, timeframe);
}
async function doAnalyze(ticker, assetType, timeframe) {
  _sigSaveState();
  _sigLastRunTime = Date.now();
  const lu = document.getElementById('sigLastUpdated');
  if (lu && _sigRefreshSecs > 0) { lu.style.display = 'inline'; lu.textContent = '🕐 Updating…'; }
  setLoading(true, `Analyzing ${ticker} on ${timeframe.toUpperCase()}…`);
  document.getElementById('emptyState').classList.add('hidden');
  document.getElementById('resultsArea').classList.add('hidden');
  // Reset backtest panel immediately so stale results from the previous run
  // are never visible while the new analysis is in flight
  const _btPanel = document.getElementById('backtestPanel');
  if (_btPanel) _btPanel.style.display = 'none';
  // Win rate badge is NOT reset here — it persists with the last known value
  // so it doesn't flash away during analysis. runBacktest() updates it on click.
  try {
    const r = await fetch('/api/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ticker,asset_type:assetType,timeframe})});
    if (!r.ok) {
      let errMsg = `Server error ${r.status}`;
      try { const ed = await r.json(); if (ed.error) errMsg = ed.error; } catch(_) {}
      showError(errMsg); return;
    }
    const d = await r.json();
    if (d.error) { showError(d.error); return; }
    currentData = d;
    isWatching = false;
    pushRecentInstrument(d.ticker, d.asset_type, d.timeframe);
    try {
      renderResults(d);
      addToHistory(d);
      // Silent background run — only populates the win rate badge, panel stays hidden.
      // The full Strategy Report panel only appears when the user clicks the button.
      runBacktest(d, false);
    } catch(renderErr) {
      console.error('[dotverse] renderResults error:', renderErr);
      showError('Display error: ' + (renderErr && renderErr.message ? renderErr.message : String(renderErr)));
    }
  } catch(e) {
    console.error('[dotverse] fetch error:', e);
    showError(e && e.message && !e.message.includes('fetch') ? 'Error: ' + e.message : 'Network error — check connection and try again.');
  } finally {
    setLoading(false);
    // Update last-updated label if auto-refresh is active
    const lu2 = document.getElementById('sigLastUpdated');
    if (lu2 && _sigRefreshSecs > 0) {
      const t = new Date().toLocaleTimeString([], { hour:'2-digit', minute:'2-digit', second:'2-digit' });
      lu2.style.display = 'inline';
      lu2.textContent   = `🕐 Updated at ${t}`;
    }
  }
}

