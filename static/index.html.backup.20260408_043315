async function runScanner() {
  const preset = document.getElementById('scanPreset').value;
  const tf     = document.getElementById('scanTF').value;
  const p = SCAN_PRESETS[preset];
  if (!p) return;
  const btn = document.getElementById('scanBtn');
  btn.disabled = true; btn.textContent = '⏳ Scanning…';
  document.getElementById('scanResults').innerHTML = '<div style="font-size:11px;color:var(--muted);padding:6px 0;">Scanning — may take 20–40s…</div>';
  try {
    const r = await fetch('/api/scan-list',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tickers:p.tickers,asset_type:p.asset_type,timeframe:tf})});
    const data = await r.json();
    renderScanResults(data.results || [], p.asset_type);
  } catch(e) {
    document.getElementById('scanResults').innerHTML = '<div style="font-size:11px;color:var(--red);">Scan failed. Try again.</div>';
  } finally { btn.disabled=false; btn.textContent='⚡ Run Scan'; }
}

function renderScanResults(results, assetType) {
  if (!results.length) { document.getElementById('scanResults').innerHTML = '<div style="font-size:11px;color:var(--muted);">No results.</div>'; return; }
  document.getElementById('scanResults').innerHTML = results.map(r => {
    if (r.error) return `<div class="scan-row"><span class="scan-ticker">${r.ticker}</span><span style="font-size:10px;color:var(--red);">ERR</span></div>`;
    const hint = r.signal_hint || 'HOLD';
    const cls  = hint==='BUY'||hint==='COUNTER_BUY'?'up':hint==='SELL'?'down':'';
    const chg  = r.chg_1d >= 0 ? `+${r.chg_1d}%` : `${r.chg_1d}%`;
    const pillCls = hint==='BUY'||hint==='POSSIBLE_BUY'?'BUY':hint==='SELL'||hint==='POSSIBLE_SELL'?'SELL':hint==='COUNTER_BUY'?'CTR':'HOLD';
    const pillLbl = hint==='COUNTER_BUY'?'CTR':hint==='POSSIBLE_BUY'?'PBY':hint==='POSSIBLE_SELL'?'PSL':hint;
    return `<div class="scan-row" onclick="quickLoad('${r.ticker}','${assetType}','${document.getElementById('scanTF').value}')">
      <span class="scan-ticker">${r.ticker}</span>
      <span class="scan-rsi">RSI ${r.rsi}</span>
      <span class="scan-chg ${cls}">${chg}</span>
      <span class="sig-pill ${pillCls}">${pillLbl}</span>
    </div>`;
  }).join('');
}

