    html += d.rules.map(r => `<div style="font-size:9.5px;color:var(--text2);padding:2px 0;">${r}</div>`).join('');
    html += `<div style="margin-top:6px;font-size:9.5px;font-style:italic;color:var(--muted);border-top:1px solid rgba(255,255,255,.06);padding-top:5px;">"${d.mindset}"</div>`;

  } else if (d.period === 'weekly') {
    html += stratCard(d.primary_strategy);
    html += `<div style="font-size:9px;color:var(--text2);margin-bottom:5px;font-weight:600;">${d.goal}</div>`;
    html += `<div style="font-size:8.5px;color:var(--muted);letter-spacing:.6px;margin-bottom:3px;">DAILY SCHEDULE</div>`;
    html += d.daily_schedule.map(ds =>
      `<div style="display:flex;gap:7px;padding:3px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:9.5px;">
        <span style="color:var(--orange);font-weight:700;width:60px;flex-shrink:0;">${ds.day.slice(0,3)}</span>
        <span style="color:var(--text2);">${ds.task}</span>
      </div>`
    ).join('');
    html += `<div style="margin-top:6px;padding:5px 8px;background:rgba(0,201,141,.06);border:1px solid rgba(0,201,141,.15);border-radius:5px;">`;
    html += d.rules.map(r => `<div style="font-size:9px;color:var(--text2);padding:1px 0;">${r}</div>`).join('');
    html += `</div>`;
    html += `<div style="margin-top:5px;font-size:9.5px;font-style:italic;color:var(--muted);">"${d.mindset}"</div>`;

  } else { // monthly
    html += `<div style="font-size:9.5px;color:var(--text2);margin-bottom:7px;">${d.monthly_goal}</div>`;
    html += d.week_plans.map(wp =>
      `<div style="margin-bottom:6px;padding:6px 8px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:5px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;">
          <span style="font-size:9.5px;font-weight:700;color:var(--orange);">${wp.week}</span>
          <span style="font-size:8.5px;padding:1px 6px;border-radius:10px;background:rgba(255,255,255,.06);color:var(--text2);">${wp.mode}</span>
        </div>
        <div style="font-size:10px;font-weight:700;color:var(--text);margin-bottom:2px;">${wp.strategy.name} ${wrBadge(wp.strategy)}</div>
        <div style="font-size:9px;color:var(--text2);">${wp.focus}</div>
      </div>`
    ).join('');
    html += `<div style="padding:5px 8px;background:rgba(77,159,255,.05);border:1px solid rgba(77,159,255,.12);border-radius:5px;">`;
    html += d.rules.map(r => `<div style="font-size:9px;color:var(--text2);padding:1px 0;">${r}</div>`).join('');
    html += `</div>`;
    html += `<div style="margin-top:5px;font-size:9.5px;font-style:italic;color:var(--muted);">"${d.mindset}"</div>`;
  }

  // Qualified strategies summary
  html += `<div style="margin-top:8px;border-top:1px solid rgba(255,255,255,.06);padding-top:6px;">
    <div style="font-size:8.5px;color:var(--muted);letter-spacing:.6px;margin-bottom:4px;">${d.qualified_count} STRATEGIES MEETING YOUR WIN RATE FILTER:</div>
    <div style="display:flex;gap:3px;flex-wrap:wrap;">
    ${(d.all_qualified||[]).map(s=>`<span style="font-size:8.5px;font-weight:700;padding:2px 6px;border-radius:10px;background:rgba(245,166,35,.1);color:#f5a623;border:1px solid rgba(245,166,35,.2);">${s.code} ${Math.round(s.win_rate*100)}%</span>`).join('')}
    </div>
  </div>`;

  el.innerHTML = html;
  el.style.display = 'block';
}
