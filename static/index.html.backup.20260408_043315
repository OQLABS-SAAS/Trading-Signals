  }
}

/* ── Rebuild TV iframe with current tvStudies toggles ── */
function rebuildTVEmbed() {
  const tvEmbed = document.getElementById('tvChartEmbed');
  if (!tvEmbed) return;
  let src = 'https://s.tradingview.com/widgetembed/?frameElementId=tv_embed' +
            '&symbol='   + encodeURIComponent(tvParams.sym) +
            '&interval=' + tvParams.ivl +
            '&theme='    + tvParams.theme +
            '&style=1&locale=en&hide_top_toolbar=0&hide_legend=0&save_image=0&allow_symbol_change=0' +
            '&hide_volume=0&no_timeframe_change=1';
  if (tvStudies.BB)  src += '&studies[]=BB%40tv-basicstudies';
  if (tvStudies.RSI) src += '&studies[]=RSI%40tv-basicstudies';
  if (tvStudies.SIG) src += '&studies[]=MACD%40tv-basicstudies';

  // Show a brief loading overlay so the user sees something is happening
  tvEmbed.style.position = 'relative';
  const loadDiv = document.createElement('div');
  loadDiv.id = 'tvReloadOverlay';
  loadDiv.style.cssText = 'position:absolute;inset:0;z-index:10;display:flex;align-items:center;justify-content:center;' +
                          'background:rgba(0,0,0,.55);border-radius:8px;color:rgba(255,255,255,.7);font-size:12px;letter-spacing:.5px;';
  loadDiv.textContent = 'Reloading chart…';

  const existing = tvEmbed.querySelector('iframe');
  if (existing) {
    // Reuse the existing iframe - just update src (avoids full DOM removal)
    const old = document.getElementById('tvReloadOverlay');
    if (old) old.remove();
    tvEmbed.appendChild(loadDiv);
    existing.onload = () => { const o = document.getElementById('tvReloadOverlay'); if (o) o.remove(); };
    existing.src = src;
  } else {
    // First render — create fresh iframe
    const iframe = document.createElement('iframe');
    iframe.src = src;
    iframe.style.cssText = 'width:100%;height:420px;border:none;border-radius:8px;display:block;';
    iframe.setAttribute('allowtransparency', 'true');
    iframe.setAttribute('scrolling', 'no');
    tvEmbed.appendChild(loadDiv);
    iframe.onload = () => { const o = document.getElementById('tvReloadOverlay'); if (o) o.remove(); };
    tvEmbed.innerHTML = '';
    tvEmbed.appendChild(iframe);
  }
}

