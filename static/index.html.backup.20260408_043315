<div class="resize-handle" id="resizeLeft" title="Drag to resize"></div>

<!-- ─── MAIN CONTENT ─── -->
<main class="main-content">

  <!-- SEARCH -->
  <div class="search-panel">
    <input class="ticker-input" id="tickerInput" placeholder="Enter ticker (BTC, AAPL, EURUSD, GOLD, SPX…)" onkeydown="if(event.key==='Enter')runAnalyze()">

    <!-- Hidden selects for JS compatibility -->
    <select id="assetType" style="display:none;">
      <option value="crypto">Crypto</option><option value="stock">Stock</option>
      <option value="forex">Forex</option><option value="commodity">Commodity</option><option value="index">Index</option>
