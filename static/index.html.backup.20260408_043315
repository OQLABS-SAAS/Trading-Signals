[rPL1_idx, rPL1_val] = findLastPivot(rsiLow,    lookback)
[rPL2_idx, rPL2_val] = findPrevPivot(rsiLow,    rPL1_idx, lookback)

[pPH1_idx, pPH1_val] = findLastPivot(priceHigh, lookback)
[pPH2_idx, pPH2_val] = findPrevPivot(priceHigh, pPH1_idx, lookback)
[pPL1_idx, pPL1_val] = findLastPivot(priceLow,  lookback)
[pPL2_idx, pPL2_val] = findPrevPivot(priceLow,  pPL1_idx, lookback)


