function highlightChart(overlayKeys) {
  const card = document.querySelector('.chart-card');
  if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });

  if (tvMode) {
    // TV embed: just flash border — can't inject overlays into cross-origin iframe
    const tvEmbed = document.getElementById('tvChartEmbed');
    if (tvEmbed && tvEmbed.style.display !== 'none') {
      tvEmbed.style.transition = 'box-shadow .15s';
      tvEmbed.style.boxShadow  = '0 0 0 2px rgba(245,166,35,.7), 0 0 20px rgba(245,166,35,.25)';
      setTimeout(() => { tvEmbed.style.boxShadow = ''; }, 800);
