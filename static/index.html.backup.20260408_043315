</div>

<!-- TICKER TAPE (built by JS) -->
<div class="tape-wrapper"><div class="tape-track" id="tapeTrack"></div></div>

<!-- HEADER -->
<header>
  <div class="header-left">
    <div class="logo">
      <div class="logo-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="dv-glow" x="-150%" y="-150%" width="400%" height="400%">
