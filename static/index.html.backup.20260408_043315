<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DotVerse — Trading Signals</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  /* ── Pure black foundation (BloFin-inspired) ── */
  --bg:#080808;--bg2:#0e0e0e;--surface:#161616;--surface2:#1c1c1c;--surface3:#242424;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#f2f2f2;--text2:#888;--muted:#484848;
  /* ── Keep green ONLY for BUY signals & positive price changes ── */
  --green:#00c98d;--green-d:#00a87a;--green-bg:rgba(0,201,141,.08);
  --red:#ff4459;--red-d:#cc2244;--red-bg:rgba(255,68,89,.08);
  --blue:#4d9fff;--blue-bg:rgba(77,159,255,.08);
  --yellow:#C8973D;--yellow-bg:rgba(200,151,61,.09);
  --purple:#a78bfa;
  /* ── ORANGE / AMBER = primary brand accent (replaces teal) ── */
  --orange:#f5a623;--orange-d:#d98b0e;--orange-bg:rgba(245,166,35,.1);
  --accent:#f5a623;--accent-bg:rgba(245,166,35,.1);
  --mono:'JetBrains Mono',monospace;--sans:'Inter',sans-serif;
  --radius:12px;--radius-sm:8px;
  --shadow:0 8px 40px rgba(0,0,0,.7);
  --glow-orange:none;
  --glow-green:none;
  --tape-h:36px;--header-h:58px;
}
[data-theme="light"] {
  --bg:#f0f4f8;--bg2:#e4ebf2;--surface:#fff;--surface2:#f7fafc;--surface3:#edf2f7;
  --border:#d1dce8;--border2:#b8ccdd;--text:#1a2840;--text2:#3d5a72;--muted:#7a9ab5;
  --green-bg:rgba(0,181,137,.1);--red-bg:rgba(220,50,80,.1);
  --blue-bg:rgba(40,130,230,.1);--yellow-bg:rgba(200,150,0,.1);--orange-bg:rgba(200,100,0,.1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{font-size:14px;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.5;overflow-x:hidden;min-height:100vh;}
/* Subtle radial spotlight — very restrained amber glow, pushed above viewport */
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 55% 30% at 50% -25%,rgba(245,166,35,.05) 0%,transparent 65%);}
button{cursor:pointer;font-family:var(--sans);}
input,select,textarea{font-family:var(--sans);}

/* TICKER TAPE */
.tape-wrapper{height:var(--tape-h);background:#0a0a0a;border-bottom:1px solid var(--border);overflow:hidden;position:relative;z-index:1;}
.tape-wrapper::before,.tape-wrapper::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none;}
.tape-wrapper::before{left:0;background:linear-gradient(to right,#0a0a0a,transparent);}
.tape-wrapper::after{right:0;background:linear-gradient(to left,#0a0a0a,transparent);}
.tape-track{display:flex;align-items:center;height:100%;white-space:nowrap;animation:tape-scroll 60s linear infinite;}
.tape-track:hover{animation-play-state:paused;}
@keyframes tape-scroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.tape-item{display:inline-flex;align-items:center;gap:7px;padding:0 18px;border-right:1px solid rgba(255,255,255,0.05);font-size:12px;}
.tape-symbol{font-family:var(--mono);font-weight:700;color:rgba(255,255,255,0.7);font-size:11px;letter-spacing:.3px;}
.tape-price{font-family:var(--mono);color:var(--text);font-size:11px;font-weight:600;}
.tape-chg{font-family:var(--mono);font-size:11px;font-weight:600;}
.tape-chg.up{color:var(--green);}.tape-chg.down{color:var(--red);}

/* HEADER */
header{height:var(--header-h);background:rgba(8,8,8,.92);border-bottom:1px solid var(--border);box-shadow:0 1px 0 rgba(255,255,255,.03),0 4px 24px rgba(0,0,0,.5);display:flex;align-items:center;justify-content:space-between;padding:0 22px;position:sticky;top:var(--tape-h);z-index:50;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);}
.header-left{display:flex;align-items:center;gap:20px;}
.logo{display:flex;align-items:center;gap:12px;font-size:17px;letter-spacing:-.5px;flex-shrink:0;}
/* dot-verse wordmark — "dot" in amber, "·" as the brand dot, "verse" in white */
.logo-word{display:flex;align-items:baseline;gap:0;font-weight:800;}
.logo-dot{color:var(--orange);font-weight:900;}
.logo-separator{color:var(--orange);font-weight:900;font-size:20px;line-height:1;margin:0 1px;opacity:.9;}
.logo-verse{color:rgba(255,255,255,0.85);font-weight:300;letter-spacing:-.2px;}
/* The icon: dot-verse SVG mark — glowing center dot with concentric rings */
.logo-icon{width:34px;height:34px;flex-shrink:0;display:flex;align-items:center;justify-content:center;position:relative;}
.logo-icon svg{overflow:visible;}
.logo-badge{font-size:9px;font-weight:700;letter-spacing:.7px;background:rgba(245,166,35,.08);color:var(--orange);border:1px solid rgba(245,166,35,.2);padding:2px 9px;border-radius:20px;white-space:nowrap;}
.header-right{display:flex;align-items:center;gap:12px;}
.sessions-row{display:flex;align-items:center;gap:8px;}
.session-dot{display:flex;align-items:center;gap:5px;font-size:10.5px;font-weight:600;color:rgba(255,255,255,.2);letter-spacing:.3px;padding:3px 8px;border-radius:20px;border:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.02);transition:all .3s;}
.session-dot .dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.18);flex-shrink:0;transition:all .3s;}
.session-dot.open{color:var(--orange);border-color:rgba(245,166,35,.28);background:rgba(245,166,35,.07);}
.session-dot.open .dot{background:var(--orange);box-shadow:0 0 7px var(--orange);animation:pulse-dot 2s ease-in-out infinite;}
.session-dot.crypto-open{color:#00c98d;border-color:rgba(0,201,141,.28);background:rgba(0,201,141,.07);}
.session-dot.crypto-open .dot{background:#00c98d;box-shadow:0 0 7px #00c98d;animation:pulse-dot 2s ease-in-out infinite;}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:.4;}}
.clock{font-family:var(--mono);font-size:12px;color:var(--text2);background:var(--surface);border:1px solid var(--border);padding:4px 10px;border-radius:var(--radius-sm);}
.theme-btn{background:var(--surface);border:1px solid var(--border);color:var(--text2);padding:6px 10px;border-radius:var(--radius-sm);font-size:14px;transition:all .2s;}
.theme-btn:hover{border-color:rgba(245,166,35,.4);color:var(--orange);}

/* APP GRID — columns controlled by JS via CSS vars for resizability */
.app-grid{
  display:flex;flex-direction:row;
  min-height:calc(100vh - var(--tape-h) - var(--header-h));
  overflow:hidden;
}
.sidebar-left{width:var(--lw,230px);min-width:160px;max-width:420px;flex-shrink:0;}
.sidebar-right{width:var(--rw,270px);min-width:180px;max-width:420px;flex-shrink:0;}
.main-content{flex:1;min-width:0;}
@media(max-width:1300px){.sidebar-right{display:none!important;}}
@media(max-width:900px){.sidebar-left{display:none!important;}.resize-handle{display:none!important;}}

/* LEFT SIDEBAR */
.sidebar-left{border-right:1px solid var(--border);background:var(--bg2);overflow-y:auto;display:flex;flex-direction:column;}
.sidebar-section{border-bottom:1px solid var(--border);padding:14px 16px;}
.sidebar-title{font-size:12px;font-weight:700;color:var(--text);margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;gap:6px;}
.sidebar-title .count{background:var(--surface2);color:var(--text2);font-size:10px;padding:1px 6px;border-radius:10px;letter-spacing:0;font-weight:600;}

/* Watchlist */
.wl-item{display:flex;align-items:center;justify-content:space-between;padding:7px 8px;border-radius:var(--radius-sm);cursor:pointer;transition:background .15s;margin-bottom:2px;}
.wl-item:hover{background:var(--surface2);}
.wl-symbol{font-family:var(--mono);font-weight:700;font-size:12px;color:var(--text);}
.wl-type{font-size:10px;color:var(--text2);text-transform:uppercase;}
.wl-price{font-family:var(--mono);font-size:11px;color:var(--text2);}
.sig-pill{font-size:9px;font-weight:700;letter-spacing:.5px;padding:2px 6px;border-radius:4px;text-transform:uppercase;}
.sig-pill.BUY{background:rgba(0,201,141,0.14);color:#00c98d;border:1px solid rgba(0,201,141,0.30);}
.sig-pill.SELL{background:rgba(255,82,70,0.12);color:rgba(255,110,100,0.88);border:1px solid rgba(255,82,70,0.26);}
.sig-pill.HOLD{background:rgba(48,209,88,0.12);color:rgba(48,209,88,0.88);border:1px solid rgba(48,209,88,0.26);}
.sig-pill.CTR{background:rgba(200,151,61,0.12);color:rgba(200,151,61,0.85);border:1px solid rgba(200,151,61,0.28);}
.add-wl-row{display:flex;flex-direction:column;gap:5px;margin-top:8px;}
.add-wl-inner{display:flex;gap:5px;}
.add-wl-input{flex:1;min-width:0;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:5px 8px;border-radius:var(--radius-sm);font-size:12px;outline:none;transition:border-color .2s;}
.add-wl-input:focus{border-color:rgba(245,166,35,.45);}
.add-wl-btn{background:var(--surface2);border:1px solid var(--border);color:var(--text2);padding:5px 9px;border-radius:var(--radius-sm);font-size:14px;transition:all .15s;}
.add-wl-btn:hover{color:var(--orange);border-color:var(--orange);}

/* BUY Scanner */
.buy-scan-hdr{display:flex;align-items:center;gap:7px;margin-bottom:10px;}
.buy-scan-badge{background:rgba(0,201,141,.15);border:1px solid rgba(0,201,141,.3);color:#00c98d;font-size:9px;font-weight:800;letter-spacing:1.2px;padding:2px 7px;border-radius:20px;text-transform:uppercase;}
.buy-scan-btn{background:linear-gradient(135deg,#00c98d,#00866a);color:#000;border:none;padding:8px;border-radius:var(--radius-sm);font-size:12px;font-weight:800;width:100%;letter-spacing:.3px;cursor:pointer;transition:all .18s;margin-top:5px;}
.buy-scan-btn:hover{opacity:.9;transform:translateY(-1px);}
.buy-scan-btn:disabled{opacity:.5;cursor:wait;transform:none;}
.buy-progress{margin:7px 0;padding:6px 8px;background:var(--surface2);border-radius:6px;}
.buy-progress-bar-wrap{height:3px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden;margin-top:5px;}
.buy-progress-bar{height:100%;background:#00c98d;border-radius:2px;transition:width .35s ease;}
.buy-scan-empty{font-size:11px;color:var(--muted);padding:10px 0;text-align:center;line-height:1.5;}
.buy-result-row{display:flex;align-items:center;gap:6px;padding:7px 8px;border-radius:8px;cursor:pointer;margin-bottom:3px;transition:background .14s;border:1px solid transparent;}
.buy-result-row:hover{background:rgba(0,201,141,.06);border-color:rgba(0,201,141,.18);}
.buy-result-ticker{font-family:var(--mono);font-size:11.5px;font-weight:700;color:var(--text);flex:1;}
.buy-result-rsi{font-family:var(--mono);font-size:10px;}
.buy-result-type{font-size:9px;font-weight:600;color:var(--muted);background:var(--surface2);padding:1px 5px;border-radius:4px;text-transform:uppercase;letter-spacing:.4px;}
/* Scanner */
.scan-controls{display:flex;flex-direction:column;gap:5px;}
.scan-select{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:6px 8px;border-radius:var(--radius-sm);font-size:12px;outline:none;width:100%;}
.scan-btn{background:linear-gradient(135deg,var(--orange),#ff8800);color:#000;border:none;padding:7px;border-radius:var(--radius-sm);font-size:12px;font-weight:800;transition:all .2s;width:100%;letter-spacing:.3px;}
.scan-btn:hover{opacity:.88;box-shadow:none;}.scan-btn:disabled{opacity:.5;cursor:wait;}
.scan-row{display:flex;align-items:center;gap:6px;padding:6px 7px;border-radius:var(--radius-sm);cursor:pointer;margin-bottom:2px;transition:background .15s;}
.scan-row:hover{background:var(--surface2);}
.scan-ticker{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--text);flex:1;}
.scan-rsi{font-family:var(--mono);font-size:10px;color:var(--text2);}
.scan-chg{font-family:var(--mono);font-size:10px;font-weight:600;}

/* MAIN CONTENT */
.main-content{overflow-y:auto;background:transparent;padding:18px;display:flex;flex-direction:column;gap:16px;position:relative;z-index:1;}

/* SEARCH */
.search-panel{display:flex;gap:10px;flex-wrap:wrap;background:var(--surface);border:1px solid var(--border);padding:14px 16px;border-radius:var(--radius);backdrop-filter:blur(10px);}
.ticker-input{flex:1;min-width:120px;background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:0 16px;border-radius:var(--radius-sm);font-size:15px;font-weight:700;font-family:var(--mono);outline:none;height:44px;letter-spacing:.5px;text-transform:uppercase;transition:border-color .2s,box-shadow .2s;}
.ticker-input::placeholder{text-transform:none;font-weight:400;font-size:13px;letter-spacing:0;color:var(--muted);}
.ticker-input:focus{border-color:rgba(245,166,35,.5);box-shadow:0 0 0 3px rgba(245,166,35,.08);}
.ctrl-select{background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:0 10px;border-radius:var(--radius-sm);font-size:13px;height:44px;outline:none;cursor:pointer;}
.analyze-btn{background:linear-gradient(135deg,var(--orange),#ff8800);color:#000;border:none;padding:0 24px;border-radius:var(--radius-sm);font-size:14px;font-weight:800;height:44px;letter-spacing:.3px;transition:all .2s;white-space:nowrap;}
.analyze-btn:hover{opacity:.9;box-shadow:0 0 28px rgba(245,166,35,.4);}.analyze-btn:disabled{opacity:.5;cursor:wait;}

/* LOADING */
.loading-state{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:60px 20px;color:var(--muted);}
.spinner{width:36px;height:36px;border:3px solid var(--surface3);border-top-color:var(--orange);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading-label{font-size:13px;font-weight:500;}

/* EMPTY STATE */
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);}
.empty-icon{font-size:44px;margin-bottom:16px;opacity:0.35;}
.empty-title{font-size:22px;font-weight:800;color:var(--text);margin-bottom:10px;letter-spacing:-.3px;}
.empty-sub{font-size:13px;max-width:400px;margin:0 auto 22px;color:var(--text2);line-height:1.7;}
.empty-examples{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
.example-chip{background:var(--surface);border:1px solid var(--border);color:var(--text2);padding:7px 14px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--mono);transition:all .15s;}
.example-chip:hover{border-color:rgba(245,166,35,.55);color:#f5c842;background:rgba(245,166,35,.08);box-shadow:0 0 0 1px rgba(245,166,35,.22),0 0 14px rgba(245,166,35,.18);}
.example-chip:active{box-shadow:0 0 0 2px rgba(245,166,35,.45),0 0 22px rgba(245,166,35,.28);}
/* Instrument quick-select tabs */
.inst-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:14px;flex-wrap:wrap;justify-content:center;}
.inst-tab{padding:9px 16px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .18s;white-space:nowrap;border-radius:4px 4px 0 0;}
.inst-tab:hover{color:#f5c842;border-bottom-color:rgba(245,166,35,.4);background:rgba(245,166,35,.06);text-shadow:0 0 12px rgba(245,166,35,.35);}
.inst-tab.active{color:#f5c842;border-bottom-color:rgba(245,166,35,.9);text-shadow:0 0 10px rgba(245,166,35,.3);}
.inst-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:7px;max-width:640px;margin:0 auto;}
@media(max-width:700px){.inst-grid{grid-template-columns:repeat(4,1fr);}}
@media(max-width:450px){.inst-grid{grid-template-columns:repeat(3,1fr);}}
.inst-chip{background:var(--surface);border:1px solid var(--border);color:var(--text2);padding:9px 4px;border-radius:10px;font-size:11px;font-weight:700;cursor:pointer;font-family:var(--mono);transition:all .18s;text-align:center;line-height:1.3;}
.inst-chip:hover{border-color:rgba(245,166,35,.55);color:#f5c842;background:rgba(245,166,35,.08);transform:translateY(-1px);box-shadow:0 0 0 1px rgba(245,166,35,.22),0 0 16px rgba(245,166,35,.2);}
.inst-chip:active{border-color:rgba(245,166,35,.7);color:#f5c842;background:rgba(245,166,35,.13);transform:translateY(0);box-shadow:0 0 0 2px rgba(245,166,35,.42),0 0 22px rgba(245,166,35,.3);}
.inst-chip .chip-tf{display:block;font-size:9px;font-weight:400;color:var(--muted);margin-top:2px;letter-spacing:.3px;}

/* ASSET HEADER */
/* ── INSTRUMENT SWITCHER BAR ── */
.inst-switch-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:10px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:0;}
.inst-switch-label{font-size:10px;font-weight:700;letter-spacing:1.3px;text-transform:uppercase;color:rgba(245,190,80,0.55);white-space:nowrap;flex-shrink:0;}
.inst-chips{display:flex;gap:6px;flex-wrap:wrap;flex:1;}
.inst-chip{font-family:var(--mono);font-size:11px;font-weight:700;padding:4px 11px;border-radius:20px;border:1px solid var(--border);background:var(--surface);color:var(--text2);cursor:pointer;transition:all .15s;white-space:nowrap;letter-spacing:.3px;}
.inst-chip:hover{border-color:var(--orange);color:var(--orange);}
.inst-chip.active{background:var(--orange);color:#000;border-color:var(--orange);box-shadow:0 0 10px rgba(245,166,35,.25);}
.inst-switch-input-wrap{display:flex;gap:6px;align-items:center;}
.inst-switch-input{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:4px 10px;border-radius:var(--radius-sm);font-size:12px;font-family:var(--mono);font-weight:700;outline:none;width:100px;letter-spacing:.4px;text-transform:uppercase;height:28px;}
.inst-switch-input::placeholder{text-transform:none;font-weight:400;letter-spacing:0;font-size:11px;}
.inst-switch-input:focus{border-color:rgba(245,166,35,.5);}
.inst-switch-go{background:linear-gradient(135deg,var(--orange),#ff8800);border:none;color:#000;font-weight:800;font-size:11px;padding:4px 12px;border-radius:var(--radius-sm);cursor:pointer;height:28px;transition:opacity .15s;letter-spacing:.3px;}
.inst-switch-go:hover{opacity:.85;}
.asset-header{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);border-top-left-radius:0;border-top-right-radius:0;border-top:none;padding:16px 20px;display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;backdrop-filter:blur(10px);}
.asset-ticker{font-family:var(--mono);font-size:21px;font-weight:800;letter-spacing:-.2px;}
.asset-meta{font-size:12px;color:var(--text2);display:flex;gap:6px;align-items:center;margin-top:3px;}
.asset-meta .am-type{font-size:9.5px;font-weight:700;letter-spacing:.6px;padding:2px 7px;border-radius:4px;background:rgba(245,166,35,.1);color:var(--orange);border:1px solid rgba(245,166,35,.22);}
.asset-meta .am-tf{font-family:var(--mono);font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:4px;background:rgba(77,159,255,.1);color:#4d9fff;border:1px solid rgba(77,159,255,.22);}
.asset-meta .am-sep{color:var(--muted);}
/* DotVerse Trade Analysis narrative block */
.dv-analysis-block{background:var(--surface);border:1px solid rgba(245,166,35,.22);border-radius:var(--radius);padding:16px 20px;position:relative;overflow:hidden;}
.dv-analysis-block::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,rgba(255,180,50,.8),rgba(255,180,50,.08));border-radius:var(--radius) var(--radius) 0 0;}
.dv-analysis-divider{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:700;color:var(--text);margin-bottom:13px;}
.dv-analysis-divider::before,.dv-analysis-divider::after{content:'';flex:1;height:1px;background:var(--border);}
.dv-analysis-text{font-size:13px;line-height:1.85;color:var(--text);opacity:.88;margin:0;}
.dv-hl-orange{color:var(--orange);font-weight:700;font-family:var(--mono);}
.dv-hl-amber{color:rgba(245,190,80,.75);font-weight:600;}
.dv-hl-green{color:var(--green);font-weight:700;}
.dv-hl-red{color:var(--red);font-weight:600;}
.dv-hl-blue{color:var(--blue);font-weight:700;font-family:var(--mono);}
.asset-price{font-family:var(--mono);font-size:30px;font-weight:800;text-align:right;}
.asset-chg{font-family:var(--mono);font-size:14px;font-weight:600;text-align:right;margin-top:3px;}
.asset-chg.up{color:var(--green);}.asset-chg.down{color:var(--red);}
.asset-stats{display:flex;gap:18px;flex-wrap:wrap;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);width:100%;}
.stat-item{display:flex;flex-direction:column;gap:2px;}
.stat-label{font-size:9.5px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:rgba(245,190,80,0.5);}
.stat-value{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--text2);}

/* CHART */
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;}
.chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}

/* ── Chart Signal Tooltip ──────────────────────────────────── */
#chartTooltip{
  position:fixed;pointer-events:none;z-index:9999;
  max-width:235px;min-width:160px;
  background:rgba(14,14,16,0.97);
  border-radius:10px;padding:10px 13px;
  border:1px solid rgba(255,255,255,0.1);
  box-shadow:0 8px 32px rgba(0,0,0,.65);
  font-family:var(--sans);font-size:11.5px;line-height:1.55;
  opacity:0;transform:translateY(4px);
  transition:opacity .15s ease,transform .15s ease;
  backdrop-filter:blur(12px);
}
#chartTooltip.visible{opacity:1;transform:translateY(0);}
.ct-badge{display:inline-flex;align-items:center;gap:5px;font-size:9.5px;font-weight:700;
  letter-spacing:.9px;text-transform:uppercase;padding:2px 7px;border-radius:20px;
  margin-bottom:6px;}
.ct-badge.buy{background:rgba(0,201,141,.15);color:#00c98d;border:1px solid rgba(0,201,141,.32);}
.ct-badge.sell{background:rgba(255,82,74,.14);color:rgba(255,110,100,.95);border:1px solid rgba(255,82,74,.32);}
.ct-badge.div-bull{background:rgba(0,201,141,.12);color:#00c98d;border:1px solid rgba(0,201,141,.3);}
.ct-badge.div-bear{background:rgba(255,82,74,.12);color:rgba(255,110,100,.9);border:1px solid rgba(255,82,74,.28);}
.ct-title{font-size:12px;font-weight:600;color:rgba(255,255,255,.92);margin-bottom:3px;}
.ct-body{font-size:11px;color:rgba(255,255,255,.58);line-height:1.6;}
.ct-action{margin-top:6px;font-size:10.5px;font-weight:600;padding:4px 8px;border-radius:6px;display:inline-block;}
.ct-action.buy{color:#f5c842;background:rgba(245,166,35,.1);}
.ct-action.sell{color:rgba(255,110,100,.9);background:rgba(255,82,74,.1);}
.ct-action.div{color:rgba(255,200,80,.88);background:rgba(245,166,35,.08);}
.chart-title{font-size:12px;font-weight:600;color:var(--text2);letter-spacing:.5px;}
.chart-legend{display:flex;gap:12px;align-items:center;}
.legend-item{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--muted);}
.legend-line{width:14px;height:2px;border-radius:1px;}
.chart-container{position:relative;height:240px;}
.vol-container{position:relative;height:50px;margin-top:3px;}

/* SIGNAL CARD */
.signal-card{border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);padding:20px;display:grid;grid-template-columns:auto 1fr;gap:20px;align-items:center;position:relative;overflow:hidden;transition:box-shadow .3s;}
.signal-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--radius) var(--radius) 0 0;}
.signal-card.BUY{border-color:rgba(0,201,141,.22);box-shadow:0 4px 32px rgba(0,0,0,.6);}
.signal-card.BUY::before{background:linear-gradient(90deg,rgba(0,201,141,.75),rgba(0,201,141,.15));}
.signal-card.SELL{border-color:rgba(255,82,70,.22);box-shadow:0 4px 32px rgba(0,0,0,.6);}
.signal-card.SELL::before{background:linear-gradient(90deg,rgba(255,82,70,.70),rgba(255,82,70,.18));}
.signal-card.HOLD{border-color:rgba(48,209,88,.22);box-shadow:0 4px 32px rgba(0,0,0,.6);}
.signal-card.HOLD::before{background:linear-gradient(90deg,rgba(48,209,88,.65),rgba(48,209,88,.15));}
.signal-badge{display:flex;flex-direction:column;align-items:center;gap:8px;min-width:88px;}
.signal-label{font-size:24px;font-weight:900;letter-spacing:1.5px;font-family:var(--mono);}
.signal-label.BUY{color:#00c98d;text-shadow:none;}
.signal-label.SELL{color:rgba(255,110,100,0.92);text-shadow:none;}
.signal-label.HOLD{color:rgba(48,209,88,0.92);text-shadow:none;}
.conf-ring{position:relative;width:72px;height:72px;}
.conf-ring svg{transform:rotate(-90deg);}
.conf-ring-track{fill:none;stroke:rgba(255,255,255,0.08);stroke-width:5;}
.conf-ring-fill{fill:none;stroke-width:5;stroke-linecap:round;transition:stroke-dashoffset .8s ease;}
.conf-ring-fill.HIGH{stroke:#f5a623;filter:none;}
.conf-ring-fill.MEDIUM{stroke:rgba(245,166,35,0.55);filter:none;}
.conf-ring-fill.LOW{stroke:rgba(255,255,255,0.22);filter:none;}
.conf-ring-text{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1;}
.conf-pct{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--text);}
.conf-label{font-size:9px;font-weight:700;letter-spacing:1px;color:rgba(245,190,80,0.50);margin-top:2px;}
.signal-body{display:flex;flex-direction:column;gap:10px;}
.signal-summary{font-size:13px;color:var(--text);opacity:.88;line-height:1.7;}
.signal-actions{display:flex;gap:7px;flex-wrap:wrap;}
.action-btn{padding:7px 14px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;border:1px solid var(--border);background:var(--surface2);color:var(--text2);transition:all .15s;display:flex;align-items:center;gap:4px;}
.action-btn:hover{border-color:var(--border2);color:var(--text);}
.action-btn.primary{background:var(--orange-bg);border-color:rgba(245,166,35,.3);color:var(--orange);}
.action-btn.primary:hover{background:rgba(245,166,35,.15);box-shadow:0 0 16px rgba(245,166,35,.2);}
.win-rate-badge{display:flex;flex-direction:column;align-items:center;gap:1px;padding:6px 10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:9px;}
.win-rate-badge .wr-val{font-family:var(--mono);font-size:13px;font-weight:700;color:#f5a623;line-height:1;}
.win-rate-badge .wr-label{font-size:8px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(245,190,80,0.48);}
/* Chart overlay toggle buttons */
.chart-ovr-row{display:flex;gap:5px;margin-bottom:8px;flex-wrap:wrap;}
.chart-ovr-btn{padding:3px 8px;font-size:9px;font-weight:700;letter-spacing:.5px;border-radius:4px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);color:rgba(255,255,255,.35);cursor:pointer;transition:all .15s;text-transform:uppercase;}
.chart-ovr-btn.active{background:rgba(245,166,35,.12);border-color:rgba(245,166,35,.3);color:rgba(245,166,35,.8);}
.chart-ovr-btn:hover:not(.active){background:rgba(255,255,255,.08);color:rgba(255,255,255,.6);}
/* ── Bottom chart indicator toggle buttons ── */
#chartIndicatorRow{display:none;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,.06);}
.chart-ind-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:9px 10px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.38);cursor:pointer;font-size:11px;font-weight:700;letter-spacing:.4px;transition:all .16s;user-select:none;}
.chart-ind-btn .ind-icon{font-size:13px;line-height:1;}
.chart-ind-btn .ind-label{line-height:1;}
.chart-ind-btn .ind-state{font-size:9px;font-weight:600;letter-spacing:.6px;opacity:.7;}
.chart-ind-btn.active{border-color:rgba(245,166,35,.35);background:rgba(245,166,35,.1);color:rgba(245,166,35,.92);}
.chart-ind-btn.rsi-ind.active{border-color:rgba(168,120,255,.38);background:rgba(168,120,255,.11);color:rgba(185,145,255,.92);}
.chart-ind-btn:hover:not(.active){background:rgba(255,255,255,.07);color:rgba(255,255,255,.6);border-color:rgba(255,255,255,.18);}
.chart-ind-btn:active{transform:scale(.96);}
/* TradingView cross-verification panel */
.tv-panel{margin-top:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:11px 15px;display:flex;align-items:center;flex-wrap:wrap;gap:14px;}
.tv-logo{font-size:9px;font-weight:700;letter-spacing:1.4px;color:rgba(245,190,80,0.45);text-transform:uppercase;white-space:nowrap;flex-shrink:0;}
.tv-rec{display:flex;align-items:center;gap:7px;}
.tv-rec-badge{font-size:11px;font-weight:800;letter-spacing:.5px;padding:4px 11px;border-radius:6px;white-space:nowrap;}
.tv-rec-badge.STRONG_BUY{background:rgba(0,201,141,.18);color:#00c98d;border:1px solid rgba(0,201,141,.45);}
.tv-rec-badge.BUY{background:rgba(0,201,141,.12);color:rgba(0,201,141,.85);border:1px solid rgba(0,201,141,.28);}
.tv-rec-badge.NEUTRAL{background:rgba(255,255,255,.06);color:rgba(255,255,255,.45);border:1px solid rgba(255,255,255,.12);}
.tv-rec-badge.SELL{background:rgba(255,82,70,.12);color:rgba(255,110,100,.88);border:1px solid rgba(255,82,70,.28);}
.tv-rec-badge.STRONG_SELL{background:rgba(255,82,70,.17);color:rgba(255,120,108,.96);border:1px solid rgba(255,82,70,.40);}
.tv-divider{width:1px;height:20px;background:rgba(255,255,255,.08);flex-shrink:0;}
.tv-stat{display:flex;flex-direction:column;gap:2px;align-items:center;}
.tv-stat-label{font-size:9px;letter-spacing:1.1px;text-transform:uppercase;color:rgba(245,190,80,0.48);}
.tv-stat-val{font-family:var(--mono);font-size:13px;font-weight:700;color:rgba(255,255,255,0.88);}
.tv-agree{font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;padding:3px 9px;border-radius:5px;background:rgba(0,201,141,.12);color:#00c98d;border:1px solid rgba(0,201,141,.28);}
.tv-agree.mismatch{background:rgba(255,255,255,.05);color:rgba(255,255,255,.40);border:1px solid rgba(255,255,255,.09);}
.tv-agree.conflict{background:rgba(245,166,35,.1);color:var(--orange);}
.tv-agree.neutral{background:var(--surface2);color:var(--muted);}
.tv-agree.match-sell{background:rgba(255,82,70,.12);color:rgba(255,110,100,.88);border:1px solid rgba(255,82,70,.28);}

/* COUNTER TRADE */
.counter-card{background:var(--surface);border:1px solid rgba(245,166,35,.25);border-radius:var(--radius);padding:16px 20px;border-top:3px solid var(--orange);box-shadow:0 0 30px rgba(245,166,35,.08);}
.counter-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.counter-badge{background:var(--orange-bg);color:var(--orange);font-size:10px;font-weight:700;letter-spacing:1px;padding:3px 8px;border-radius:4px;text-transform:uppercase;}
.counter-warning{font-size:10px;color:var(--orange);font-weight:700;background:rgba(255,140,66,.12);border:1px solid rgba(255,140,66,.25);padding:3px 8px;border-radius:4px;}
.counter-body{font-size:12px;color:var(--text);opacity:.85;line-height:1.6;margin-bottom:12px;}
.counter-levels-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;}
@media(max-width:700px){.counter-levels-grid{grid-template-columns:repeat(3,1fr);}}
.cl-item{display:flex;flex-direction:column;gap:3px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 10px;}
.cl-item.primary-exit{border-color:rgba(0,229,170,.35);background:var(--green-bg);}
.cl-item.danger{border-color:rgba(255,77,106,.25);background:var(--red-bg);}
.cl-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:rgba(245,190,80,0.52);}
.cl-val{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--text);margin-top:1px;}
.cl-sub{font-size:10px;color:var(--muted);margin-top:1px;}

/* SCENARIOS */
.scenarios-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
@media(max-width:700px){.scenarios-grid{grid-template-columns:1fr;}}
.scenario-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;}
.scenario-card.bull{border-top:2px solid rgba(245,166,35,0.70);}
.scenario-card.base{border-top:2px solid rgba(48,209,88,0.55);}
.scenario-card.bear{border-top:2px solid rgba(255,82,70,0.55);}
.scenario-label{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px;}
.scenario-card.bull .scenario-label{color:#f5a623;}
.scenario-card.base .scenario-label{color:rgba(48,209,88,0.90);}
.scenario-card.bear .scenario-label{color:rgba(255,110,100,0.88);}
.scenario-text{font-size:12px;color:rgba(255,255,255,0.85);line-height:1.7;}

/* TRADE LEVELS */
.levels-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;}
.card-title{font-size:12px;font-weight:700;color:var(--text);margin-bottom:12px;display:flex;align-items:center;gap:7px;}
.card-title::after{content:'';flex:1;height:1px;background:var(--border);}
.card-title svg{flex-shrink:0;}
.levels-table{width:100%;border-collapse:collapse;}
.levels-table th{text-align:left;font-size:10px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:rgba(245,190,80,0.52);padding:0 0 7px 0;}
.levels-table td{padding:7px 0;border-top:1px solid var(--border);vertical-align:middle;}
.level-name{font-size:12px;font-weight:600;color:var(--text2);}
.level-name.entry{color:#f5a623;}.level-name.sl{color:rgba(255,110,100,0.85);}
.level-name.tp1,.level-name.tp2,.level-name.tp3{color:rgba(72,220,105,0.85);}
.level-val{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--text);}
.level-rr{font-family:var(--mono);font-size:11px;color:var(--text2);}
.rr-bar-wrap{width:80px;background:var(--surface3);border-radius:3px;height:4px;overflow:hidden;}
.rr-bar{height:100%;border-radius:3px;}

/* INDICATORS */
.indicators-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
@media(max-width:800px){.indicators-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:500px){.indicators-grid{grid-template-columns:1fr;}}
.ind-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px;transition:border-color .2s;}
.ind-card:hover{border-color:var(--border2);}
/* preview-style card header: plain English name + tech name stacked */
.ind-card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.ind-plain{font-size:12px;font-weight:700;color:var(--text);}
.ind-tech{font-size:9px;font-weight:600;color:rgba(245,190,80,0.5);letter-spacing:.4px;margin-top:1px;}
/* legacy — kept for any remaining references */
