    <div class="glass-pill-group" id="assetTypePills">
      <button class="gpill active" data-sel="assetType" data-val="crypto" onclick="setPill(this)">Crypto</button>
      <button class="gpill" data-sel="assetType" data-val="stock"     onclick="setPill(this)">Stock</button>
      <button class="gpill" data-sel="assetType" data-val="forex"     onclick="setPill(this)">Forex</button>
      <button class="gpill" data-sel="assetType" data-val="commodity" onclick="setPill(this)">Commod</button>
      <button class="gpill" data-sel="assetType" data-val="index"     onclick="setPill(this)">Index</button>
