      <button class="gpill" data-sel="timeframe" data-val="30m" onclick="setPill(this)">30M</button>
      <button class="gpill" data-sel="timeframe" data-val="1h"  onclick="setPill(this)">1H</button>
      <button class="gpill" data-sel="timeframe" data-val="4h"  onclick="setPill(this)">4H</button>
      <button class="gpill active" data-sel="timeframe" data-val="1d" onclick="setPill(this)">1D</button>
    </div>

    <button class="analyze-btn" id="analyzeBtn" onclick="runAnalyze()">Analyze</button>

    <!-- Auto-refresh controls for signals -->
    <div style="display:flex;align-items:center;gap:6px;margin-top:6px;flex-wrap:wrap;">
      <span style="font-size:9.5px;color:var(--muted);letter-spacing:.4px;">AUTO-REFRESH:</span>
