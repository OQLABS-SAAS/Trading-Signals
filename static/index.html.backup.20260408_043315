      'GOLD','SILVER','OIL','NATGAS','COPPER','WHEAT','CORN','PLATINUM'
  ]},
];

let buyScanActive = false;

async function runBuyScanner() {
  if (buyScanActive) return;
  buyScanActive = true;

  const tf      = document.getElementById('buyScanTF').value;
  const btn     = document.getElementById('buyScanBtn');
  const progEl  = document.getElementById('buyScanProgress');
  const resEl   = document.getElementById('buyScanResults');
  const countEl = document.getElementById('buyCount');

  btn.disabled = true; btn.textContent = '⏳ Scanning all markets…';
  progEl.style.display = 'block';
  resEl.innerHTML = '';
  countEl.textContent = '0';

  // Split each group into batches of 10
  const batches = [];
  for (const group of MASTER_BUY_UNIVERSE) {
    for (let i = 0; i < group.tickers.length; i += 10) {
      batches.push({ asset_type: group.asset_type, tickers: group.tickers.slice(i, i + 10) });
    }
  }

  const total = batches.length;
  let done    = 0;
  const buySignals = [];

  function updateProgress() {
    const pct = total > 0 ? Math.round(done / total * 100) : 0;
    progEl.innerHTML = `
      <div class="buy-progress">
        <div style="font-size:10px;color:var(--muted);display:flex;justify-content:space-between;">
          <span>Batch ${done}/${total}</span>
          <span style="color:#00c98d;font-weight:700;">${buySignals.length} BUY signal${buySignals.length!==1?'s':''} found</span>
        </div>
        <div class="buy-progress-bar-wrap">
          <div class="buy-progress-bar" style="width:${pct}%;"></div>
        </div>
      </div>`;
  }

  function renderLive() {
    // Sort by RSI ascending (most oversold first — strongest BUY candidates)
    const sorted = [...buySignals].sort((a,b) =>
      (parseFloat(a.rsi)||50) - (parseFloat(b.rsi)||50)
    );
    countEl.textContent = sorted.length;

    resEl.innerHTML = (sorted.length
      ? `<div style="font-size:9px;color:rgba(255,255,255,0.3);padding:0 2px 5px;line-height:1.4;">
           Pre-scan BUY indicators — click any to run full analysis &amp; confirm signal
         </div>` + sorted.map(r => {
           const rsiNum    = parseFloat(r.rsi)||0;
           const rsiCol    = rsiNum < 40 ? '#00c98d' : rsiNum > 60 ? '#ff6b7a' : 'rgba(255,255,255,0.45)';
           const chg       = r.chg_1d != null ? (r.chg_1d >= 0 ? `+${r.chg_1d}%` : `${r.chg_1d}%`) : '';
           const typeShort = {crypto:'CRY',stock:'STK',forex:'FX',index:'IDX',commodity:'COM'}[r._asset_type] || (r._asset_type||'').toUpperCase().slice(0,3);
           return `<div class="buy-result-row" onclick="quickLoad('${r.ticker}','${r._asset_type||'crypto'}','${tf}')">
             <span class="buy-result-ticker">${r.ticker}</span>
             <span class="buy-result-type">${typeShort}</span>
             <span class="buy-result-rsi" style="color:${rsiCol};">RSI ${rsiNum.toFixed(0)}</span>
             <span class="scan-chg up" style="font-size:10px;">${chg}</span>
             <span class="sig-pill BUY" style="font-size:9px;padding:1px 5px;">BUY</span>
           </div>`;
         }).join('')
      : `<div class="buy-scan-empty">No confirmed BUY signals yet…</div>`
    );
  }

  updateProgress();

  // Process in parallel chunks of 4 batches at a time
  const CONCURRENCY = 4;
  for (let i = 0; i < batches.length; i += CONCURRENCY) {
    const chunk = batches.slice(i, i + CONCURRENCY);
    const results = await Promise.all(chunk.map(b =>
      fetch('/api/scan-list', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({tickers: b.tickers, asset_type: b.asset_type, timeframe: tf})
      })
      .then(r => r.json())
      .then(data => {
        return (data.results||[]).filter(r => !r.error &&
          r.signal_hint === 'BUY'
        ).map(r => ({ ...r, _asset_type: b.asset_type }));
      })
      .catch(() => [])
    ));
    done += chunk.length;
    results.forEach(buys => buySignals.push(...buys));
    updateProgress();
    renderLive();
  }

  // Final state
  if (buySignals.length === 0) {
    resEl.innerHTML = `<div class="buy-scan-empty">✅ Scan complete — no BUY signals found across all markets on ${tf.toUpperCase()} timeframe.</div>`;
  }
  progEl.innerHTML = `<div class="buy-progress"><div style="font-size:10px;color:#00c98d;font-weight:700;">✅ Scan complete · ${buySignals.length} BUY signal${buySignals.length!==1?'s':''} found across all markets</div></div>`;

  btn.disabled = false; btn.textContent = '🔍 Scan All Markets for BUY';
  buyScanActive = false;
}

