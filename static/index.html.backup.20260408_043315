fill(rsiPlot, osPlot, rsi < rsiOS ? C_OS : na, title="OS Fill")

// OB/OS background zones
bgcolor(rsi > rsiOB ? color.new(#ff524a, 93) : rsi < rsiOS ? color.new(#30d158, 93) : na, title="Zone BG")


// ===============================================================
// PIVOT DETECTION
// ===============================================================
// Price pivots (using high/low)
priceHigh = ta.pivothigh(high, pivLen, pivLen)  // Returns price value at swing high, na otherwise
priceLow  = ta.pivotlow(low,   pivLen, pivLen)

