  const f = v => v != null ? fmt(v) : '—';
  const rr = (v, rr) => rr ? `R/R ${rr}:1` : '';

  wrap.innerHTML = `
    <div class="mgmt-title">Trade Management Plan</div>
    <div class="mgmt-steps">
      <div class="mgmt-step">
        <div class="mgmt-num sl-num">SL</div>
        <div class="mgmt-body">
          <div class="mgmt-label">Stop Loss — Full position at risk</div>
          <div class="mgmt-rule">Exit 100% if price reaches stop. No exceptions.</div>
        </div>
        <div>
          <div class="mgmt-price" style="color:rgba(255,110,100,.88)">${f(d.stop_loss)}</div>
          <div class="mgmt-rr">—</div>
        </div>
      </div>
      <div class="mgmt-step">
        <div class="mgmt-num tp1-num">1</div>
        <div class="mgmt-body">
          <div class="mgmt-label">TP1 — Close 50%</div>
          <div class="mgmt-rule">Close half the position. Immediately move SL to breakeven (entry price). The remaining 50% now risks nothing.</div>
          <div><span class="mgmt-badge be-badge">→ SL moves to breakeven</span></div>
        </div>
        <div>
          <div class="mgmt-price" style="color:rgba(48,209,88,.90)">${f(d.tp1)}</div>
          <div class="mgmt-rr">${rr(d.tp1, d.rr1)}</div>
        </div>
      </div>
      <div class="mgmt-step">
        <div class="mgmt-num tp2-num">2</div>
        <div class="mgmt-body">
          <div class="mgmt-label">TP2 — Close 25%</div>
          <div class="mgmt-rule">Close another quarter. Stop still at breakeven — worst case is now a scratch trade.</div>
        </div>
        <div>
          <div class="mgmt-price" style="color:rgba(48,209,88,.78)">${f(d.tp2)}</div>
          <div class="mgmt-rr">${rr(d.tp2, d.rr2)}</div>
        </div>
      </div>
      <div class="mgmt-step">
        <div class="mgmt-num tp3-num">3</div>
        <div class="mgmt-body">
          <div class="mgmt-label">TP3 — Close remaining 25%</div>
          <div class="mgmt-rule">Let the final runner go. Full exit at TP3 — maximum reward captured.</div>
        </div>
        <div>
          <div class="mgmt-price" style="color:rgba(48,209,88,.65)">${f(d.tp3)}</div>
          <div class="mgmt-rr">${rr(d.tp3, d.rr3)}</div>
        </div>
      </div>
    </div>`;
}

/* ════════════════════════════════════════════
   INDICATORS
════════════════════════════════════════════ */
function renderIndicators(d) {
  const rsi    = d.rsi ?? 50;
  const rsiColor = rsi < 30 ? '#00c98d' : rsi > 70 ? '#ff4459' : '#f5c842';
  const rsiBadge = rsi < 30 ? 'bull' : rsi > 70 ? 'bear' : 'warn';
  const rsiLabel = rsi < 30 ? 'Oversold' : rsi > 70 ? 'Overbought' : rsi < 45 ? 'Mild Oversold' : rsi > 55 ? 'Mild Overbought' : 'Neutral';

  const macdBull = d.macd_hist > 0;
  const bbPct    = Math.round((d.bb_pos||0) * 100);
  const bbLabel  = d.bb_pos < 0.2 ? 'Near Lower Band' : d.bb_pos > 0.8 ? 'Near Upper Band' : 'Mid-Range';
  const bbBadge  = d.bb_pos < 0.2 ? 'bull' : d.bb_pos > 0.8 ? 'bear' : 'warn';
  const volBull  = (d.vol_ratio||0) >= 1.5;
  const stBull   = d.supertrend === 'BULLISH';
  const etBull   = (d.ema_trend||'').includes('BULL');
  const etBear   = (d.ema_trend||'').includes('BEAR');

  const div      = d.rsi_divergence || {};
  const divType  = div.type || 'none';
  const divLabel = div.label || 'None';
  const divStr   = div.strength || 0;
  const divBadge = divType === 'bullish' ? 'bull' : divType === 'hidden_bullish' ? 'neut' :
                   divType === 'bearish' ? 'bear' : divType === 'hidden_bearish' ? 'warn' : 'neut';
  const divColor = divType === 'bullish' ? '#f5c842' : divType === 'hidden_bullish' ? '#00c98d' :
                   divType.includes('bear') ? '#ff6b7a' : 'rgba(255,255,255,.3)';
  const divBl    = divType === 'none' ? 'No Divergence' : divType.includes('bull') ? 'Bullish' : 'Bearish';

  const bar = (pct, color) =>
    `<div class="bar-track"><div class="bar-fill" style="width:${Math.min(Math.round(pct),100)}%;background:${color}"></div></div>`;

