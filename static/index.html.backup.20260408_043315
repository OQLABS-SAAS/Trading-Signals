/* ── colorizeNumbers: wraps inline numbers in colour spans ──
   Positive (led by + or context):  green
   Negative (led by - or context):  red
   Plain numbers / prices:          amber/neutral               */
function colorizeNumbers(text) {
  // Escape HTML first so we don't double-encode anything
  const safe = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  // Pattern: optional $, optional sign, digits with optional commas/decimals, optional %
  // Captures: (sign?)(number)(unit?)
  return safe.replace(/([\+\-]?\$?[\d,]+(?:\.\d+)?%?)/g, (match) => {
    const raw = match.replace(/[$,%,]/g, '');
    const num = parseFloat(raw);
    if (isNaN(num)) return match;
    if (match.startsWith('+') || match.startsWith('+$')) {
      return `<span style="color:rgba(48,209,88,.92);font-weight:600;">${match}</span>`;
    }
    if (match.startsWith('-') || match.startsWith('-$')) {
      return `<span style="color:rgba(255,90,80,.92);font-weight:600;">${match}</span>`;
    }
    // Plain number — amber neutral
    return `<span style="color:rgba(245,190,80,.82);font-weight:600;">${match}</span>`;
  });
}

/* ── colorizeNarrative: full rich-text coloring for analysis & brief text ──
   Bullish phrases → green   |   Bearish/risk → red
   Technical indicators → amber   |   Prices/numbers → amber/green/red
   Works on both plain text and already-HTML strings (splits on tags).     */
function colorizeNarrative(text) {
  if (!text) return '';

  // Apply number coloring ONLY to plain text (not inside HTML tags)
  function colorNumbers(str) {
    return str.split(/(<[^>]+>)/).map(part => {
      if (part.startsWith('<')) return part; // skip tag attributes
      return part.replace(/([\+\-]?\$?[\d,]+(?:\.\d+)?K?%?)/g, (match) => {
        const raw = parseFloat(match.replace(/[$,%K]/g,'').replace(/,/g,''));
        if (isNaN(raw)) return match;
        if (match.startsWith('+')) return `<span style="color:rgba(48,209,88,.92);font-weight:600;">${match}</span>`;
        if (match.startsWith('-')) return `<span style="color:rgba(255,90,80,.92);font-weight:600;">${match}</span>`;
        return `<span style="color:rgba(245,190,80,.82);font-weight:600;">${match}</span>`;
      });
    }).join('');
  }

  function colorChunk(chunk) {
    if (!chunk) return chunk;

    // 1. Bullish / positive phrases → green
    chunk = chunk.replace(/\b(positive(?:\s+and\s+building)?|bullish\s+reversal|bullish\s+cross|bullish|uptrend|in\s+favour\s+of\s+longs?|buyers?\s+are\s+active|turning\s+up|oversold\s+and\s+recovering|oversold\s+territory|recovering|bounces?\s+historically|breaking?\s+(?:out|higher)|holds?\s+(?:firm|above|key|support)?|momentum\s+(?:is\s+)?(?:intact|building|turning\s+up)|safe-haven\s+demand|risk-on|three\s+of\s+four\s+timeframes?|aligned\s+bullish)\b/gi,
      '<span style="color:rgba(0,201,141,.92);font-weight:600;">$&</span>');

    // 2. Bearish / risk phrases → red
    chunk = chunk.replace(/\b(remains?\s+the\s+(?:main|primary)\s+risk|(?:main|primary)\s+risk|risk(?:-off|\s+aversion)?|under\s+pressure|bearish|downtrend|breakdown|rejection|sell[-\s]off|stop\s+loss(?:\s+activates?)?|invalidates?|re-analyze|cautious(?:ly)?|risk-off|subdued|caution\s+flag|weekly\s+trend\s+remains)\b/gi,
      '<span style="color:rgba(255,82,70,.9);font-weight:600;">$&</span>');

    // 3. Technical indicators → amber
    chunk = chunk.replace(/\b(EMA\d*|MACD(?:\s+(?:histogram|bullish\s+cross))?|RSI|BB\s+(?:upper|lower)\s+band|Bollinger(?:\s+Bands?)?|Supertrend|ATR|ADX|SMA\d*|DXY|NFP|CPI|PCE|PMI|1D|4H|1H|weekly\s+trend|daily\s+trend|USDJPY|EURUSD|USDCAD)\b/gi,
      '<span style="color:rgba(245,180,50,.88);font-weight:600;">$&</span>');

    // 4. Volume / directional → blue
    chunk = chunk.replace(/\b(volume|in\s+favour\s+of\s+(?:longs?|shorts?))\b/gi,
      '<span style="color:#4d9fff;font-weight:600;">$&</span>');

    // 5. Numbers — applied AFTER phrase coloring, split on newly added tags
    chunk = colorNumbers(chunk);

    return chunk;
  }

  // Split on any existing HTML tags first, then colorize each text node
  return text.split(/(<[^>]+>)/).map(part =>
    part.startsWith('<') ? part : colorChunk(part)
  ).join('');
}

/* ── Auto-colour numbers: positive=green  negative=red  neutral=amber ──
   Call after any data render. Scans .auto-num elements and stat-value /
   asset-chg elements, then stamps data-sign based on the numeric value.  */
function colorNumbers() {
  // 1. Elements already marked .auto-num — just set data-sign from text
  document.querySelectorAll('.auto-num').forEach(el => {
    const txt = el.textContent.trim();
    const val = parseFloat(txt.replace(/[^0-9.\-+]/g, ''));
    if (isNaN(val)) return;
    el.dataset.sign = val > 0 ? 'pos' : val < 0 ? 'neg' : 'neu';
  });

  // 2. .stat-value — colour based on leading sign or value
  document.querySelectorAll('.stat-value').forEach(el => {
    const txt = el.textContent.trim();
    if (txt.startsWith('+') || /^\d/.test(txt) && parseFloat(txt) > 0 && txt.includes('%')) {
      el.classList.add('num-pos');
      el.classList.remove('num-neg','num-neu');
    } else if (txt.startsWith('-')) {
      el.classList.add('num-neg');
      el.classList.remove('num-pos','num-neu');
    }
  });

  // 3. .asset-chg — already has .up/.down but reinforce colour
  document.querySelectorAll('.asset-chg').forEach(el => {
    const txt = el.textContent.trim();
    if (txt.startsWith('+'))      { el.classList.add('up');   el.classList.remove('down'); }
    else if (txt.startsWith('-')) { el.classList.add('down'); el.classList.remove('up');   }
  });
}
