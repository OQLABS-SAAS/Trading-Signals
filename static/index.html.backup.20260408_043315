  crypto:  ['BTC','ETH','SOL','XRP','BNB','DOGE','ADA','AVAX'],
  forex:   ['EUR/USD','GBP/USD','USD/JPY','AUD/USD','USD/CAD','USD/CHF','NZD/USD','EUR/GBP'],
  stocks:  ['AAPL','TSLA','NVDA','META','MSFT','AMZN','GOOGL','NFLX'],
  indices: ['SPX','NDX100','DJI','RUT','VIX','FTSE','DAX','NIKKEI','HSI','ASX200','DXY','SPY','QQQ'],
};
