let _newsLoaded = false;
async function loadNewsTab() {
  if (_newsLoaded) return; // only fetch once per session
  _newsLoaded = true;

  // Render CB rates
  document.getElementById('cbRatesGrid').innerHTML = CB_RATES.map(r => `
    <div class="macro-card">
      <div class="macro-card-bank">${r.bank}</div>
      <div class="macro-card-rate">${r.rate}</div>
      <span class="macro-card-bias ${r.bias}">${r.bias.toUpperCase()}</span>
    </div>`).join('');

  // Render KPI cards
  document.getElementById('kpiGrid').innerHTML = KPI_DATA.map(k => {
    // Auto-detect direction from prev string for smart color
    let clr = k.color;
    try {
      const prevNum = parseFloat((k.prev||'').replace(/[^0-9.\-+]/g,''));
      const curNum  = parseFloat((k.val||'').replace(/[^0-9.\-+]/g,''));
      if (!isNaN(prevNum) && !isNaN(curNum) && !k.color) {
        clr = curNum > prevNum ? 'var(--red)' : curNum < prevNum ? 'var(--green)' : 'var(--orange)';
      }
    } catch(_){}
    return `<div class="kpi-card">
      <div class="kpi-label">${k.label}</div>
      <div class="kpi-val" style="color:${clr}">${k.val}</div>
      <div class="kpi-prev">${k.prev}</div>
    </div>`;
  }).join('');

  // Fetch economic calendar from backend proxy
  try {
    const r   = await fetch('/api/econ-calendar');
    const j   = await r.json();
    const allEvs = (j.result || j.events || j.data || []);
    // importance can be numeric (1-3) or string ('low','medium','high')
    function impNum(e) {
      if (typeof e.importance === 'number') return e.importance;
      const s = (e.importance || e.impact || '').toString().toLowerCase();
      if (s === 'high' || s === '3') return 3;
      if (s === 'medium' || s === 'moderate' || s === '2') return 2;
      return 1;
    }
    const evs = allEvs.filter(e => impNum(e) >= 1).slice(0, 25);
    if (evs.length) {
      document.getElementById('econCalList').innerHTML = evs.map(e => {
        const n = impNum(e);
        const imp = n >= 3 ? 'high' : n === 2 ? 'medium' : 'low';
        let dayStr = '';
        try {
          const ts = e.date || e.timestamp || e.time;
          if (ts) {
            const dt = new Date(typeof ts === 'number' ? ts * 1000 : ts);
            dayStr = dt.toLocaleDateString(undefined,{weekday:'short',month:'short',day:'numeric'});
          }
        } catch(_){}
        return `<div class="econ-event">
          <div>
            <div class="econ-time">${dayStr||e.date_str||'—'}</div>
            <div class="econ-country">${e.country||e.currency||''}</div>
          </div>
          <div class="econ-name">${e.title||e.name||e.indicator||e.event||'Event'}</div>
          <span class="econ-impact ${imp}">${imp.toUpperCase()}</span>
        </div>`;
      }).join('');
    } else {
      document.getElementById('econCalList').innerHTML =
        '<div style="font-size:12px;color:var(--muted);padding:8px 0;">No events found — check back later.</div>';
    }
  } catch(e) {
    document.getElementById('econCalList').innerHTML =
      '<div style="font-size:12px;color:var(--muted);">Calendar unavailable — check connection.</div>';
  }

  // Auto-load brief
  loadDailyBrief();
}

async function loadDailyBrief() {
  const box = document.getElementById('dailyBriefBox');
  box.innerHTML = '<span style="color:rgba(255,255,255,0.28);font-size:12px;">Generating brief…</span>';
  try {
    const r = await fetch('/api/daily-brief');
    const j = await r.json();
    const raw = (j.brief || 'Brief unavailable.')
      .replace(/\bdot-verse\b/gi, 'DotVerse');  // fix brand name
    // Strip markdown: **bold** → <strong>, *italic* → plain, # headers → section labels
    let html = raw
      // Section headers: lines starting with ## or ### or ** at start of line
      .replace(/^#{1,3}\s*\*{0,2}(.+?)\*{0,2}\s*$/gm, '<div class="brief-section">$1</div>')
      // Bold: **text**
      .replace(/\*\*([^*\n]+)\*\*/g, '<strong>$1</strong>')
      // Italic: *text* (single asterisk, not at start of line)
      .replace(/\*([^*\n]+)\*/g, '$1')
      // Bullet lines: "- text" or "• text"
      .replace(/^[\-•]\s+/gm, '&#8212; ')
      // Double newlines → paragraph break
      .replace(/\n{2,}/g, '<br><br>')
      // Single newlines → space (inline)
      .replace(/\n/g, ' ');
    box.innerHTML = colorizeNarrative(html);
  } catch(e) {
    box.innerHTML = '<span style="color:rgba(255,255,255,0.28);font-size:12px;">Brief unavailable — check connection.</span>';
  }
}

