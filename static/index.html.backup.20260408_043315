<!-- APP GRID -->
<div class="app-grid">

<!-- ─── LEFT SIDEBAR (desktop) / Drawer (mobile) ─── -->
<aside class="sidebar-left" id="sidebarLeft">
  <!-- Mobile drag-handle (hidden on desktop) -->
  <div class="drawer-handle" style="display:none;" id="drawerHandleL"></div>
