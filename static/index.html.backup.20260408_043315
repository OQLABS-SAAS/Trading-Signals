showRegBear = input.bool(true, "Regular Bearish",   group="[BUY] Show Divergences")
showHidBull = input.bool(true, "Hidden Bullish",    group="[BUY] Show Divergences")
showHidBear = input.bool(true, "Hidden Bearish",    group="[BUY] Show Divergences")

