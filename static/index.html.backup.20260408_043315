<script>
/* ════════════════════════════════════════════
   STRATEGY REPORT (TradingView-style)
════════════════════════════════════════════ */

let btEquityChartInst = null;
let _btGeneration = 0;  // incremented on every trigger; stale callbacks are discarded

/* ── Explicit user trigger for the Strategy Report panel ──
   Called by the "📊 Strategy Report" button in the share panel.
   Guards against null state (no analysis yet) and HOLD signals (no levels). */
function triggerBacktest() {
  // Silent guards — button is hidden for HOLD/no-entry by renderResults(),
  // but keep these as a safety net in case of stale state.
  if (!currentData) return;
  if (currentData.signal === 'HOLD' || currentData.entry == null) return;
  runBacktest(currentData);
}

/* ── Tab switcher — only toggles visibility if results have already loaded ── */
function switchBtTab(tab) {
  const isMetrics  = tab === 'metrics';
  const resultsEl  = document.getElementById('backtestResults');
  const tradesEl   = document.getElementById('btTradesTab');
  const loadingEl  = document.getElementById('backtestLoading');
  // Only switch content if we're NOT in loading state (results have loaded)
  const hasLoaded  = loadingEl && loadingEl.style.display === 'none';
  if (hasLoaded) {
    if (resultsEl) resultsEl.style.display = isMetrics ? '' : 'none';
    if (tradesEl)  tradesEl.style.display  = isMetrics ? 'none' : '';
  }
  // Always update tab button styles
  const tabM = document.getElementById('btTabMetrics');
  const tabT = document.getElementById('btTabTrades');
  if (tabM) { tabM.style.borderBottomColor = isMetrics ? 'var(--accent)' : 'transparent'; tabM.style.color = isMetrics ? 'var(--text)' : 'var(--muted)'; }
  if (tabT) { tabT.style.borderBottomColor = isMetrics ? 'transparent' : 'var(--accent)'; tabT.style.color = isMetrics ? 'var(--muted)' : 'var(--text)'; }
}

/* ── Equity curve mini chart ── */
function renderEquityChart(equityCurve) {
  const canvas = document.getElementById('btEquityChart');
  if (!canvas || !equityCurve || equityCurve.length < 2) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth || 400;
  const H = canvas.height;
  canvas.width = W;

  const min  = Math.min(...equityCurve);
  const max  = Math.max(...equityCurve);
  const span = max - min || 1;
  const pad  = 6;

  const toX = i => pad + (i / (equityCurve.length - 1)) * (W - pad * 2);
  const toY = v => H - pad - ((v - min) / span) * (H - pad * 2);

  // Gradient fill
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  const isUp = equityCurve[equityCurve.length - 1] >= equityCurve[0];
  grad.addColorStop(0,   isUp ? 'rgba(48,209,88,.35)'  : 'rgba(255,82,70,.35)');
  grad.addColorStop(1,   'rgba(0,0,0,0)');

  ctx.clearRect(0, 0, W, H);

  // Fill area
  ctx.beginPath();
  ctx.moveTo(toX(0), toY(equityCurve[0]));
  for (let i = 1; i < equityCurve.length; i++) ctx.lineTo(toX(i), toY(equityCurve[i]));
  ctx.lineTo(toX(equityCurve.length - 1), H);
  ctx.lineTo(toX(0), H);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  ctx.moveTo(toX(0), toY(equityCurve[0]));
  for (let i = 1; i < equityCurve.length; i++) ctx.lineTo(toX(i), toY(equityCurve[i]));
  ctx.strokeStyle = isUp ? 'rgba(48,209,88,.9)' : 'rgba(255,82,70,.9)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Baseline ($10k)
  const baseY = toY(equityCurve[0]);
  ctx.beginPath();
  ctx.setLineDash([3, 4]);
  ctx.moveTo(pad, baseY); ctx.lineTo(W - pad, baseY);
  ctx.strokeStyle = 'rgba(255,255,255,.15)';
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.setLineDash([]);
}

/* ── Main backtest runner ── */
async function runBacktest(d, showPanel = true) {
  // showPanel=false → silent background run, only updates the win rate badge.
  // showPanel=true  → full Strategy Report panel is revealed when data arrives.
  // Claim this generation slot. If a newer analysis starts while we're
  // awaiting /api/backtest, myGen won't match _btGeneration and we discard
  // the stale result instead of painting it over the new analysis state.
  const myGen = ++_btGeneration;

  const panel   = document.getElementById('backtestPanel');
  const loading = document.getElementById('backtestLoading');
  const results = document.getElementById('backtestResults');
  const errEl   = document.getElementById('backtestError');
  const tradesTab = document.getElementById('btTradesTab');
  const period  = document.getElementById('backtestPeriod');

  if (!panel) return;

  if (d.signal === 'HOLD' || d.entry == null) { panel.style.display = 'none'; return; }

  // ── Keep panel fully hidden until results arrive ─────────────────────────
  // We do NOT show a loading state inside the panel — the panel simply doesn't
  // appear until data is ready. This eliminates any "pre-populated" perception.
  panel.style.display = 'none';
  results.style.display = 'none';
  if (tradesTab) tradesTab.style.display = 'none';
  errEl.style.display = 'none';
  loading.style.display = 'none';

  // Reset tab button styles
  const tabM = document.getElementById('btTabMetrics');
  const tabT = document.getElementById('btTabTrades');
  if (tabM) { tabM.style.borderBottomColor = 'var(--accent)'; tabM.style.color = 'var(--text)'; }
  if (tabT) { tabT.style.borderBottomColor = 'transparent';   tabT.style.color = 'var(--muted)'; }

  // Set strategy name header (populated before panel shows)
  if (period) period.textContent = '';
  const nameEl = document.getElementById('btStratName');
  if (nameEl) nameEl.textContent = 'DotVerse ' + d.signal + ' \u2014 ' + d.ticker + ' ' + d.timeframe.toUpperCase();

  try {
    const r = await fetch('/api/backtest', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ticker: d.ticker, asset_type: d.asset_type, timeframe: d.timeframe,
        signal: d.signal, entry: d.entry, stop_loss: d.stop_loss,
        tp1: d.tp1, tp2: d.tp2, tp3: d.tp3
      })
    });
    const bt = await r.json();
    // If another analysis was launched while we were waiting, silently discard
    if (myGen !== _btGeneration) return;
    loading.style.display = 'none';

    if (bt.error) {
      if (showPanel) {
        errEl.innerHTML = bt.error + '<br><br>Paste the <b>TP/SL Backtest Strategy</b> into TradingView Pine Editor → Strategy Tester.';
        errEl.style.display = '';
        panel.style.display = '';
      }
      return;
    }

    // ── Helper formatters ──
    const fUSD  = v => (v >= 0 ? '+' : '') + '$' + Math.abs(v).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
    const fPct  = v => (v >= 0 ? '+' : '') + v.toFixed(2) + '%';
    const fR    = v => (v >= 0 ? '+' : '') + v + 'R';
    const green = 'var(--green)', red = 'var(--red)', yellow = 'var(--yellow)', muted = 'var(--muted)';

    // ── Primary stats ──
    const pnlUsdEl = document.getElementById('btPnlUsd');
    pnlUsdEl.textContent  = fUSD(bt.total_pnl_usd);
    pnlUsdEl.style.color  = bt.total_pnl_usd >= 0 ? green : red;
    const pnlPctEl = document.getElementById('btPnlPct');
    pnlPctEl.textContent  = fPct(bt.total_pnl_pct);
    pnlPctEl.style.color  = bt.total_pnl_pct >= 0 ? green : red;

    const ddUsdEl = document.getElementById('btDdUsd');
    ddUsdEl.textContent   = '$' + Math.abs(bt.max_dd_usd).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
    ddUsdEl.style.color   = bt.max_dd_usd > 0 ? red : muted;
    document.getElementById('btDdPct').textContent = bt.max_dd_pct.toFixed(2) + '%';

    document.getElementById('btTrades').textContent = bt.total_trades;

    const wr = bt.win_rate;
    const wrEl = document.getElementById('btWinRate');
    wrEl.textContent = wr + '%';
    wrEl.style.color = wr >= 60 ? green : wr >= 45 ? yellow : red;
    document.getElementById('btWL').textContent = bt.wins + ' / ' + bt.losses;

    // ── Secondary stats ──
    const pf = bt.profit_factor;
    const pfEl = document.getElementById('btPF');
    pfEl.textContent = pf >= 99 ? '\u221e' : pf.toFixed(2);
    pfEl.style.color = pf >= 1.5 ? green : pf >= 1 ? yellow : red;

    const trEl = document.getElementById('btTotalR');
    trEl.textContent = fR(bt.total_r);
    trEl.style.color = bt.total_r >= 0 ? green : red;

    document.getElementById('btAvgWin').textContent  = '+' + bt.avg_win_r + 'R';
    document.getElementById('btAvgLoss').textContent = '\u2212' + bt.avg_loss_r + 'R';

    if (period) period.textContent = bt.period || (bt.bars_tested + ' bars');

    // Reveal panel only when explicitly requested (button click)
    if (showPanel) {
      panel.style.display = '';
      results.style.display = '';
    }

    // ── Equity chart ──
    requestAnimationFrame(() => renderEquityChart(bt.equity_curve));

    // ── List of trades ──
    const tbody = document.getElementById('btTradesTbody');
    if (tbody && bt.trades_list) {
      const exitLabel = { win_tp1:'TP1', win_tp2:'TP2', win_tp3:'TP3', loss:'SL' };
      tbody.innerHTML = bt.trades_list.map(t => {
        const win   = t.outcome !== 'loss';
        const col   = win ? green : red;
        const exit  = exitLabel[t.outcome] || t.outcome;
        const badge = win
          ? `<span style="background:rgba(48,209,88,.18);color:${green};padding:1px 7px;border-radius:10px;font-size:10px;">${exit}</span>`
          : `<span style="background:rgba(255,82,70,.18);color:${red};padding:1px 7px;border-radius:10px;font-size:10px;">${exit}</span>`;
        return `<tr style="border-bottom:1px solid rgba(255,255,255,.05);">
          <td style="padding:7px 12px;color:var(--muted);">${t.n}</td>
          <td style="padding:7px 12px;color:var(--text);white-space:nowrap;">${t.date}</td>
          <td style="padding:7px 12px;color:var(--accent);">${d.signal}</td>
          <td style="padding:7px 12px;text-align:center;">${badge}</td>
          <td style="padding:7px 12px;text-align:right;color:${col};">${fR(t.r)}</td>
          <td style="padding:7px 12px;text-align:right;color:${col};">${fUSD(t.pnl_usd)}</td>
        </tr>`;
      }).join('');
    }

    // ── Win rate badge under confidence ring (backtest win rate + sample size) ──
    const wrBadge2  = document.getElementById('winRateBadge');
    const wrVal2    = document.getElementById('winRateVal');
    const wrSample2 = document.getElementById('winRateSample');
    if (wrBadge2 && wrVal2) {
      wrVal2.textContent    = wr + '%';
      if (wrSample2) wrSample2.textContent = bt.total_trades ? `${bt.total_trades} past signals` : '';
      wrBadge2.style.display = 'inline-flex';
    }

  } catch(e) {
    if (showPanel) {
      loading.style.display = 'none';
      errEl.textContent = 'Backtest unavailable — use TradingView Strategy Tester.';
      errEl.style.display = '';
      panel.style.display = '';
    }
  }
}

