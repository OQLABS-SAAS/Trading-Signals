/* ── Position Size Calculator AUTO logic ── */
const riskAutoState = { entry: true, sl: true };
let calcDirection = 'BUY'; // tracks BUY or SELL for the calculator

function setCalcDir(dir) {
  // dir = 'BUY' | 'SELL' | null (null = HOLD / neutral — user must choose)
  calcDirection = dir;
  const buyBtn  = document.getElementById('calcDirBuy');
  const sellBtn = document.getElementById('calcDirSell');
  const holdNote = document.getElementById('calcDirHoldNote');
  if (buyBtn && sellBtn) {
    buyBtn.classList.toggle('buy-on',  dir === 'BUY');
    buyBtn.classList.remove('sell-on');
    sellBtn.classList.toggle('sell-on', dir === 'SELL');
    sellBtn.classList.remove('buy-on');
    // Dim both when neutral (HOLD)
    buyBtn.classList.toggle('dim',  dir === null);
    sellBtn.classList.toggle('dim', dir === null);
  }
  if (holdNote) holdNote.style.display = (dir === null) ? 'block' : 'none';
}

function updateRiskAutoValues(d) {
  // Called whenever a new signal renders — updates the stored auto values.
  // For HOLD signals the AI returns null entry/stop_loss — we fall back to
  // current price for entry and price ± 1.5×ATR for stop loss (same formula
  // the backend uses for BUY/SELL trade levels).
  const fmtP = v => parseFloat(v).toPrecision(7).replace(/\.?0+$/, '');

  // Auto-set direction from signal — neutral (null) for HOLD
  if (d.signal === 'BUY' || d.signal === 'SELL') {
    setCalcDir(d.signal);
  } else {
    setCalcDir(null); // HOLD → dim both buttons, show manual note
  }

  // Resolve entry: AI value → current price
  const resolvedEntry = (d.entry != null) ? d.entry : d.price;

  // Resolve SL: AI value → price ± 1.5×ATR (direction: below for BUY/HOLD, above for SELL)
  let resolvedSL = d.stop_loss;
  if (resolvedSL == null && d.atr && d.price) {
    resolvedSL = (d.signal === 'SELL')
      ? parseFloat((d.price + d.atr * 1.5).toFixed(6))
      : parseFloat((d.price - d.atr * 1.5).toFixed(6));
  }

  const isHoldFallback = (d.entry == null); // true for HOLD
  const entryLabel  = isHoldFallback ? 'Current price (HOLD)' : 'AI entry';
  const slLabel     = (d.stop_loss == null) ? `Price ± 1.5×ATR (HOLD)` : 'AI stop-loss';

  const entryEl = document.getElementById('entryAutoVal');
  const slEl    = document.getElementById('slAutoVal');

  if (resolvedEntry != null) {
    entryEl.textContent = fmtP(resolvedEntry);
    entryEl.classList.remove('empty');
    entryEl.title = entryLabel;
    // Store resolved value into hidden input for calcRisk
    document.getElementById('riskEntry').value = resolvedEntry;
  }
  if (resolvedSL != null) {
    slEl.textContent = fmtP(resolvedSL);
    slEl.classList.remove('empty');
    slEl.title = slLabel;
    document.getElementById('riskSL').value = resolvedSL;
  }

  // Keep currentData patched so calcRisk() can read resolved values
  if (!d.entry)     d._autoEntry = resolvedEntry;
  if (!d.stop_loss) d._autoSL    = resolvedSL;
}

function toggleRiskAuto(field) {
  const isEntry = field === 'entry';
  const btn     = document.getElementById(isEntry ? 'entryAutoBtn' : 'slAutoBtn');
  const autoDiv = document.getElementById(isEntry ? 'entryAutoVal' : 'slAutoVal');
  const input   = document.getElementById(isEntry ? 'riskEntry'    : 'riskSL');
  const nowAuto = !riskAutoState[field];
  riskAutoState[field] = nowAuto;

  if (nowAuto) {
    // Switching TO auto
    btn.classList.add('on');
    autoDiv.style.display = 'flex';
    input.style.display   = 'none';
    // Pull latest from currentData if available
    if (currentData) {
      const val = isEntry ? currentData.entry : currentData.stop_loss;
      if (val) {
        const fmtP = v => parseFloat(v).toPrecision(7).replace(/\.?0+$/, '');
        autoDiv.textContent = fmtP(val);
        autoDiv.classList.remove('empty');
        input.value = val;
      }
    }
  } else {
    // Switching TO manual
    btn.classList.remove('on');
    autoDiv.style.display = 'none';
    input.style.display   = '';
    input.focus();
  }
}

/* ── Toggle inline calculator open/closed ── */
function toggleCalcPanel() {
