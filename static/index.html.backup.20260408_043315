.calc-auto-val.empty::before{content:'';display:none;}
.calc-input{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:6px 9px;border-radius:var(--radius-sm);font-size:12px;font-family:var(--mono);outline:none;width:100%;box-sizing:border-box;}
.calc-input:focus{border-color:rgba(245,166,35,.5);}
.pct-btns{display:flex;gap:4px;align-items:center;margin-top:5px;}
.pct-btn{flex:1;padding:5px;font-size:11px;font-weight:700;background:var(--surface2);border:1px solid var(--border);color:var(--text2);border-radius:6px;cursor:pointer;font-family:var(--sans);}
