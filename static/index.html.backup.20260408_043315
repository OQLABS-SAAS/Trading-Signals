let _tpPeriod = 'daily';

function tpSelectTab(period) {
  _tpPeriod = period;
  ['D','W','M'].forEach(k => {
    const btn = document.getElementById('tpTab'+k);
    if (btn) btn.classList.toggle('active', k === period[0].toUpperCase());
