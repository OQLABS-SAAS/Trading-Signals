  const cls = tv.tv_rec_label.replace(' ', '_');
  badge.textContent = tv.tv_rec_label;
  badge.className   = `tv-rec-badge ${cls}`;

  // MA & oscillator consensus — colour by direction
  const tvValColor = (lbl) => {
    const v = (lbl || '').toUpperCase();
    if (v.includes('STRONG BUY'))  return '#f5a623';
    if (v.includes('BUY'))         return 'rgba(245,166,35,0.80)';
    if (v.includes('STRONG SELL')) return 'rgba(255,110,100,0.96)';
    if (v.includes('SELL'))        return 'rgba(255,110,100,0.85)';
    return 'rgba(48,209,88,0.85)'; /* NEUTRAL = green = safe */
  };
  const maEl  = document.getElementById('tvMaLbl');
  const oscEl = document.getElementById('tvOscLbl');
  maEl.textContent  = tv.tv_rec_ma_lbl  || '—';
  oscEl.textContent = tv.tv_rec_osc_lbl || '—';
  maEl.style.color  = tvValColor(tv.tv_rec_ma_lbl);
  oscEl.style.color = tvValColor(tv.tv_rec_osc_lbl);

  // Individual indicators
  document.getElementById('tvRsi').textContent = tv.tv_rsi  != null ? tv.tv_rsi.toFixed(1) : '—';
  document.getElementById('tvAdx').textContent = tv.tv_adx  != null ? tv.tv_adx.toFixed(1) : '—';

  // Agreement pill — does TV agree with our yfinance-derived signal?
  const agree = document.getElementById('tvAgree');
  const tvBull = ['STRONG BUY','BUY'].includes(tv.tv_rec_label);
  const tvBear = ['STRONG SELL','SELL'].includes(tv.tv_rec_label);
  const tvNeut = tv.tv_rec_label === 'NEUTRAL';
  let agreeCls = 'neutral', agreTxt = '≈ TV Neutral';
  if (signal === 'BUY'  && tvBull) { agreeCls = 'match';      agreTxt = '✓ TV Agrees'; }
  if (signal === 'SELL' && tvBear) { agreeCls = 'match-sell'; agreTxt = '✓ TV Agrees'; }
  if (signal === 'BUY'  && tvBear) { agreeCls = 'conflict';   agreTxt = '⚠ TV Disagrees'; }
  if (signal === 'SELL' && tvBull) { agreeCls = 'conflict';   agreTxt = '⚠ TV Disagrees'; }
  if (signal === 'HOLD' && tvNeut) { agreeCls = 'match';      agreTxt = '✓ TV Neutral'; }
  agree.textContent = agreTxt;
  agree.className   = `tv-agree ${agreeCls}`;
}

