/* Always send cookies with API calls */
const _origFetch = window.fetch;
window.fetch = function(url, opts={}) {
  if (typeof url === 'string' && url.startsWith('/api')) {
    opts = {...opts, credentials: 'include'};
  }
  return _origFetch(url, opts);
};

/* ════════════════════════════════════════════
   AUTH — PASSWORD GATE
════════════════════════════════════════════ */
async function checkAuth() {
  try {
    const r = await fetch('/api/auth-check', {credentials:'include'});
    const d = await r.json();
    if (d.authenticated) {
      // Already logged in (or no password set) — start app directly, no gate flash
      startApp();
    } else {
      // Password required and not logged in — show the gate
      showGate();
    }
  } catch(e) {
    // Network error — show gate as safe default
    showGate();
  }
}

function showGate() {
  const gate = document.getElementById('passwordGate');
  gate.style.display = 'flex';
  requestAnimationFrame(() => { gate.style.opacity = '1'; });
  setTimeout(() => document.getElementById('gateInput').focus(), 350);
}

function startApp() {
  buildTape(); loadTape(); renderWatchlist(); refreshWatchPanel();
  switchTab('crypto');       // populate sidebar instrument quick-select grid
  updateInlineInst('crypto'); // populate inline instrument row under analyze bar
  renderInstChips(null, null); // seed the switcher bar from localStorage
  loadMarketPulse();
  setInterval(loadTape, 120000);
  setInterval(refreshWatchPanel, 60000);
  setInterval(loadMarketPulse, 30 * 60 * 1000); // refresh every 30 min
}

async function doLogin() {
  const password = document.getElementById('gateInput').value;
  const btn      = document.getElementById('gateBtn');
  const errEl    = document.getElementById('gateError');
  if (!password) { errEl.textContent = 'Please enter the password.'; return; }

  btn.disabled = true;
  btn.textContent = 'Verifying…';
  errEl.textContent = '';

  try {
    const r = await fetch('/api/login', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      credentials:'include',
      body: JSON.stringify({password})
    });
    if (r.ok) {
      unlockApp();
    } else {
      const d = await r.json();
      errEl.textContent = d.message || 'Incorrect password. Try again.';
      document.getElementById('gateInput').value = '';
      document.getElementById('gateInput').focus();
    }
  } catch(e) {
    errEl.textContent = 'Connection error. Please retry.';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Get In';
  }
}

function unlockApp() {
  const gate = document.getElementById('passwordGate');
  gate.style.transition = 'opacity .4s';
  gate.style.opacity = '0';
  setTimeout(() => gate.remove(), 400);
  // Start app features now that we're logged in
  buildTape();
  loadTape();
  renderWatchlist();
  refreshWatchPanel();
  switchTab('crypto');
  loadMarketPulse();
  setInterval(loadTape, 120000);
  setInterval(refreshWatchPanel, 60000);
  setInterval(loadMarketPulse, 30 * 60 * 1000);
  // Restore Strategy Engine + Signals state from last session
  _seRestoreState();
  _sigRestoreState();
}

async function doLogout() {
  await fetch('/api/logout', {method:'POST', credentials:'include'});
  location.reload();
}

function toggleGateEye() {
  const inp = document.getElementById('gateInput');
  const eye = document.getElementById('gateEye');
  if (inp.type === 'password') { inp.type = 'text'; eye.textContent = '🙈'; }
  else                         { inp.type = 'password'; eye.textContent = '👁'; }
}

