  // Update AUTO values in position size calc whenever a new signal loads
  updateRiskAutoValues(d);

  // Apply number colour coding (positive=green, negative=red, neutral=amber)
  setTimeout(colorNumbers, 80);
  // Re-attach data-tip listeners (overlay buttons may have been re-labelled)
  setTimeout(_initDataTips, 100);
  // Signal other listeners that a new analysis has been rendered
  document.dispatchEvent(new Event('analysisRendered'));
}

