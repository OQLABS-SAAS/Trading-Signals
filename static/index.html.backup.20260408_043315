function copyDivergence() {
  const d = currentData;
  if (!d) { alert('Run an analysis first.'); return; }
  const div     = d.rsi_divergence || {};
  const divType = div.type || 'none';
  const ticker  = d.ticker;
  const tf      = d.timeframe.toUpperCase();

  let lines = [];
  lines.push('//@version=5');
  lines.push('indicator("DotVerse RSI Divergence \u2014 ' + ticker + ' ' + tf + '", overlay=false, max_lines_count=100, max_labels_count=50)');
  lines.push('');
  lines.push('// Current RSI: ' + (d.rsi||'\u2014') + ' | Divergence: ' + (divType !== 'none' ? divType : 'None detected'));
  lines.push('');
  lines.push('rsiLen   = input.int(14, "RSI Length", minval=2, maxval=50)');
  lines.push('src      = input.source(close, "Source")');
  lines.push('lookback = input.int(5,  "Pivot Lookback", minval=2, maxval=20)');
  lines.push('obLevel  = input.int(70, "Overbought", minval=50, maxval=100)');
  lines.push('osLevel  = input.int(30, "Oversold",   minval=0,  maxval=50)');
  lines.push('');
  lines.push('rsi = ta.rsi(src, rsiLen)');
  lines.push('plot(rsi, "RSI", color.new(color.purple, 0), 2)');
  lines.push('hline(obLevel, "OB",  color.new(color.red,   0), linestyle=hline.style_dashed)');
  lines.push('hline(50,      "Mid", color.new(color.gray,  0), linestyle=hline.style_dotted)');
  lines.push('hline(osLevel, "OS",  color.new(color.green, 0), linestyle=hline.style_dashed)');
  lines.push('');
  lines.push('// Pivot detection');
  lines.push('rsiH = ta.pivothigh(rsi,   lookback, lookback)');
  lines.push('rsiL = ta.pivotlow (rsi,   lookback, lookback)');
  lines.push('prH  = ta.pivothigh(close, lookback, lookback)');
  lines.push('prL  = ta.pivotlow (close, lookback, lookback)');
  lines.push('');
  lines.push('// Bearish divergence: price makes higher high, RSI makes lower high');
  lines.push('bearDiv = not na(rsiH) and not na(prH) and');
  lines.push('          prH  > ta.valuewhen(not na(prH),  prH,  1) and');
  lines.push('          rsiH < ta.valuewhen(not na(rsiH), rsiH, 1)');
  lines.push('');
  lines.push('// Bullish divergence: price makes lower low, RSI makes higher low');
  lines.push('bullDiv = not na(rsiL) and not na(prL) and');
  lines.push('          prL  < ta.valuewhen(not na(prL),  prL,  1) and');
  lines.push('          rsiL > ta.valuewhen(not na(rsiL), rsiL, 1)');
  lines.push('');
  lines.push('plotshape(bearDiv, "Bear Div", shape.labeldown, location.abovebar, color.new(color.red,   0), text="DIV\u25bc",  textcolor=color.white, size=size.small)');
  lines.push('plotshape(bullDiv, "Bull Div", shape.labelup,   location.belowbar, color.new(color.green, 0), text="DIV\u25b2", textcolor=color.white, size=size.small)');
  lines.push('');
  lines.push('bgcolor(bearDiv ? color.new(color.red, 90) : bullDiv ? color.new(color.green, 90) : na)');

  const pine = lines.join('\n');
  const pre = document.getElementById('pineCodePre');
  if (pre) pre.textContent = pine;

  const wrap = document.getElementById('pineCodeWrap');
  const btn2 = document.getElementById('pineToggleBtn');
  if (wrap) wrap.style.display = '';
  if (btn2) btn2.textContent = 'Hide Indicator \u25b2';

  _clipWrite(pine);
  _btnFeedback('copyDivBtn', '\u2713 Copied!', '\ud83d\udcc9 Copy RSI Div');
  showCopyCheck();
  showToast('📋 RSI Divergence script copied — paste into TradingView Pine Editor');
}

