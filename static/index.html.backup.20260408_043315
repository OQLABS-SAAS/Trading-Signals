// ===============================================================
// INPUTS
// ===============================================================
rsiLen      = input.int(14,  "RSI Length",              minval=1,  group=" RSI")
rsiOB       = input.float(70,"Overbought Level",        group=" RSI")
rsiOS       = input.float(30,"Oversold Level",          group=" RSI")
