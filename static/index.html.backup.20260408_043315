  let html = `<div style="font-size:10px;font-weight:700;color:var(--orange);letter-spacing:.5px;margin-bottom:8px;">${d.title}</div>`;

  if (d.period === 'daily') {
    html += stratCard(d.primary_strategy);
    if (d.backup_strategy) {
      html += `<div style="font-size:8.5px;color:var(--muted);margin-bottom:3px;">BACKUP (if primary has no setup):</div>`;
      html += stratCard(d.backup_strategy);
    }
    html += `<div style="font-size:9px;color:var(--text2);background:rgba(245,166,35,.06);border:1px solid rgba(245,166,35,.15);border-radius:5px;padding:6px 8px;margin:5px 0;">
      <div style="font-weight:700;color:var(--orange);margin-bottom:3px;">⏰ ${d.session_window}</div>
      <div>Max ${d.max_trades} trades · ${d.risk_per_trade_pct}% risk each</div>
