function renderMTF(mtf) {
  const keys = Object.keys(mtf);
  if (!keys.length) { document.getElementById('mtfContent').innerHTML = '<div style="font-size:12px;color:var(--muted);">Not available for this timeframe.</div>'; return; }
  document.getElementById('mtfContent').innerHTML = keys.map(tf => {
    const t = mtf[tf];
    return `<div class="mtf-row"><span class="mtf-tf">${tf}</span><span class="mtf-trend ${t.trend}">${t.trend}</span><span class="mtf-rsi">RSI ${t.rsi}</span></div>`;
  }).join('');
}

function renderAlignment(d) {
  // Build descriptive label + arrow for each indicator
  function rsiLabel(v) {
    if (v == null) return {label:'RSI —', cls:'neut', arrow:''};
    if (v < 40)   return {label:'RSI Oversold',   cls:'bull', arrow:'▲'};
    if (v > 60)   return {label:'RSI Overbought',  cls:'bear', arrow:'▼'};
                   return {label:'RSI Neutral',     cls:'neut', arrow:''};
  }
  function macdLabel(h) {
    if (h == null) return {label:'MACD —', cls:'neut', arrow:''};
    if (h > 0)     return {label:'MACD Bull Cross', cls:'bull', arrow:'▲'};
    if (h < 0)     return {label:'MACD Bear Cross', cls:'bear', arrow:'▼'};
                    return {label:'MACD Neutral',    cls:'neut', arrow:''};
  }
  function emaLabel(t) {
    if (!t) return {label:'EMA —', cls:'neut', arrow:''};
    if (t.includes('BULL')) return {label:'EMA Uptrend',   cls:'bull', arrow:'▲'};
    if (t.includes('BEAR')) return {label:'EMA Downtrend', cls:'bear', arrow:'▼'};
                             return {label:'EMA Neutral',   cls:'neut', arrow:''};
  }
  function bbLabel(p) {
    if (p == null) return {label:'BB —', cls:'neut', arrow:''};
    if (p < 0.30)  return {label:'BB Near Lower Band', cls:'bull', arrow:'▲'};
    if (p > 0.70)  return {label:'BB Near Upper Band', cls:'bear', arrow:'▼'};
                    return {label:'BB Mid Range',       cls:'neut', arrow:''};
  }

  // name = short label left, desc = description right, arrow separate
  function rsiRow(v)  { return v==null?{name:'RSI', desc:'—',    cls:'neut',arrow:''}:v<40?{name:'RSI', desc:'Oversold',   cls:'bull',arrow:'▲'}:v>60?{name:'RSI', desc:'Overbought', cls:'bear',arrow:'▼'}:{name:'RSI', desc:'Neutral', cls:'neut',arrow:''}; }
  function macdRow(h) { return h==null?{name:'MACD',desc:'—',    cls:'neut',arrow:''}:h>0?{name:'MACD',desc:'Bull Cross',  cls:'bull',arrow:'▲'}:h<0?{name:'MACD',desc:'Bear Cross',  cls:'bear',arrow:'▼'}:{name:'MACD',desc:'Neutral', cls:'neut',arrow:''}; }
  function emaRow(t)  { return !t?{name:'EMA', desc:'—',cls:'neut',arrow:''}:t.includes('BULL')?{name:'EMA', desc:'Uptrend',    cls:'bull',arrow:'▲'}:t.includes('BEAR')?{name:'EMA', desc:'Downtrend',  cls:'bear',arrow:'▼'}:{name:'EMA', desc:'Neutral', cls:'neut',arrow:''}; }
  function bbRow(p)   { return p==null?{name:'BB',  desc:'—',    cls:'neut',arrow:''}:p<0.30?{name:'BB',  desc:'Near Lower Band',cls:'bull',arrow:'▲'}:p>0.70?{name:'BB',  desc:'Near Upper Band',cls:'bear',arrow:'▼'}:{name:'BB',  desc:'Mid Range',cls:'neut',arrow:''}; }

  // ── Volume row — instrument-aware ──
  function volRow(data) {
    const v     = data.volume;
    const ratio = data.vol_ratio;
    const aType = (data.asset_type || 'crypto').toLowerCase();
    const tkr   = (data.ticker || '').toUpperCase();
    if (v == null) return {name:'VOL', desc:'—', cls:'neut', arrow:'', extra:''};

    // Format raw volume number
    let volFmt;
    if      (v >= 1e9) volFmt = (v/1e9).toFixed(2) + 'B';
    else if (v >= 1e6) volFmt = (v/1e6).toFixed(2) + 'M';
    else if (v >= 1e3) volFmt = (v/1e3).toFixed(1) + 'K';
    else               volFmt = v.toFixed(2);

    // Unit label per instrument
    let unit = '';
    if (aType === 'crypto') {
      const base = tkr.replace(/USDT?$|BUSD$|USD$|BTC$/, tkr.endsWith('BTC') ? '' : '');
      unit = base ? ' ' + base.slice(0,6) : '';
    } else if (aType === 'stock' || aType === 'index') {
      unit = ' shrs';
    }
    // forex: no unit (it's in base currency lots)

    // Direction from vol_ratio vs 20-bar avg
    let cls, arrow, strength;
    if (ratio == null) {
      cls = 'neut'; arrow = ''; strength = '';
    } else if (ratio >= 2.0) {
      cls = 'bull'; arrow = '▲'; strength = ' Surge';
    } else if (ratio >= 1.5) {
      cls = 'bull'; arrow = '▲'; strength = ' High';
    } else if (ratio < 0.5) {
      cls = 'bear'; arrow = '▼'; strength = ' Very Low';
    } else if (ratio < 0.7) {
      cls = 'bear'; arrow = '▼'; strength = ' Low';
    } else {
      cls = 'neut'; arrow = ''; strength = ' Avg';
    }

    const ratioStr = ratio != null ? ` (${parseFloat(ratio).toFixed(1)}×)` : '';
    return {name:'VOL', desc: volFmt + unit + strength + ratioStr, cls, arrow};
  }

  const checks = [ rsiRow(d.rsi), macdRow(d.macd_hist), emaRow(d.ema_trend), bbRow(d.bb_pos), volRow(d) ];

  document.getElementById('alignContent').innerHTML = checks.map(c => {
    const valCol = c.cls==='bull' ? 'rgba(72,220,105,0.92)' : c.cls==='bear' ? 'rgba(255,110,100,0.90)' : 'rgba(255,255,255,0.35)';
    return `<div class="alignment-row" style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.06);">
      <span style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.55);font-family:var(--mono);letter-spacing:.4px;">${c.name}</span>
      <span style="font-size:11px;font-weight:600;color:${valCol};letter-spacing:.2px;">${c.desc}${c.arrow ? ' <span style="font-size:10px;">'+c.arrow+'</span>' : ''}</span>
    </div>`;
  }).join('');
}

