════════════════════════════════════════════ */
function startClock() {
  const upd = () => {
    const n = new Date();
    const h = n.getUTCHours(), m = n.getUTCMinutes(), s = n.getUTCSeconds();
    const dow = n.getUTCDay(); // 0=Sunday, 6=Saturday
    const isWeekend = (dow === 0 || dow === 6);
    document.getElementById('headerClock').textContent =
      `${pad(h)}:${pad(m)}:${pad(s)} UTC`;
    const tot = h * 60 + m;
    // Markets are closed all weekend. On weekdays, check session hours.
    // Crypto is always open 24/7 — kept via crypto-open class permanently
    setSess('Tokyo',   !isWeekend && (tot < 540 || tot >= 1380));   // 00:00–09:00 UTC
    setSess('London',  !isWeekend && (tot >= 480 && tot < 1020));   // 08:00–17:00 UTC
    setSess('NewYork', !isWeekend && (tot >= 810 && tot < 1200));   // 13:30–20:00 UTC
  };
  upd(); setInterval(upd, 1000);
}
function setSess(id, open) { document.getElementById(`sess-${id}`).classList.toggle('open', open); }
function pad(n) { return String(n).padStart(2,'0'); }

