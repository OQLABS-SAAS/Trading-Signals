};

function _renderDeltaChart(deltas, dates) {
  if (!deltas || !deltas.length) return;
  const ctx = document.getElementById('deltaChart');
  if (!ctx) return;
  if (deltaChartInst) { deltaChartInst.destroy(); deltaChartInst = null; }

  const colors = deltas.map(d => d >= 0 ? 'rgba(0,201,141,0.75)' : 'rgba(255,68,89,0.75)');
  const borderColors = deltas.map(d => d >= 0 ? '#00c98d' : '#ff4459');

  deltaChartInst = new Chart(ctx.getContext('2d'), {
    type: 'bar',
    data: {
      labels: dates || deltas.map((_, i) => i),
      datasets: [{
        data:            deltas,
        backgroundColor: colors,
        borderColor:     borderColors,
        borderWidth:     0,
        barPercentage:   0.85,
        categoryPercentage: 0.95,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      plugins: { legend: { display: false }, tooltip: {
        callbacks: {
          label: ctx => {
            const v = ctx.parsed.y;
            return (v >= 0 ? '▲ Buy Δ: +' : '▼ Sell Δ: ') + _fmtVolLocal(Math.abs(v));
          }
        }
      }},
      scales: {
        x: { display: false },
        y: {
          display: true,
          position: 'right',
          ticks: { color: 'rgba(255,255,255,.25)', font: { size: 8 },
            callback: v => _fmtVolLocal(Math.abs(v)) },
          grid: { color: 'rgba(255,255,255,.04)' },
        }
      }
    }
  });
}

function _fmtVolLocal(v) {
  if (v == null || isNaN(v)) return '—';
  const n = Number(v);
  if (n >= 1e9) return (n/1e9).toFixed(1)+'B';
  if (n >= 1e6) return (n/1e6).toFixed(1)+'M';
  if (n >= 1e3) return (n/1e3).toFixed(1)+'K';
  return n.toFixed(0);
}

// Called by renderChart() — stores delta for toggle-on-demand rendering
function _updateDeltaLayer(d) {
  if (!d || !d.chart_delta) return;
  _latestChartDelta = { delta: d.chart_delta, dates: d.chart_dates || [] };
  if (_deltaVisible) {
    _renderDeltaChart(_latestChartDelta.delta, _latestChartDelta.dates);
  }
  // Always update the footprint strip (even if delta chart hidden)
  _updateFpStrip(d.chart_delta, d.chart_volumes);
}

function _updateFpStrip(deltas, volumes) {
  if (!deltas || !deltas.length) return;
  const lastDelta = deltas[deltas.length - 1] || 0;
  const avgVol    = volumes ? (volumes.reduce((a,b)=>a+b,0)/volumes.length) : 1;
  const lastVol   = volumes ? (volumes[volumes.length-1] || 0) : 0;

  // Recompute buy/sell split for latest candle using delta
  // delta = vol*(2*buyRatio-1)  →  buyRatio = (delta/vol + 1) / 2
  const absD    = Math.abs(lastDelta);
  const buyPct  = lastVol > 0 ? Math.round(((lastDelta / lastVol) + 1) / 2 * 100) : 50;
  const sellPct = 100 - buyPct;
  const buyVol  = Math.round(lastVol * buyPct / 100);
  const sellVol = Math.round(lastVol * sellPct / 100);

  // Estimate poser volume: CVD divergence suggests hidden pressure
  const cvd      = deltas.reduce((a, b) => a + b, 0);
  const cvdTrend = cvd > 0;

  // Poser signal: last candle delta OPPOSITE to 5-bar CVD trend = poser
  const last5 = deltas.slice(-5).reduce((a,b)=>a+b,0);
  const poserBuy  = lastDelta > 0 && last5 < 0;  // buying into selling trend
  const poserSell = lastDelta < 0 && last5 > 0;  // selling into buying trend
  const poserVol  = (poserBuy || poserSell) ? Math.round(Math.abs(lastDelta) * 0.6) : 0;

  // Update strip
  const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  const setColor = (id, color) => { const el = document.getElementById(id); if (el) el.style.color = color; };

  set('fpStripBuyPct',  buyPct  + '% BUY');
  set('fpStripSellPct', sellPct + '% SELL');
  const bar = document.getElementById('fpStripBar');
  if (bar) bar.style.width = buyPct + '%';

  set('fpStripBuyVol',  _fmtVolLocal(buyVol));
  set('fpStripSellVol', _fmtVolLocal(sellVol));
  set('fpStripPosers',  poserVol > 0 ? _fmtVolLocal(poserVol) : '—');
  setColor('fpStripPosers', poserVol > 0 ? '#f5a623' : 'var(--muted)');

  set('fpStripDelta', (lastDelta >= 0 ? '+' : '') + _fmtVolLocal(lastDelta));
  setColor('fpStripDelta', lastDelta >= 0 ? '#00c98d' : '#ff4459');

  set('fpStripCVD', (cvd >= 0 ? '+' : '') + _fmtVolLocal(cvd));
  setColor('fpStripCVD', cvd >= 0 ? '#00c98d' : '#ff4459');

  // Signal pills
  const pills = [];
  if (buyPct >= 65) pills.push({text:'Hidden Buyers', c:'#00c98d', bg:'rgba(0,201,141,.1)', b:'rgba(0,201,141,.25)'});
  if (sellPct >= 65) pills.push({text:'Hidden Sellers', c:'#ff4459', bg:'rgba(255,68,89,.1)', b:'rgba(255,68,89,.25)'});
  if (poserBuy)  pills.push({text:'⚡ Buyer Posers', c:'#f5a623', bg:'rgba(245,166,35,.1)', b:'rgba(245,166,35,.25)'});
  if (poserSell) pills.push({text:'⚡ Seller Posers', c:'#f5a623', bg:'rgba(245,166,35,.1)', b:'rgba(245,166,35,.25)'});

  const sp = document.getElementById('fpStripSignals');
  if (sp) sp.innerHTML = pills.map(p =>
    `<span style="font-size:8.5px;font-weight:700;padding:2px 6px;border-radius:10px;background:${p.bg};color:${p.c};border:1px solid ${p.b};">${p.text}</span>`
  ).join('');

  // Show strip if delta is toggled on
  const stripWrap = document.getElementById('fpStripWrap');
  if (stripWrap && _deltaVisible) stripWrap.style.display = 'block';
}

