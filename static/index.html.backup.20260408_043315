  if (!watchlist.length) { el.innerHTML = '<div style="font-size:12px;color:var(--muted);padding:6px 0;text-align:center;opacity:.6;">No tickers yet.</div>'; return; }
  el.innerHTML = watchlist.map((w, i) => `
