.fp-caveat{font-size:8px;color:var(--muted);font-style:italic;margin-top:5px;padding-top:4px;border-top:1px solid rgba(255,255,255,.05);}
/* Order Flow panel */
.of-section-title{font-size:8.5px;color:var(--muted);letter-spacing:.7px;margin:5px 0 3px;font-weight:600;}
.of-stack-row{display:flex;align-items:center;gap:5px;margin-bottom:3px;}
.of-stack-label{font-size:9px;color:var(--text2);width:34px;}
.of-stack-dots{display:flex;gap:2px;}
.of-dot{width:8px;height:8px;border-radius:50%;}
.of-dot.bull-on{background:#00c98d;box-shadow:0 0 4px rgba(0,201,141,.5);}
.of-dot.bull-off{background:rgba(0,201,141,.2);}
.of-dot.bear-on{background:#ff4459;box-shadow:0 0 4px rgba(255,68,89,.5);}
.of-dot.bear-off{background:rgba(255,68,89,.2);}
.of-liq-row{display:flex;align-items:center;justify-content:space-between;padding:3px 0;font-size:9.5px;}
.of-liq-key{color:var(--text2);}
.of-liq-val{font-family:var(--mono);font-weight:700;color:var(--text);}
.of-liq-near{font-size:8px;font-weight:700;padding:1px 5px;border-radius:10px;background:rgba(255,166,35,.2);color:#f5a623;margin-left:4px;}
/* Confidence bar on signal cards */
.se-conf-wrap{margin-top:5px;}
.se-conf-label{font-size:8.5px;color:var(--muted);letter-spacing:.5px;margin-bottom:2px;display:flex;justify-content:space-between;}
.se-conf-track{height:5px;background:rgba(255,255,255,.08);border-radius:10px;overflow:hidden;}
.se-conf-fill{height:100%;border-radius:10px;transition:width .4s ease;}
.se-conf-fill.high{background:linear-gradient(90deg,#00c98d,#00e5a0);}
.se-conf-fill.mid{background:linear-gradient(90deg,#f5a623,#ffd166);}
.se-conf-fill.low{background:linear-gradient(90deg,#ff4459,#ff8a80);}
.se-align-pills{display:flex;gap:3px;flex-wrap:wrap;margin-top:4px;}
.se-align-pill{font-size:8.5px;font-weight:700;padding:1px 6px;border-radius:10px;letter-spacing:.3px;}
.se-pill-fp-ok{background:rgba(0,201,141,.12);color:#00c98d;border:1px solid rgba(0,201,141,.25);}
.se-pill-fp-warn{background:rgba(255,68,89,.12);color:#ff4459;border:1px solid rgba(255,68,89,.25);}
.se-pill-of-ok{background:rgba(77,159,255,.12);color:#4d9fff;border:1px solid rgba(77,159,255,.25);}
.se-pill-liq{background:rgba(167,139,250,.12);color:#a78bfa;border:1px solid rgba(167,139,250,.25);}
.se-tab{flex:1;padding:4px 2px;font-size:9.5px;font-weight:600;color:var(--text2);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:4px;cursor:pointer;letter-spacing:.2px;transition:all .15s;white-space:nowrap;}
.se-tab:hover{background:rgba(245,158,11,.12);color:#F59E0B;}
.se-tab.active{background:rgba(245,158,11,.18);color:#F59E0B;border-color:rgba(245,158,11,.4);}
.se-input{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:4px;color:var(--text);font-size:11px;padding:4px 7px;outline:none;font-family:inherit;}
.se-qp-sym{font-size:8.5px;font-weight:700;padding:3px 7px;border-radius:3px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:var(--text2);cursor:pointer;letter-spacing:.3px;transition:all .15s;}
.se-qp-sym:hover,.se-qp-sym.active-sym{background:rgba(245,158,11,.16);color:#F59E0B;border-color:rgba(245,158,11,.4);}
.se-ticker-chip{display:inline-flex;align-items:center;gap:3px;font-size:9px;font-weight:700;padding:3px 7px;border-radius:10px;background:rgba(77,159,255,.12);color:#4d9fff;border:1px solid rgba(77,159,255,.25);}
.se-ticker-chip button{background:none;border:none;color:rgba(77,159,255,.6);cursor:pointer;font-size:10px;padding:0 0 0 2px;line-height:1;}
.se-ticker-chip button:hover{color:#ff4459;}
.se-scan-card{padding:7px 9px;border-radius:5px;border:1px solid rgba(255,255,255,.08);margin-bottom:4px;background:rgba(255,255,255,.025);}
.se-scan-go{border-color:rgba(0,201,141,.25) !important;background:rgba(0,201,141,.06) !important;}
.se-scan-nogo{border-color:rgba(239,68,68,.2) !important;background:rgba(239,68,68,.04) !important;}
.se-input:focus{border-color:rgba(245,158,11,.5);}
.se-gate-row{display:flex;justify-content:space-between;align-items:center;padding:2px 0;}
.se-gate-label{font-size:10px;color:var(--text2);}
.se-gate-val{font-size:10px;font-weight:600;}
.se-ref-btn{font-size:9px;font-weight:600;padding:2px 7px;border-radius:4px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:var(--muted);cursor:pointer;letter-spacing:.3px;}
.se-ref-btn:hover{border-color:rgba(245,158,11,.4);color:var(--orange);}
.se-ref-active{background:rgba(245,158,11,.15) !important;border-color:rgba(245,158,11,.5) !important;color:#F59E0B !important;}
.se-gate-ok{color:#22C55E;}.se-gate-fail{color:#EF4444;}.se-gate-neutral{color:#7a90b0;}
.se-signal-card{padding:8px;background:rgba(255,255,255,.03);border-radius:5px;margin-bottom:6px;border:1px solid rgba(255,255,255,.07);}
.se-signal-dir{font-size:11px;font-weight:700;margin-bottom:4px;}
.se-signal-dir.LONG{color:#22C55E;}.se-signal-dir.SHORT{color:#EF4444;}
.se-signal-row{display:flex;justify-content:space-between;font-size:10px;color:var(--text2);margin-bottom:1px;}
.se-signal-val{color:var(--text);font-family:var(--mono, monospace);}
.panel-title svg{flex-shrink:0;}
.mtf-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);}
.mtf-row:last-child{border-bottom:none;}
.mtf-tf{font-size:12px;font-weight:700;color:var(--text);font-family:var(--mono);}
.mtf-trend{font-size:11px;font-weight:700;}
.mtf-trend.BULLISH{color:rgba(72,220,105,0.88);}.mtf-trend.BEARISH{color:rgba(255,110,100,0.85);}.mtf-trend.NEUTRAL{color:var(--text2);}
.mtf-rsi{font-family:var(--mono);font-size:11px;color:var(--text2);max-width:54px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.watch-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:9px 10px;margin-bottom:5px;}
.watch-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;}
.watch-ticker{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--text);}
.watch-tf{font-size:10px;color:var(--muted);}
.watch-status{font-size:11px;color:var(--text2);}
.watch-check{font-size:10px;color:var(--muted);}
.remove-watch-btn{background:none;border:none;color:var(--muted);font-size:13px;padding:0;line-height:1;transition:color .15s;}
.remove-watch-btn:hover{color:var(--red);}
.no-watches{font-size:12px;color:var(--muted);text-align:center;padding:14px 0;}
/* ── Alert channel picker ── */
.ch-toggle{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--text2);cursor:pointer;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:3px 8px;user-select:none;transition:border-color .15s,color .15s;}
.ch-toggle input[type=checkbox]{accent-color:var(--accent);width:12px;height:12px;cursor:pointer;}
.ch-toggle:has(input:checked){border-color:var(--accent);color:var(--accent);}
.ch-test-btn{background:none;border:1px dashed var(--border);border-radius:6px;color:var(--muted);font-size:10px;padding:3px 8px;cursor:pointer;margin-left:auto;transition:all .16s;}
.ch-test-btn:hover{border-color:rgba(245,166,35,.55);color:#f5c842;background:rgba(245,166,35,.06);box-shadow:0 0 0 1px rgba(245,166,35,.18),0 0 10px rgba(245,166,35,.16);}
.ch-test-btn:active{box-shadow:0 0 0 2px rgba(245,166,35,.38),0 0 16px rgba(245,166,35,.26);}
.watch-channels{font-size:10px;color:var(--muted);margin-top:2px;}
/* ── Alert channel modal rows ── */
.am-ch-row{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:10px;border:1px solid var(--border);cursor:pointer;transition:border-color .15s,background .15s;user-select:none;}
.am-ch-row:has(input:checked){border-color:var(--accent,#f5a623);background:rgba(245,166,35,.07);}
.am-ch-row input[type=checkbox]{accent-color:var(--accent,#f5a623);width:16px;height:16px;flex-shrink:0;}
.am-ch-icon{font-size:20px;width:28px;text-align:center;flex-shrink:0;}
.am-ch-name{font-size:13px;font-weight:600;color:var(--text);}
.am-ch-desc{font-size:11px;color:var(--muted);margin-top:1px;}
#alertModal.open{display:flex!important;}
.alignment-row{display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border);font-size:11px;}
.alignment-row:last-child{border-bottom:none;}
.alignment-name{color:var(--text);font-weight:700;font-family:var(--mono);font-size:11px;}
.alignment-status{font-size:11px;font-weight:700;}
.alignment-status.bull{color:rgba(72,220,105,0.88);}.alignment-status.bear{color:rgba(255,110,100,0.85);}.alignment-status.neut{color:var(--muted);}
.risk-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.risk-field{display:flex;flex-direction:column;gap:3px;}
.risk-label-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:1px;}
.risk-label{font-size:10px;font-weight:700;letter-spacing:1.1px;color:rgba(245,190,80,0.52);}
.risk-auto-btn{font-size:8px;font-weight:800;letter-spacing:.9px;padding:2px 7px;border-radius:20px;border:1px solid rgba(245,166,35,.25);background:transparent;color:var(--muted);cursor:pointer;transition:all .18s;line-height:1.5;}
.risk-auto-btn.active{background:var(--orange);color:#000;border-color:var(--orange);box-shadow:0 0 8px rgba(245,166,35,.3);}
.risk-auto-val{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--text);padding:5px 8px;background:var(--surface);border:1px solid rgba(245,166,35,.3);border-radius:var(--radius-sm);min-height:28px;display:flex;align-items:center;gap:5px;}
.risk-auto-val::before{content:'⚡';font-size:9px;opacity:.7;}
.risk-auto-val.empty{color:var(--muted);font-size:10px;font-family:var(--sans);font-weight:400;}
.risk-auto-val.empty::before{content:'';display:none;}
.risk-input{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:6px 8px;border-radius:var(--radius-sm);font-size:12px;font-family:var(--mono);outline:none;width:100%;}
.risk-input:focus{border-color:var(--border2);}
.risk-result{margin-top:8px;background:var(--orange-bg);border:1px solid rgba(245,166,35,.2);border-radius:var(--radius-sm);padding:10px;display:none;}
.risk-result-val{font-family:var(--mono);font-size:17px;font-weight:700;color:var(--orange);margin-top:2px;}
.risk-calc-btn{background:linear-gradient(135deg,var(--orange),#ff8800);border:none;color:#000;padding:9px;border-radius:var(--radius-sm);font-size:12px;font-weight:800;transition:all .15s;width:100%;margin-top:7px;letter-spacing:.3px;}
.risk-calc-btn:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 4px 16px rgba(245,166,35,.35);}
/* Direction selector */
.calc-dir-row{display:flex;gap:6px;margin-bottom:10px;}
.calc-dir-btn{flex:1;padding:7px 0;border-radius:var(--radius-sm);border:1.5px solid rgba(255,255,255,.1);background:var(--card);font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;letter-spacing:.4px;color:var(--muted);}
.calc-dir-btn.buy-on{background:rgba(0,201,141,.14);border-color:#00c98d;color:#00c98d;}
.calc-dir-btn.sell-on{background:rgba(255,68,89,.14);border-color:#ff4459;color:#ff6b7a;}
.calc-dir-btn:not(.buy-on):not(.sell-on):hover{background:rgba(255,255,255,.06);color:rgba(255,255,255,.7);}
.calc-dir-btn.dim{opacity:.35;pointer-events:auto;} /* HOLD neutral state — still clickable */
/* Calculate Position CTA (in signal card) */
.calc-pos-cta{display:flex;align-items:center;gap:10px;width:100%;margin:10px 0 0;padding:11px 14px;border-radius:var(--radius-sm);background:rgba(245,166,35,.07);border:1.5px solid rgba(245,166,35,.22);cursor:pointer;transition:all .2s;text-align:left;}
.calc-pos-cta:hover{background:rgba(245,166,35,.14);border-color:rgba(245,166,35,.4);transform:translateY(-1px);}
.calc-pos-cta.sell-mode{background:rgba(255,82,74,.07);border-color:rgba(255,82,74,.22);}
.calc-pos-cta.sell-mode:hover{background:rgba(255,82,74,.14);border-color:rgba(255,82,74,.4);}
.calc-pos-icon{font-size:18px;flex-shrink:0;}
.calc-pos-text{flex:1;display:flex;flex-direction:column;gap:1px;}
.calc-pos-main{font-size:12px;font-weight:700;color:var(--orange);letter-spacing:.2px;}
.calc-pos-cta.sell-mode .calc-pos-main{color:#ff6e66;}
.calc-pos-sub{font-size:10px;color:var(--muted);}
.calc-pos-arrow{font-size:16px;color:var(--orange);opacity:.7;font-weight:700;}
.calc-pos-cta.sell-mode .calc-pos-arrow{color:#ff6e66;}
/* Signal context badge (in calculator) */
.calc-signal-badge{display:flex;align-items:center;gap:7px;padding:7px 10px;border-radius:6px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);margin-bottom:10px;font-size:11px;}
.calc-badge-pill{padding:2px 7px;border-radius:4px;font-size:9px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.calc-badge-pill.BUY{background:rgba(0,201,141,.15);color:#00c98d;border:1px solid rgba(0,201,141,.3);}
.calc-badge-pill.SELL{background:rgba(255,82,74,.13);color:#ff6e66;border:1px solid rgba(255,82,74,.28);}
.calc-badge-ticker{font-weight:700;color:var(--text);font-family:var(--mono);}
.calc-badge-tf{color:var(--muted);font-size:10px;}
.calc-badge-dot{color:rgba(255,255,255,.2);}
.calc-badge-clear{margin-left:auto;background:none;border:none;color:var(--muted);cursor:pointer;font-size:14px;line-height:1;padding:0;opacity:.6;}
.calc-badge-clear:hover{opacity:1;color:var(--text);}

/* ── ENHANCED CALCULATOR ── */
.calc-row{display:flex;gap:7px;margin-bottom:7px;}
.calc-field{margin-bottom:7px;}
.calc-field.half{flex:1;margin-bottom:0;}
.calc-pct-btns{display:flex;gap:4px;align-items:center;margin-top:5px;}
.calc-pct-btn{flex:1;padding:5px 0;font-size:11px;font-weight:700;background:var(--surface2);border:1px solid var(--border);color:var(--text2);border-radius:6px;transition:all .15s;cursor:pointer;line-height:1;}
.calc-pct-btn:hover{border-color:var(--orange);color:var(--orange);}
.calc-pct-btn.active{background:var(--orange-bg);border-color:rgba(245,166,35,.5);color:var(--orange);}
.calc-pct-input{width:42px;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:6px;font-size:11px;font-family:var(--mono);padding:4px 5px;text-align:center;outline:none;flex-shrink:0;}
.calc-pct-input:focus{border-color:var(--orange);}
.calc-risk-amt-row{display:flex;justify-content:space-between;align-items:center;background:var(--red-bg);border:1px solid rgba(255,68,89,.15);border-radius:8px;padding:7px 10px;margin-bottom:7px;}
.calc-risk-amt{font-family:var(--mono);font-size:14px;font-weight:800;color:var(--red);}
.calc-results{margin-top:10px;}
.calc-result-block{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px;margin-bottom:8px;}
.calc-result-row{display:flex;gap:6px;}
.calc-result-row.main{margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.calc-result-row>div{flex:1;min-width:0;}
.calc-result-label{font-size:9px;color:rgba(245,190,80,0.52);font-weight:700;letter-spacing:1.2px;text-transform:uppercase;margin-bottom:2px;}
.calc-result-val{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.calc-result-val.orange{color:var(--orange);}
.calc-result-val.red{color:var(--red);}
.calc-tp-title{font-size:10px;font-weight:700;letter-spacing:1.3px;color:rgba(245,190,80,0.55);text-transform:uppercase;margin-bottom:6px;}
.calc-tp-table{display:flex;flex-direction:column;gap:5px;}
/* Redesigned TP rows — price level + expandable detail */
.calc-tp-row{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 10px;cursor:pointer;transition:border-color .15s;}
.calc-tp-row:hover{border-color:rgba(255,255,255,.18);}
.calc-tp-row-main{display:grid;grid-template-columns:auto 1fr auto;gap:8px;align-items:center;}
.calc-tp-lhs{display:flex;flex-direction:column;gap:2px;}
.calc-tp-name{font-size:11px;font-weight:800;}
.calc-tp-price{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.38);letter-spacing:.2px;}
.calc-tp-mid{display:flex;flex-direction:column;gap:1px;}
.calc-tp-rr{font-family:var(--mono);font-size:10px;color:var(--text2);}
.calc-tp-rr-hint{font-size:9px;color:var(--muted);}
.calc-tp-profit{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--green);text-align:right;}
.calc-tp-expand-hint{font-size:9px;color:rgba(255,255,255,.22);text-align:right;margin-top:1px;}
/* Expanded detail */
.calc-tp-detail{display:none;flex-direction:column;gap:4px;padding-top:8px;margin-top:8px;border-top:1px solid rgba(255,255,255,.07);}
.calc-tp-detail-row{display:flex;justify-content:space-between;align-items:center;font-size:10px;}
.calc-tp-detail-label{color:var(--muted);}
.calc-tp-detail-val{font-family:var(--mono);color:var(--text);font-weight:600;}
.calc-tp-row.expanded .calc-tp-detail{display:flex;}
.calc-tp-row.expanded{border-color:rgba(255,255,255,.22);}
/* Pips breakdown block */
.calc-pips-block{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:9px 10px;margin-bottom:8px;}
.calc-pips-title{font-size:9px;font-weight:700;letter-spacing:1.3px;color:rgba(245,190,80,0.55);text-transform:uppercase;margin-bottom:7px;}
.calc-pips-row{display:flex;align-items:center;gap:7px;padding:4px 0;}
.calc-pips-row+.calc-pips-row{border-top:1px solid rgba(255,255,255,.05);}
.calc-pips-label{width:30px;font-size:9px;font-weight:700;flex-shrink:0;letter-spacing:.3px;}
.calc-pips-bar-wrap{flex:1;height:4px;background:rgba(255,255,255,.07);border-radius:2px;overflow:hidden;}
.calc-pips-bar{height:100%;border-radius:2px;}
.calc-pips-val{font-family:var(--mono);font-size:10px;text-align:right;min-width:58px;flex-shrink:0;}

/* UTILS */
.up{color:var(--green)!important;}.down{color:var(--red)!important;}
.hidden{display:none!important;}
.hold-msg{background:var(--yellow-bg);border:1px solid rgba(255,201,71,.2);border-radius:var(--radius-sm);padding:12px 16px;color:var(--yellow);font-size:12px;font-weight:500;}
.toast{position:fixed;bottom:20px;right:20px;background:var(--surface2);border:1px solid rgba(245,166,35,.2);color:var(--text);padding:12px 18px;border-radius:var(--radius);font-size:13px;font-weight:500;box-shadow:var(--shadow);display:none;align-items:center;gap:8px;z-index:200;animation:slideIn .3s ease;}
@keyframes slideIn{from{transform:translateY(10px);opacity:0;}to{transform:translateY(0);opacity:1;}}

/* ── PASSWORD GATE ── */
#passwordGate {
  position:fixed;inset:0;z-index:999;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(245,166,35,.06) 0%,#080808 60%);
  display:none;  /* hidden until auth check confirms password required */
  align-items:center;justify-content:center;
  flex-direction:column;
  opacity:0;transition:opacity .3s;
}
.gate-card {
  background:var(--surface);
  border:1px solid rgba(245,166,35,.12);
  border-radius:20px;
  padding:48px 44px;
  width:100%;max-width:400px;
  display:flex;flex-direction:column;align-items:center;gap:0;
  box-shadow:0 32px 80px rgba(0,0,0,.7);
  animation:gateIn .45s cubic-bezier(.16,1,.3,1);
}
@keyframes gateIn{from{transform:translateY(28px);opacity:0;}to{transform:translateY(0);opacity:1;}}
.gate-logo {
  width:76px;height:76px;border-radius:50%;
  background:radial-gradient(circle at 50% 50%,rgba(245,166,35,.08),rgba(245,166,35,.02));
  border:1px solid rgba(245,166,35,.18);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:22px;
  box-shadow:0 0 40px rgba(245,166,35,.2), 0 0 80px rgba(245,166,35,.08);
}
.gate-title {
  font-size:24px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:6px;
}
.gate-sub {
  font-size:13px;color:var(--muted);margin-bottom:30px;text-align:center;line-height:1.6;
}
.gate-input-wrap {
  width:100%;position:relative;margin-bottom:14px;
}
.gate-input {
  width:100%;background:var(--bg2);border:1px solid var(--border);
  color:var(--text);padding:0 44px 0 16px;border-radius:12px;
  font-size:15px;font-family:var(--mono);height:50px;outline:none;
  letter-spacing:2px;transition:border-color .2s,box-shadow .2s;
}
.gate-input:focus{border-color:rgba(245,166,35,.5);box-shadow:0 0 0 3px rgba(245,166,35,.1);}
.gate-eye {
  position:absolute;right:14px;top:50%;transform:translateY(-50%);
  background:none;border:none;color:var(--muted);font-size:17px;cursor:pointer;
  transition:color .15s;
}
.gate-eye:hover{color:var(--text);}
.gate-btn {
  width:100%;height:50px;border-radius:12px;border:none;
  background:linear-gradient(135deg,var(--orange),#ff8800);
  color:#000;font-size:15px;font-weight:800;letter-spacing:.3px;
  cursor:pointer;transition:all .2s;
}
.gate-btn:hover{opacity:.9;box-shadow:0 0 28px rgba(245,166,35,.4);}.gate-btn:disabled{opacity:.55;cursor:wait;}
.gate-error {
  color:var(--red);font-size:12px;font-weight:500;margin-top:10px;
  min-height:16px;text-align:center;
}
.gate-footer {
  margin-top:24px;font-size:11px;color:var(--muted);text-align:center;
}
.gate-footer strong{color:var(--text2);}

/* Logout button in header */
.logout-btn{
  background:none;border:1px solid var(--border);color:var(--muted);
  padding:5px 11px;border-radius:var(--radius-sm);font-size:12px;
  transition:all .15s;
}
.logout-btn:hover{border-color:var(--red);color:var(--red);}

/* ══════════════════════════════════════════
   MOBILE BOTTOM NAV
══════════════════════════════════════════ */
.mobile-nav{
  display:none;
  position:fixed;bottom:0;left:0;right:0;height:60px;z-index:90;
  background:rgba(10,10,10,.95);border-top:1px solid var(--border);
  box-shadow:0 -4px 30px rgba(0,0,0,.5);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
}
.mnav-btn{
  flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:3px;background:none;border:none;
  color:var(--muted);font-size:10px;font-weight:600;
  padding:6px 0;transition:color .15s;letter-spacing:.3px;
  -webkit-tap-highlight-color:transparent;
}
.mnav-btn:hover{color:#f5c842;text-shadow:0 0 10px rgba(245,166,35,.35);}
.mnav-btn.active{color:#f5c842;text-shadow:0 0 8px rgba(245,166,35,.28);}
.mnav-icon{font-size:18px;line-height:1;}

/* Drawer backdrop */
.drawer-backdrop{
  display:none;position:fixed;inset:0;z-index:84;
  background:rgba(0,0,0,.55);backdrop-filter:blur(3px);
  transition:opacity .25s;opacity:0;
}
.drawer-backdrop.open{display:block;opacity:1;}

/* Drawer handle bar */
.drawer-handle{
  width:40px;height:4px;border-radius:2px;background:rgba(245,166,35,.25);
  margin:10px auto 6px;flex-shrink:0;
}
.drawer-title{
  font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  color:var(--muted);text-align:center;padding-bottom:10px;
  border-bottom:1px solid var(--border);margin-bottom:4px;flex-shrink:0;
}

/* ══════════════════════════════════════════
   MOBILE RESPONSIVE — TABLET (≤900px)
══════════════════════════════════════════ */
@media(max-width:900px){
  /* Show mobile nav */
  .mobile-nav{display:flex;}

  /* Sidebars become bottom drawers */
  .sidebar-left,.sidebar-right{
    display:flex!important;
    position:fixed!important;
    bottom:60px;left:0;right:0;
    height:72vh;width:100%!important;max-width:100%!important;
    border-radius:20px 20px 0 0;
    border-top:1px solid rgba(245,166,35,.15);
    border-right:none;border-left:none;
    transform:translateY(110%);
    transition:transform .35s cubic-bezier(.16,1,.3,1);
    z-index:86;overflow:hidden;
    background:rgba(14,14,14,.98);backdrop-filter:blur(20px);
  }
  .sidebar-left.drawer-open,.sidebar-right.drawer-open{transform:translateY(0);}

  /* Drawer inner scroll */
  .sidebar-left,.sidebar-right{overflow-y:auto;-webkit-overflow-scrolling:touch;}

  /* Resize handles hidden */
  .resize-handle{display:none!important;}

  /* Main fills screen width */
  .main-content{overflow-y:auto;padding-bottom:68px;}

  /* Header — hide sessions + clock on tablet */
  .sessions-row{display:none;}
  .clock{display:none;}
}

/* ══════════════════════════════════════════
   MOBILE RESPONSIVE — PHONE (≤600px)
══════════════════════════════════════════ */
@media(max-width:600px){
  /* Header tightening */
  header{padding:0 12px;height:50px;}
  :root{--header-h:50px;}
  .logo{font-size:14px;gap:7px;}
  .logo-badge{display:none;}
  .logo-icon{width:26px;height:26px;font-size:13px;}
  .theme-btn{padding:5px 8px;font-size:13px;}
  .logout-btn{padding:5px 8px;font-size:11px;}

  /* Tape tighter */
  .tape-item{padding:0 10px;gap:4px;}
  .tape-symbol{font-size:10px;}
  .tape-price,.tape-chg{font-size:10px;}

  /* Search panel — stack vertically */
  .search-panel{flex-direction:column;padding:10px 12px;gap:8px;}
  .ticker-input{width:100%;height:46px;font-size:16px;} /* 16px prevents iOS zoom */
  .ctrl-select{width:100%;height:46px;font-size:15px;}
  .analyze-btn{width:100%;height:46px;font-size:15px;}

  /* Main content */
  .main-content{padding:10px 10px 68px;}

  /* Asset header */
  .asset-header{padding:12px 14px;}
  .asset-ticker{font-size:17px;}
  .asset-price{font-size:24px;}
  .asset-chg{font-size:13px;}
  /* Stat bar — 3-column grid so all stats are visible without horizontal scroll */
  .asset-stats{
    display:grid!important;grid-template-columns:repeat(3,1fr);gap:8px 6px;
    overflow-x:unset;padding-bottom:2px;
  }
  .stat-item{min-width:unset;flex-shrink:unset;padding-right:0;border-right:none!important;}
  .stat-label{font-size:9px;}
  .stat-value{font-size:12px;}

  /* Chart */
  .chart-card{padding:10px;}
  .chart-container{height:190px;}
  .vol-container{height:44px;}
  .chart-legend{gap:8px;}
  .legend-item{font-size:10px;}

  /* Signal card — stack on small */
  .signal-card{grid-template-columns:1fr;padding:14px;}
  .signal-badge{flex-direction:row;gap:14px;justify-content:flex-start;min-width:unset;}
  .signal-label{font-size:28px;}
  .signal-summary{font-size:12px;}
  .action-btn{padding:8px 12px;font-size:12px;min-height:40px;}

  /* Scenarios — single column */
  .scenarios-grid{grid-template-columns:1fr;}

  /* Indicators — 2 columns */
  .indicators-grid{grid-template-columns:repeat(2,1fr);}
  .ind-card{padding:11px;}
  .ind-val{font-size:16px;}

  /* Counter levels — 2 columns */
  .counter-levels-grid{grid-template-columns:repeat(2,1fr)!important;}
  .counter-header{flex-wrap:wrap;gap:6px;}

  /* Levels table */
  .levels-table th,.levels-table td{padding:5px 3px;font-size:11px;}
  .rr-bar-wrap{width:50px;}

  /* Empty state */
  .empty-state{padding:30px 12px;}
  .empty-icon{font-size:36px;}
  .empty-title{font-size:16px;}
  .empty-sub{font-size:12px;}

  /* Instrument tabs */
  .inst-tab{padding:7px 10px;font-size:11px;}
  .inst-grid{grid-template-columns:repeat(3,1fr)!important;max-width:100%;}
  .inst-chip{padding:10px 4px;font-size:11px;}
  .inst-chip .chip-tf{font-size:9px;}

  /* Hold message */
  .hold-msg{font-size:12px;padding:10px 12px;}

  /* Password gate */
  .gate-card{padding:32px 24px;}
  .gate-title{font-size:19px;}
  .gate-input{font-size:16px;}
  .gate-btn{font-size:15px;}

  /* Panel cards in drawers */
  .panel-card{padding:10px 14px;}
  .sidebar-section{padding:10px 14px;}

  /* MTF, alignment rows */
  .mtf-tf,.mtf-rsi,.alignment-name,.alignment-status{font-size:12px;}
  .risk-input{font-size:14px;height:40px;}
  .risk-calc-btn{font-size:13px;padding:10px;}
}

/* ── MAIN AREA TABS (Analysis | News & Markets) ── */
.main-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);background:var(--bg2);padding:0 18px;}
.main-tab{background:none;border:none;border-bottom:2px solid transparent;color:var(--muted);font-size:12px;font-weight:600;padding:11px 16px;cursor:pointer;transition:all .15s;letter-spacing:.3px;white-space:nowrap;}
.main-tab.active{color:var(--orange);border-bottom-color:var(--orange);}
.main-tab:hover:not(.active){color:var(--text);}

/* ── ASSET TYPE QUICK FILTER ── */
.asset-filter-row{display:flex;gap:5px;padding:10px 0 4px;flex-wrap:wrap;}
.asset-filter-btn{padding:5px 11px;font-size:11px;font-weight:600;background:var(--surface2);border:1px solid var(--border);color:var(--text2);border-radius:20px;cursor:pointer;transition:all .15s;}
.asset-filter-btn:hover{border-color:var(--orange);color:var(--orange);}
.asset-filter-btn.active{background:var(--orange-bg);border-color:rgba(245,166,35,.5);color:var(--orange);}

/* ── SENTIMENT HEATMAP ── */
.sentiment-wrap{margin-top:10px;padding:10px 12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:9px;}
.sentiment-title{font-size:9px;font-weight:700;letter-spacing:1.6px;color:rgba(245,190,80,0.55);text-transform:uppercase;margin-bottom:7px;}
.sentiment-bar{height:5px;border-radius:3px;overflow:hidden;display:flex;margin-bottom:6px;background:rgba(255,255,255,0.06);}
.sent-bull{background:#f5a623;transition:width .7s ease;}
.sent-bear{background:rgba(48,209,88,0.70);transition:width .7s ease;}
.sentiment-labels{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;font-weight:600;}
.sent-bull-lbl{color:#f5a623;font-weight:600;}
.sent-bear-lbl{color:rgba(48,209,88,0.90);font-weight:600;}
.sent-source{font-size:9px;color:rgba(255,255,255,0.25);text-align:center;margin-top:4px;}

/* ── CONFIDENCE WARNING ── */
.conf-warn{font-size:10px;font-weight:700;text-align:center;padding:4px 10px;border-radius:20px;margin-top:6px;display:none;}
.conf-warn.low{background:var(--red-bg);color:var(--red);}
.conf-warn.medium{background:var(--yellow-bg);color:var(--yellow);}

/* ── NEWS & MARKETS AREA ── */
.news-area{padding:12px 0;}
.news-section-title{font-size:10px;font-weight:700;letter-spacing:1.6px;color:rgba(245,190,80,0.65);text-transform:uppercase;padding:14px 0 6px;border-bottom:1px solid rgba(245,166,35,0.15);margin-bottom:8px;}
.daily-brief-box{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:13px;padding:16px 18px;font-size:13px;line-height:1.80;color:rgba(255,255,255,0.78);font-weight:400;letter-spacing:.01em;}
.daily-brief-box strong{color:rgba(255,255,255,0.92);font-weight:600;}
.daily-brief-box .brief-section{margin:10px 0 4px;font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,0.28);}
.macro-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;}
@media(max-width:600px){.macro-grid{grid-template-columns:1fr;}}
.macro-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:13px;padding:12px 14px;}
.macro-card-bank{font-size:11px;font-weight:600;color:rgba(245,190,80,0.62);letter-spacing:.04em;}
.macro-card-rate{font-family:var(--mono);font-size:15px;font-weight:800;color:#f5a623;margin:4px 0 5px;}
.macro-card-bias{font-size:9px;font-weight:700;padding:2px 9px;border-radius:20px;display:inline-block;letter-spacing:.6px;text-transform:uppercase;}
.macro-card-bias.hold{background:rgba(245,166,35,0.10);color:#f5a623;border:1px solid rgba(245,166,35,0.25);}
.macro-card-bias.hawkish{background:rgba(255,82,70,0.12);color:rgba(255,110,100,0.88);border:1px solid rgba(255,82,70,0.28);}
.macro-card-bias.dovish{background:rgba(48,209,88,0.10);color:rgba(48,209,88,0.85);border:1px solid rgba(48,209,88,0.25);}
.econ-list{display:flex;flex-direction:column;gap:5px;}
.econ-event{display:grid;grid-template-columns:70px 1fr auto;gap:8px;align-items:center;padding:9px 13px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:11px;}
.econ-time{font-family:var(--mono);font-size:10px;color:rgba(245,190,80,0.52);}
.econ-name{font-size:12px;font-weight:500;color:rgba(255,255,255,0.82);}
.econ-country{font-size:10px;color:rgba(245,190,80,0.38);}
.econ-impact{font-size:9px;font-weight:700;padding:2px 8px;border-radius:20px;letter-spacing:.4px;text-transform:uppercase;}
.econ-impact.high{background:rgba(245,166,35,0.12);color:rgba(245,166,35,0.85);border:1px solid rgba(245,166,35,0.25);}
.econ-impact.medium{background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.45);border:1px solid rgba(255,255,255,0.10);}
.econ-impact.low{background:rgba(255,255,255,0.03);color:rgba(255,255,255,0.22);border:1px solid rgba(255,255,255,0.07);}
.kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;}
@media(max-width:600px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);border-radius:11px;padding:11px 13px;}
.kpi-label{font-size:9px;font-weight:700;letter-spacing:1.2px;color:rgba(245,190,80,0.52);text-transform:uppercase;margin-bottom:4px;}
.kpi-val{font-family:var(--mono);font-size:14px;font-weight:800;}
.kpi-prev{font-size:10px;color:rgba(255,255,255,0.28);margin-top:3px;}

/* ── RESULTS MAIN ROW: chart + signal side-by-side ── */
/* Chart full-width, signal card below it */
.results-main-row{display:flex;flex-direction:column;gap:16px;}
.results-main-row .chart-card{width:100%;}

/* Signal card — horizontal layout: badge left, content right */
.signal-card{display:flex;flex-direction:row;gap:24px;align-items:flex-start;width:100%;}
.signal-badge{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:10px;min-width:90px;}
.signal-body{flex:1;min-width:0;}

/* New feature cards — neutral glass, no competing colors */
.narrative-card{background:var(--surface);border:1px solid rgba(245,166,35,.22);border-radius:var(--radius);padding:16px 20px;margin-top:0;position:relative;overflow:hidden;}
.narrative-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,rgba(255,180,50,.8),rgba(255,180,50,.08));border-radius:var(--radius) var(--radius) 0 0;}
.narrative-text{font-size:13px;line-height:1.85;color:var(--text);opacity:.88;font-style:normal;}
.narrative-label{font-size:12px;font-weight:700;color:var(--text);margin-bottom:13px;display:flex;align-items:center;gap:8px;}
.narrative-label::before{content:'';flex:1;height:1px;background:var(--border);}
.narrative-label::after{content:'';flex:1;height:1px;background:var(--border);}

/* Timing meter — subtle, iOS-style */
.timing-meter{display:flex;align-items:center;gap:10px;padding:9px 13px;border-radius:9px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);}
.timing-icon{font-size:14px;flex-shrink:0;opacity:0.55;}
.timing-signal{font-size:11px;font-weight:700;letter-spacing:.7px;font-family:var(--mono);text-transform:uppercase;}
.timing-signal.enter{color:#f5a623;}
.timing-signal.wait{color:rgba(245,166,35,0.60);}
.timing-signal.late{color:rgba(255,255,255,0.35);}
.timing-detail{font-size:11px;color:rgba(255,255,255,0.35);margin-top:2px;}

/* Micro lesson — same neutral glass as narrative */
.micro-lesson{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:12px 16px;margin-top:0;}
.micro-lesson-label{font-size:9px;font-weight:700;letter-spacing:1.8px;text-transform:uppercase;color:rgba(245,190,80,0.75);margin-bottom:6px;text-align:center;}
.micro-lesson-text{font-size:12px;line-height:1.72;color:rgba(255,255,255,0.68);}

/* Simulate button */
.simulate-btn{background:rgba(245,166,35,0.12);border:1px solid rgba(245,166,35,0.30);color:var(--orange);font-size:12px;font-weight:700;padding:8px 16px;border-radius:9px;cursor:pointer;transition:all .16s;letter-spacing:.3px;font-family:var(--sans);}
.simulate-btn:hover{background:rgba(245,166,35,0.20);border-color:rgba(245,166,35,0.48);transform:translateY(-1px);}
.simulate-btn:disabled{opacity:.5;cursor:wait;transform:none;}

/* ── SIMULATION MODAL ── */
.sim-modal-backdrop{position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,.65);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);display:flex;align-items:center;justify-content:center;padding:16px;}
.sim-modal{background:rgba(18,16,14,0.92);backdrop-filter:blur(40px) saturate(160%);-webkit-backdrop-filter:blur(40px) saturate(160%);border:1px solid rgba(255,255,255,0.11);border-radius:20px;padding:28px 28px 22px;width:min(780px,96vw);max-height:88vh;overflow-y:auto;box-shadow:0 40px 100px rgba(0,0,0,.85),inset 0 1px 0 rgba(255,255,255,0.10);}
.sim-modal-title{font-size:15px;font-weight:700;color:rgba(255,255,255,0.90);letter-spacing:-.2px;margin-bottom:3px;}
.sim-modal-sub{font-size:11px;color:rgba(255,255,255,0.30);letter-spacing:.3px;margin-bottom:22px;}

/* Three scenario cards stacked vertically — each a distinct section */
.sim-paths{display:flex;flex-direction:column;gap:10px;}
.sim-path{
  display:grid;
  grid-template-columns:100px 1fr;
  gap:0;
  border-radius:13px;
  border:1px solid rgba(255,255,255,0.09);
  background:rgba(255,255,255,0.04);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  overflow:hidden;
}
/* Left accent column — probability + label */
.sim-path-left{
  padding:18px 16px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;
  border-right:1px solid rgba(255,255,255,0.07);
  background:rgba(255,255,255,0.02);
}
.sim-path-prob{font-family:var(--mono);font-size:24px;font-weight:800;line-height:1;color:rgba(255,255,255,0.85);}
.sim-path-prob-lbl{font-size:8px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,0.28);}
.sim-path-title{font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;margin-top:10px;text-align:center;line-height:1.5;}

/* Right content column */
.sim-path-right{padding:16px 18px;display:flex;flex-direction:column;gap:10px;}
.sim-path-text{font-size:12.5px;line-height:1.78;color:rgba(255,255,255,0.78);}
.sim-path-meta{display:flex;flex-direction:column;gap:6px;padding-top:10px;border-top:1px solid rgba(255,255,255,0.07);}
.sim-meta-row{display:flex;gap:8px;align-items:flex-start;}
.sim-meta-label{font-size:9px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase;white-space:nowrap;padding-top:1px;min-width:52px;}
.sim-meta-text{font-size:11.5px;color:rgba(255,255,255,0.60);line-height:1.55;}

/* WATCH = amber (pay attention), MANAGE = green (safe action) */
.sim-meta-label.watch  { color: #f5a623; }
.sim-meta-label.manage { color: rgba(48,209,88,0.85); }

/* Accent top-border + probability colour per scenario */
.sim-path.success      { border-top: 2px solid rgba(245,166,35,0.65); }
.sim-path.consolidation{ border-top: 2px solid rgba(48,209,88,0.50); }
.sim-path.reversal     { border-top: 2px solid rgba(255,82,70,0.55); }

/* Left column probability number colour */
.sim-path.success      .sim-path-left { background: rgba(245,166,35,0.04); border-right-color: rgba(245,166,35,0.10); }
.sim-path.consolidation .sim-path-left{ background: rgba(48,209,88,0.04);  border-right-color: rgba(48,209,88,0.10); }
.sim-path.reversal     .sim-path-left { background: rgba(255,82,70,0.05);  border-right-color: rgba(255,82,70,0.12); }

.sim-path.success      .sim-path-prob  { color: #f5a623; }
.sim-path.consolidation .sim-path-prob { color: rgba(48,209,88,0.92); }
.sim-path.reversal     .sim-path-prob  { color: rgba(255,110,100,0.90); }

.sim-path.success      .sim-path-title { color: rgba(245,166,35,0.55); }
.sim-path.consolidation .sim-path-title{ color: rgba(48,209,88,0.50); }
.sim-path.reversal     .sim-path-title { color: rgba(255,110,100,0.55); }

.sim-close-btn{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.55);padding:10px;border-radius:10px;cursor:pointer;font-size:12px;font-weight:500;letter-spacing:.3px;margin-top:14px;transition:all .15s;}
.sim-close-btn:hover{background:rgba(255,255,255,0.09);color:rgba(255,255,255,0.75);}
.sim-loading{text-align:center;padding:48px 0;color:rgba(255,255,255,0.28);font-size:12px;letter-spacing:.5px;}

/* Live commentary badge on watch items */
.live-badge{display:inline-flex;align-items:center;gap:4px;font-size:9px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:#f5a623;background:rgba(245,166,35,.10);border:1px solid rgba(245,166,35,.28);border-radius:4px;padding:2px 6px;}
.live-narrative{font-size:11px;color:rgba(255,255,255,.5);line-height:1.6;margin-top:6px;font-style:italic;}

/* ── MARKET PULSE WIDGET ── */
.pulse-gauge{display:flex;flex-direction:column;align-items:center;gap:6px;padding:10px 0 6px;}
.pulse-num{font-family:var(--mono);font-size:34px;font-weight:800;line-height:1;}
.pulse-label{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;}
.pulse-bar-wrap{width:100%;padding:0 4px;}
.pulse-bar{width:100%;height:4px;border-radius:2px;background:linear-gradient(to right,rgba(255,255,255,0.12) 0%,rgba(245,166,35,0.60) 50%,rgba(245,166,35,0.20) 100%);position:relative;margin:4px 0;}
.pulse-bar-dot{position:absolute;top:50%;transform:translate(-50%,-50%);width:9px;height:9px;border-radius:50%;background:#f5a623;box-shadow:none;}
.pulse-updated{font-size:10px;color:var(--muted);text-align:center;margin-top:2px;}
.pulse-loading{font-size:12px;color:var(--muted);padding:12px 0;text-align:center;}

/* ── RESIZABLE DIVIDERS ── */
.resize-handle{
  width:4px;background:var(--border);cursor:col-resize;
  flex-shrink:0;position:relative;z-index:10;
  transition:background .15s;
  display:flex;align-items:center;justify-content:center;
}
.resize-handle::after{
  content:'';width:2px;height:40px;border-radius:2px;
  background:var(--border2);
  transition:background .15s;
}
.resize-handle:hover,.resize-handle.dragging{background:var(--orange-bg);}
.resize-handle:hover::after,.resize-handle.dragging::after{background:var(--orange);}
@media(max-width:900px){.resize-handle{display:none;}}

/* ═══════════════════════════════════════════════════════════
   DOT-VERSE — DESIGN SYSTEM
   Reference: instrument switcher bar aesthetic.
   Warm near-black surface. One amber accent. Zero glows.
   Clean text hierarchy. iOS/macOS precision.
   ═══════════════════════════════════════════════════════════ */

/* ── Background: warm near-black, no competing gradients ── */
body { background: #0C0A08 !important; }
body::before {
  background: radial-gradient(ellipse 80% 40% at 50% -10%, rgba(245,166,35,0.04) 0%, transparent 60%) !important;
}

/* ══ LIQUID GLASS SURFACES ═════════════════════════════════════ */
/* Main cards */
.search-panel,
.chart-card,
.levels-card,
.asset-header {
  background: rgba(255,255,255,0.055) !important;
  backdrop-filter: blur(28px) saturate(160%) !important;
  -webkit-backdrop-filter: blur(28px) saturate(160%) !important;
  border-color: rgba(255,255,255,0.11) !important;
  box-shadow:
    0 8px 32px rgba(0,0,0,0.50),
    inset 0 1px 0 rgba(255,255,255,0.13),
    inset 0 -1px 0 rgba(0,0,0,0.15) !important;
  border-radius: 16px !important;
}

/* News & Markets cards — same glass depth, own border-radius defined per class */
.macro-card,
.kpi-card,
.econ-event,
.daily-brief-box {
  backdrop-filter: blur(20px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(20px) saturate(150%) !important;
  box-shadow:
    0 4px 16px rgba(0,0,0,0.40),
    inset 0 1px 0 rgba(255,255,255,0.10) !important;
}

/* Small cards */
.ind-card, .scenario-card {
  background: rgba(255,255,255,0.048) !important;
  backdrop-filter: blur(20px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(20px) saturate(150%) !important;
  border-color: rgba(255,255,255,0.10) !important;
  box-shadow:
    0 4px 16px rgba(0,0,0,0.42),
    inset 0 1px 0 rgba(255,255,255,0.11) !important;
  border-radius: 12px !important;
}

/* Signal card — liquid glass */
.signal-card {
  background: rgba(255,255,255,0.052) !important;
  backdrop-filter: blur(28px) saturate(160%) !important;
  -webkit-backdrop-filter: blur(28px) saturate(160%) !important;
  border-radius: 16px !important;
  box-shadow:
    0 8px 32px rgba(0,0,0,0.52),
    inset 0 1px 0 rgba(255,255,255,0.13),
    inset 0 -1px 0 rgba(0,0,0,0.12) !important;
}
.signal-card.BUY {
  border-color: rgba(0,201,141,0.28) !important;
}
.signal-card.SELL {
  border-color: rgba(255,82,70,0.22) !important;
}
.signal-card.HOLD {
  border-color: rgba(255,255,255,0.10) !important;
}
/* BUY card top accent — green, matching preview */
.signal-card.BUY::before {
  background: linear-gradient(90deg, rgba(0,201,141,0.75), rgba(0,201,141,0.15)) !important;
}
/* SELL card top accent — muted red */
.signal-card.SELL::before {
  background: linear-gradient(90deg, rgba(255,82,70,0.70), rgba(255,82,70,0.15)) !important;
}
/* Signal pills — BUY green, SELL red */
.sig-pill.BUY  { background: rgba(0,201,141,0.15) !important; color: #00c98d !important; border: 1px solid rgba(0,201,141,0.32) !important; }
.sig-pill.SELL { background: rgba(255,82,70,0.13) !important; color: rgba(255,110,100,0.92) !important; border: 1px solid rgba(255,82,70,0.30) !important; }

/* Counter card */
.counter-card {
  background: rgba(255,255,255,0.042) !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
  border-radius: 16px !important;
  border-color: rgba(245,166,35,0.22) !important;
  box-shadow: 0 8px 28px rgba(0,0,0,0.5), inset 0 1px 0 rgba(245,166,35,0.10) !important;
}

/* Watch items */
.watch-item {
  background: rgba(255,255,255,0.04) !important;
  border-color: rgba(255,255,255,0.09) !important;
  border-radius: 10px !important;
  box-shadow: none !important;
}

/* Sidebars */
.sidebar-left, .sidebar-right {
  background: rgba(12,10,9,0.82) !important;
  backdrop-filter: blur(32px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(32px) saturate(150%) !important;
  border-color: rgba(255,255,255,0.09) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.07) !important;
}
.sidebar-section { border-color: rgba(255,255,255,0.07) !important; }
.panel-card      { border-color: rgba(255,255,255,0.07) !important; }

/* Header */
header {
  background: rgba(6,6,10,0.88) !important;
  backdrop-filter: blur(24px) !important;
  -webkit-backdrop-filter: blur(24px) !important;
  border-bottom-color: rgba(255,255,255,0.09) !important;
  box-shadow: 0 1px 0 rgba(255,255,255,0.06), 0 6px 28px rgba(0,0,0,0.5) !important;
}

/* Ticker tape */
.tape-wrapper {
  background: rgba(6,6,8,0.85) !important;
  border-bottom-color: rgba(255,255,255,0.07) !important;
}

/* TV panel, calc blocks */
.tv-panel {
  background: rgba(255,255,255,0.04) !important;
  border-color: rgba(255,255,255,0.09) !important;
  border-radius: 10px !important;
}
.calc-result-block, .calc-tp-row {
  background: rgba(255,255,255,0.05) !important;
  border-color: rgba(255,255,255,0.09) !important;
}

/* Instrument switch bar */
.inst-switch-bar {
  background: rgba(255,255,255,0.04) !important;
  border-color: rgba(255,255,255,0.09) !important;
}

/* Toast */
.toast {
  background: rgba(14,14,18,0.94) !important;
  border-color: rgba(245,166,35,0.22) !important;
  border-radius: 12px !important;
  backdrop-filter: blur(24px) !important;
}

/* Gate & modal */
.gate-card {
  background: rgba(10,10,14,0.92) !important;
  backdrop-filter: blur(40px) !important;
  -webkit-backdrop-filter: blur(40px) !important;
  border-color: rgba(255,255,255,0.12) !important;
  border-radius: 22px !important;
  box-shadow: 0 32px 80px rgba(0,0,0,0.85), inset 0 1px 0 rgba(255,255,255,0.10) !important;
}
#alertModal > div {
  background: rgba(10,10,14,0.92) !important;
  backdrop-filter: blur(40px) !important;
  -webkit-backdrop-filter: blur(40px) !important;
  border-color: rgba(255,255,255,0.11) !important;
  border-radius: 18px !important;
  box-shadow: 0 24px 60px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.09) !important;
}

/* ══ INPUTS ════════════════════════════════════════════════════ */
.ticker-input, .ctrl-select, .add-wl-input,
.scan-select, .risk-input, .gate-input, .inst-switch-input, .calc-pct-input {
  background: rgba(255,255,255,0.06) !important;
  border-color: rgba(255,255,255,0.12) !important;
}
.ticker-input:focus, .add-wl-input:focus, .risk-input:focus,
.inst-switch-input:focus, .calc-pct-input:focus, .scan-select:focus {
  background: rgba(255,255,255,0.08) !important;
  border-color: rgba(245,166,35,0.55) !important;
  box-shadow: 0 0 0 3px rgba(245,166,35,0.09) !important;
  outline: none;
}

/* Example chips / instrument switch chips */
.example-chip, .inst-chip {
  background: rgba(255,255,255,0.06) !important;
  border: 1px solid rgba(255,255,255,0.11) !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
}
.example-chip:hover {
  border-color: rgba(245,166,35,0.55) !important;
  color: #f5c842 !important;
  background: rgba(245,166,35,0.08) !important;
  box-shadow: 0 0 0 1px rgba(245,166,35,.22), 0 0 14px rgba(245,166,35,.18) !important;
}
.example-chip:active {
  box-shadow: 0 0 0 2px rgba(245,166,35,.45), 0 0 22px rgba(245,166,35,.28) !important;
  background: rgba(245,166,35,0.13) !important;
}
.inst-chip        { color: rgba(255,255,255,0.55) !important; }
.inst-chip:hover  { background: rgba(245,166,35,0.07) !important; border-color: rgba(245,166,35,.45) !important; color: #f5c842 !important; transform: none !important; box-shadow: 0 0 0 1px rgba(245,166,35,.2), 0 0 14px rgba(245,166,35,.18) !important; }
.inst-chip:active { background: rgba(245,166,35,0.12) !important; border-color: rgba(245,166,35,.65) !important; color: #f5c842 !important; box-shadow: 0 0 0 2px rgba(245,166,35,.4), 0 0 22px rgba(245,166,35,.28) !important; }
.inst-chip.active { background: rgba(245,166,35,0.18) !important; border-color: rgba(245,166,35,0.55) !important; color: #f5c842 !important; box-shadow: 0 0 0 1px rgba(245,166,35,.3), 0 0 12px rgba(245,166,35,.2) !important; text-shadow: none !important; }

/* ══ BUTTONS ═══════════════════════════════════════════════════ */

/* Primary amber (Analyze / Scan / Calculate / Gate Go) */
.analyze-btn,
.scan-btn,
.risk-calc-btn,
.gate-btn,
.inst-switch-go {
  background: linear-gradient(160deg, rgba(255,185,40,0.95) 0%, rgba(230,110,0,0.90) 100%) !important;
  border: 1px solid rgba(255,190,60,0.5) !important;
  box-shadow: 0 4px 18px rgba(200,120,0,0.30), inset 0 1px 0 rgba(255,235,160,0.45), inset 0 -1px 0 rgba(100,40,0,0.25) !important;
  border-radius: 11px !important;
  color: rgba(0,0,0,0.88) !important;
  text-shadow: none !important;
  transition: all 0.18s ease !important;
}
.analyze-btn:hover, .scan-btn:hover, .risk-calc-btn:hover, .gate-btn:hover, .inst-switch-go:hover {
  box-shadow: 0 6px 22px rgba(200,120,0,0.38), inset 0 1px 0 rgba(255,235,160,0.5), inset 0 -1px 0 rgba(100,40,0,0.2) !important;
  transform: translateY(-1px) !important;
}
.analyze-btn:active, .scan-btn:active, .risk-calc-btn:active {
  transform: translateY(0) !important;
  box-shadow: 0 2px 10px rgba(200,120,0,0.25), inset 0 1px 0 rgba(255,235,160,0.3), inset 0 2px 4px rgba(0,0,0,0.15) !important;
}
.analyze-btn:disabled { opacity: 0.5 !important; cursor: wait !important; transform: none !important; }

/* Secondary glass (theme toggle, add to watchlist, logout, test) */
.theme-btn, .add-wl-btn, .logout-btn, .action-btn, .ch-test-btn {
  background: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.14) !important;
  box-shadow: none !important;
  color: rgba(255,255,255,0.7) !important;
  border-radius: 9px !important;
  transition: all 0.16s ease !important;
}
.theme-btn:hover, .add-wl-btn:hover, .action-btn:hover, .ch-test-btn:hover {
  background: rgba(255,255,255,0.11) !important;
  border-color: rgba(245,166,35,0.35) !important;
  color: #f5c842 !important;
  box-shadow: none !important;
}
.logout-btn:hover {
  background: rgba(255,68,89,0.09) !important;
  border-color: rgba(255,68,89,0.38) !important;
  color: var(--red) !important;
}

/* Alert Me (primary action btn) */
.action-btn.primary {
  background: rgba(245,166,35,0.15) !important;
  border: 1px solid rgba(245,166,35,0.38) !important;
  color: var(--orange) !important;
  box-shadow: none !important;
}
.action-btn.primary:hover {
  background: rgba(245,166,35,0.22) !important;
  border-color: rgba(245,166,35,0.55) !important;
}

/* Small pill buttons (risk %, asset filter) */
.calc-pct-btn, .asset-filter-btn, .risk-auto-btn {
  background: rgba(255,255,255,0.06) !important;
  border: 1px solid rgba(255,255,255,0.12) !important;
  box-shadow: none !important;
  color: rgba(255,255,255,0.6) !important;
  transition: all 0.15s ease !important;
}
.calc-pct-btn:hover, .asset-filter-btn:hover, .risk-auto-btn:hover {
  background: rgba(255,255,255,0.10) !important;
  border-color: rgba(245,166,35,0.32) !important;
  color: #f5c842 !important;
  transform: none !important;
}
.calc-pct-btn.active, .asset-filter-btn.active, .risk-auto-btn.active {
  background: rgba(245,166,35,0.20) !important;
  border: 1px solid rgba(245,166,35,0.42) !important;
  color: #f5c842 !important;
  box-shadow: none !important;
}

/* Win rate badge */
.win-rate-badge {
  background: rgba(255,255,255,0.06) !important;
  border: 1px solid rgba(255,255,255,0.12) !important;
  box-shadow: none !important;
}
.win-rate-badge .wr-val { color: var(--orange) !important; }

/* ══ MAIN TABS ════════════════════════════════════════════════ */
.main-tabs {
  background: rgba(8,8,12,0.65) !important;
  border-bottom-color: rgba(255,255,255,0.08) !important;
  padding: 0 22px;
}
.main-tab { font-size:12.5px; font-weight:600; letter-spacing:0.4px; padding:12px 20px; border-radius: 7px !important; margin: 5px 2px !important; transition: all 0.16s ease !important; }
.main-tab:hover:not(.active) {
  background: rgba(245,166,35,0.07) !important;
  border: 1px solid rgba(245,166,35,0.32) !important;
  color: #f5c842 !important;
  box-shadow: 0 0 0 1px rgba(245,166,35,.18), 0 0 14px rgba(245,166,35,.16) !important;
  text-shadow: 0 0 10px rgba(245,166,35,.3) !important;
}
.main-tab:active:not(.active) {
  box-shadow: 0 0 0 2px rgba(245,166,35,.38), 0 0 20px rgba(245,166,35,.26) !important;
}
.main-tab.active {
  background: rgba(245,166,35,0.16) !important;
  border: 1px solid rgba(245,166,35,0.36) !important;
  border-bottom: 1px solid rgba(245,166,35,0.36) !important;
  color: #f5c842 !important;
  box-shadow: 0 0 0 1px rgba(245,166,35,.22), 0 0 12px rgba(245,166,35,.18) !important;
  text-shadow: 0 0 10px rgba(245,166,35,.28) !important;
}

/* Mobile nav */
.mnav-btn.active {
  background: rgba(245,166,35,0.14) !important;
  border-radius: 10px !important;
  box-shadow: none !important;
}

/* ══ LIQUID GLASS PILL SELECTORS ════════════════════════════ */
.glass-pill-group {
  display: flex;
  gap: 3px;
  align-items: center;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(16px) saturate(140%);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  border: 1px solid rgba(255,255,255,0.11);
  border-radius: 11px;
  padding: 4px;
  flex-wrap: wrap;
  box-shadow: 0 2px 12px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.10);
}
.gpill {
  background: transparent;
  border: none;
  color: rgba(255,255,255,0.45);
  font-size: 11px;
  font-weight: 700;
  font-family: var(--mono);
  letter-spacing: 0.3px;
  padding: 5px 10px;
  border-radius: 7px;
  cursor: pointer;
  transition: all 0.14s ease;
  white-space: nowrap;
  text-shadow: none;
}
.gpill:hover {
  color: #f5c842;
  background: rgba(245,166,35,0.08);
  border-radius: 7px;
  box-shadow: 0 0 0 1px rgba(245,166,35,.2), 0 0 12px rgba(245,166,35,.16);
  text-shadow: 0 0 8px rgba(245,166,35,.28);
}
.gpill:active {
  box-shadow: 0 0 0 2px rgba(245,166,35,.4), 0 0 18px rgba(245,166,35,.26);
}
.gpill.active {
  background: rgba(245,166,35,0.22) !important;
  border: 1px solid rgba(245,166,35,0.40) !important;
  color: #f5c842 !important;
  box-shadow: 0 0 0 1px rgba(245,166,35,.24), 0 0 10px rgba(245,166,35,.18) !important;
  text-shadow: 0 0 8px rgba(245,166,35,.25) !important;
}

/* ══ ALERT CHANNELS ══════════════════════════════════════════ */

/* Sidebar channel toggles — instrument-bar pill style */
.ch-toggle {
  display: flex !important;
  align-items: center !important;
  gap: 7px !important;
  padding: 7px 11px !important;
  background: rgba(255,255,255,0.04) !important;
  border: 1px solid rgba(255,255,255,0.09) !important;
  border-radius: 8px !important;
  font-size: 11px !important;
  font-weight: 500 !important;
  color: rgba(255,255,255,0.50) !important;
  cursor: pointer !important;
  transition: all 0.15s ease !important;
  box-shadow: none !important;
}
.ch-toggle:hover {
  background: rgba(255,255,255,0.07) !important;
  border-color: rgba(255,255,255,0.14) !important;
  color: rgba(255,255,255,0.70) !important;
}
.ch-toggle:has(input:checked) {
  background: rgba(245,166,35,0.12) !important;
  border-color: rgba(245,166,35,0.38) !important;
  color: #f5a623 !important;
  box-shadow: none !important;
}
/* Test button — small and minimal */
.ch-test-btn {
  padding: 5px 10px !important;
  font-size: 10px !important;
  letter-spacing: .4px !important;
  border-radius: 7px !important;
  white-space: nowrap !important;
}

/* Alert modal channel rows */
.am-ch-row {
  background: rgba(255,255,255,0.05) !important;
  border-color: rgba(255,255,255,0.10) !important;
  border-radius: 12px !important;
  padding: 13px 15px !important;
  position: relative;
  overflow: hidden;
  transition: all 0.16s ease !important;
}
.am-ch-row:hover {
  background: rgba(255,255,255,0.07) !important;
  border-color: rgba(245,166,35,0.24) !important;
}
/* All checked rows: amber */
.am-ch-row:has(input:checked) {
  background: rgba(245,166,35,0.10) !important;
  border-color: rgba(245,166,35,0.38) !important;
  box-shadow: none !important;
}
.am-ch-row:has(input:checked) .am-ch-tick { color: #f5c842 !important; }
.am-ch-row input[type=checkbox] { display: none; }

/* Icon wraps — neutral glass, no brand hues */
.am-ch-icon-wrap, .am-icon-sms, .am-icon-wa, .am-icon-tg {
  width: 40px; height: 40px;
  border-radius: 11px;
  display: flex; align-items: center; justify-content: center;
  font-size: 19px;
  flex-shrink: 0;
  background: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.12) !important;
  box-shadow: none !important;
}

/* Modal cancel & confirm */
.am-cancel-btn {
  flex: 1; padding: 11px; border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.7);
  font-size: 13px; font-weight: 600; cursor: pointer;
  transition: all 0.16s ease;
}
.am-cancel-btn:hover { background: rgba(255,255,255,0.10); border-color: rgba(245,166,35,0.30); color: #f5c842; }
.am-confirm-btn {
  flex: 2; padding: 11px; border-radius: 10px;
  border: 1px solid rgba(245,166,35,0.55);
