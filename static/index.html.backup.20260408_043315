          </filter>
        </defs>
        <circle cx="22" cy="22" r="20" stroke="#f5a623" stroke-width="0.6" opacity="0.18"/>
        <circle cx="22" cy="22" r="14.5" stroke="#f5a623" stroke-width="0.9" opacity="0.32"/>
        <circle cx="22" cy="22" r="9" stroke="#f5a623" stroke-width="1.2" opacity="0.55"/>
        <circle cx="22" cy="22" r="5" fill="#f5a623" opacity="0.4" filter="url(#gate-glow)"/>
