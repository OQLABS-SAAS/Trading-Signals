regBearOk = not na(pPH1_val) and not na(pPH2_val) and
            not na(rPH1_val) and not na(rPH2_val) and
            pPH1_val > pPH2_val and    // price: higher high
            rPH1_val < rPH2_val and    // RSI:   lower high
            math.abs(pPH1_idx - rPH1_idx) <= tol

// HIDDEN BULLISH: price HL, RSI LL (compare lows)
hidBullOk = not na(pPL1_val) and not na(pPL2_val) and
            not na(rPL1_val) and not na(rPL2_val) and
            pPL1_val > pPL2_val and    // price: higher low
            rPL1_val < rPL2_val and    // RSI:   lower low
            math.abs(pPL1_idx - rPL1_idx) <= tol

// HIDDEN BEARISH: price LH, RSI HH (compare highs)
hidBearOk = not na(pPH1_val) and not na(pPH2_val) and
            not na(rPH1_val) and not na(rPH2_val) and
            pPH1_val < pPH2_val and    // price: lower high
            rPH1_val > rPH2_val and    // RSI:   higher high
            math.abs(pPH1_idx - rPH1_idx) <= tol

// Strength: distance between RSI pivots (normalised)
regBullStr = regBullOk ? math.min(math.round(math.abs(rPL1_val - rPL2_val) * 2.5), 100) : 0
regBearStr = regBearOk ? math.min(math.round(math.abs(rPH1_val - rPH2_val) * 2.5), 100) : 0
hidBullStr = hidBullOk ? math.min(math.round(math.abs(rPL1_val - rPL2_val) * 2.5), 100) : 0
hidBearStr = hidBearOk ? math.min(math.round(math.abs(rPH1_val - rPH2_val) * 2.5), 100) : 0


// ===============================================================
// DRAW DIVERGENCE LINES ON RSI PANE
// Lines connect the two RSI pivot points.
// ===============================================================
var line divLine1 = na
var line divLine2 = na
var line divLine3 = na
var line divLine4 = na

if barstate.islast
    line.delete(divLine1)
    line.delete(divLine2)
    line.delete(divLine3)
    line.delete(divLine4)

    if showRegBull and regBullOk
        divLine1 := line.new(rPL2_idx, rPL2_val, rPL1_idx, rPL1_val,
            color=C_REG_BULL, width=lineWidth, style=line.style_solid,
            extend=extend.none)

    if showRegBear and regBearOk
        divLine2 := line.new(rPH2_idx, rPH2_val, rPH1_idx, rPH1_val,
            color=C_REG_BEAR, width=lineWidth, style=line.style_solid,
            extend=extend.none)

    if showHidBull and hidBullOk
        divLine3 := line.new(rPL2_idx, rPL2_val, rPL1_idx, rPL1_val,
            color=C_HID_BULL, width=lineWidth, style=line.style_dashed,
            extend=extend.none)

    if showHidBear and hidBearOk
        divLine4 := line.new(rPH2_idx, rPH2_val, rPH1_idx, rPH1_val,
            color=C_HID_BEAR, width=lineWidth, style=line.style_dashed,
            extend=extend.none)


// ===============================================================
// LABELS AT SIGNAL BAR
// ===============================================================
var label divLbl = na

if barstate.islast and showLabels
    label.delete(divLbl)

    if showRegBull and regBullOk
        divLbl := label.new(rPL1_idx, rPL1_val - 4,
            "[BUY] REG BULL DIV\nPrice LL . RSI HL\nStrength " + str.tostring(regBullStr) + "%",
            style=label.style_label_up,
            color=color.new(#f5a623, 10),
            textcolor=color.white,
            size=size.small)

    else if showRegBear and regBearOk
        divLbl := label.new(rPH1_idx, rPH1_val + 4,
            "[SELL] REG BEAR DIV\nPrice HH . RSI LH\nStrength " + str.tostring(regBearStr) + "%",
            style=label.style_label_down,
            color=color.new(#ff524a, 10),
            textcolor=color.white,
            size=size.small)

    else if showHidBull and hidBullOk
        divLbl := label.new(rPL1_idx, rPL1_val - 4,
            "[HOLD] HIDDEN BULL\nPrice HL . RSI LL\nStrength " + str.tostring(hidBullStr) + "%",
            style=label.style_label_up,
            color=color.new(#30d158, 10),
            textcolor=color.white,
            size=size.small)

    else if showHidBear and hidBearOk
        divLbl := label.new(rPH1_idx, rPH1_val + 4,
            "[BEAR] HIDDEN BEAR\nPrice LH . RSI HH\nStrength " + str.tostring(hidBearStr) + "%",
            style=label.style_label_down,
            color=color.new(#ff524a, 40),
            textcolor=color.white,
            size=size.small)


// ===============================================================
// SIGNAL SHAPES ON RSI (fire on the bar divergence is confirmed)
// ===============================================================
newRegBull = regBullOk and not regBullOk[1]
newRegBear = regBearOk and not regBearOk[1]
newHidBull = hidBullOk and not hidBullOk[1]
newHidBear = hidBearOk and not hidBearOk[1]

plotshape(showRegBull and newRegBull, title="Reg Bull Signal",
    location=location.absolute, y=rsi - 5,
    style=shape.triangleup, size=size.small,
    color=C_REG_BULL, textcolor=C_REG_BULL, text="DIV^")

plotshape(showRegBear and newRegBear, title="Reg Bear Signal",
    location=location.absolute, y=rsi + 5,
    style=shape.triangledown, size=size.small,
    color=C_REG_BEAR, textcolor=C_REG_BEAR, text="DIVv")

plotshape(showHidBull and newHidBull, title="Hid Bull Signal",
    location=location.absolute, y=rsi - 5,
    style=shape.triangleup, size=size.tiny,
    color=color.new(C_HID_BULL, 30), text="H^")

plotshape(showHidBear and newHidBear, title="Hid Bear Signal",
    location=location.absolute, y=rsi + 5,
    style=shape.triangledown, size=size.tiny,
    color=color.new(C_HID_BEAR, 30), text="Hv")


// ===============================================================
// INFO PANEL
// ===============================================================
C_HEAD = color.new(#f5a623, 88)

activeDivType =
    regBullOk ? "Regular Bullish" :
    regBearOk ? "Regular Bearish" :
    hidBullOk ? "Hidden Bullish"  :
    hidBearOk ? "Hidden Bearish"  : "None"

activeDivCol =
    regBullOk ? C_REG_BULL :
    regBearOk ? C_REG_BEAR :
    hidBullOk ? C_HID_BULL :
    hidBearOk ? C_HID_BEAR : C_MUTED

activeStr =
    regBullOk ? regBullStr :
    regBearOk ? regBearStr :
    hidBullOk ? hidBullStr :
    hidBearOk ? hidBearStr : 0

var table dash = table.new(position.top_right, columns=2, rows=14,
    bgcolor=C_BG, border_color=color.new(#ffffff, 80), border_width=1,
    frame_color=color.new(#ffffff, 60), frame_width=1)

if barstate.islast and showDash
    // Header
    table.cell(dash, 0, 0, "DotVerse",         text_color=color.new(#f5a623,0), bgcolor=C_HEAD, text_size=size.small)
    table.cell(dash, 1, 0, "RSI Divergence",   text_color=color.new(#f5a623,0), bgcolor=C_HEAD, text_size=size.small)

    // Current RSI
    rsiZone = rsi >= rsiOB ? "Overbought" : rsi <= rsiOS ? "Oversold" :
              rsi >= 55    ? "Bullish"    : rsi <= 45    ? "Bearish"  : "Neutral"
    rsiCol  = rsi >= rsiOB ? C_REG_BEAR  : rsi <= rsiOS ? C_HID_BULL :
              rsi >= 55    ? C_REG_BULL  : rsi <= 45    ? C_REG_BEAR : C_MUTED
    table.cell(dash, 0, 1, "RSI(" + str.tostring(rsiLen) + ")", text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(math.round(rsi, 1)) + "  " + rsiZone, text_color=rsiCol, text_size=size.small, text_halign=text.align_right)

    // Active divergence
    table.cell(dash, 0, 2, "Divergence",        text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, activeDivType,        text_color=activeDivCol, text_size=size.small, text_halign=text.align_right)

    // Strength
    table.cell(dash, 0, 3, "Strength",           text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 3, str.tostring(activeStr) + "%", text_color=activeDivCol, text_size=size.small, text_halign=text.align_right)

    // Pivot settings
    table.cell(dash, 0, 4, "Pivot Len",          text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(pivLen) + " bars each side", text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_right)

    // Divider
    table.cell(dash, 0, 5, "-- LEGEND -------------", text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 5, "",                   bgcolor=C_BG)

    // Legend rows
    table.cell(dash, 0, 6,  "* Reg Bullish",  text_color=C_REG_BULL, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 6,  "Price LL . RSI HL", text_color=C_MUTED,  text_size=size.tiny, text_halign=text.align_right)

    table.cell(dash, 0, 7,  "* Reg Bearish",  text_color=C_REG_BEAR, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 7,  "Price HH . RSI LH", text_color=C_MUTED,  text_size=size.tiny, text_halign=text.align_right)

    table.cell(dash, 0, 8,  "* Hid Bullish",  text_color=C_HID_BULL, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 8,  "Price HL . RSI LL", text_color=C_MUTED,  text_size=size.tiny, text_halign=text.align_right)

    table.cell(dash, 0, 9,  "* Hid Bearish",  text_color=C_HID_BEAR, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 9,  "Price LH . RSI HH", text_color=C_MUTED,  text_size=size.tiny, text_halign=text.align_right)

    // Line style legend
    table.cell(dash, 0, 10, "-- LINE STYLE ----------", text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 10, "",                  bgcolor=C_BG)

    table.cell(dash, 0, 11, "--- Solid",        text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 11, "Regular divergence", text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_right)

    table.cell(dash, 0, 12, "- - Dashed",       text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 12, "Hidden divergence", text_color=C_MUTED, text_size=size.tiny, text_halign=text.align_right)

    // Ticker
    table.cell(dash, 0, 13, syminfo.ticker,      text_color=color.new(#ffffff,50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 13, timeframe.period,    text_color=color.new(#ffffff,50), text_size=size.tiny, text_halign=text.align_right)


// ===============================================================
// ALERT CONDITIONS
// ===============================================================
alertcondition(newRegBull, title="[BUY] Regular Bullish Divergence",
    message="[BUY] REGULAR BULLISH DIVERGENCE - {{ticker}} ({{interval}})\n" +
            "Price: Lower Low . RSI: Higher Low\n" +
            "RSI: {{plot_0}}\n" +
            "Potential reversal to the upside.\n- DotVerse Signals")

alertcondition(newRegBear, title="[SELL] Regular Bearish Divergence",
    message="[SELL] REGULAR BEARISH DIVERGENCE - {{ticker}} ({{interval}})\n" +
            "Price: Higher High . RSI: Lower High\n" +
            "RSI: {{plot_0}}\n" +
            "Momentum weakening - watch for reversal down.\n- DotVerse Signals")

alertcondition(newHidBull, title="[HOLD] Hidden Bullish Divergence",
    message="[HOLD] HIDDEN BULLISH DIVERGENCE - {{ticker}} ({{interval}})\n" +
            "Price: Higher Low . RSI: Lower Low\n" +
            "RSI: {{plot_0}}\n" +
            "Bullish trend continuation - dip buy opportunity.\n- DotVerse Signals")

alertcondition(newHidBear, title="[BEAR] Hidden Bearish Divergence",
    message="[BEAR] HIDDEN BEARISH DIVERGENCE - {{ticker}} ({{interval}})\n" +
            "Price: Lower High . RSI: Higher High\n" +
            "RSI: {{plot_0}}\n" +
            "Bearish trend continuation - bounce sell opportunity.\n- DotVerse Signals")

alertcondition(newRegBull or newRegBear or newHidBull or newHidBear,
    title="Any RSI Divergence",
    message="[!] RSI DIVERGENCE - {{ticker}} ({{interval}})\nRSI: {{plot_0}}\n- DotVerse Signals")
`;
        const PINE_STRATEGY = `//@version=5
strategy("DotVerse Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.02, slippage=2, max_labels_count=500, max_lines_count=500)

// ---- INPUTS ----
emaFast  = input.int(20,    "EMA Fast",          group="EMAs")
emaMid   = input.int(50,    "EMA Mid",           group="EMAs")
emaSlow  = input.int(200,   "EMA Slow",          group="EMAs")
rsiLen   = input.int(14,    "RSI Length",        group="RSI")
rsiBuyLo = input.float(40,  "RSI Buy Min",       group="RSI")
rsiBuyHi = input.float(70,  "RSI Buy Max",       group="RSI")
rsiSlLo  = input.float(30,  "RSI Sell Min",      group="RSI")
rsiSlHi  = input.float(60,  "RSI Sell Max",      group="RSI")
stFactor = input.float(3.0, "ST Factor",         group="Supertrend")
stLen    = input.int(10,    "ST ATR Length",     group="Supertrend")
macdFast = input.int(12,    "MACD Fast",         group="MACD")
macdSlow = input.int(26,    "MACD Slow",         group="MACD")
macdSig  = input.int(9,     "MACD Signal",       group="MACD")
adxLen   = input.int(14,    "ADX Length",        group="ADX")
adxMin   = input.float(20,  "ADX Min Strength",  group="ADX")
slMult   = input.float(1.5, "SL (x ATR)",        group="Trade Management")
tp1Mult  = input.float(2.0, "TP1 50% (x ATR)",   group="Trade Management")
tp2Mult  = input.float(3.5, "TP2 25% (x ATR)",   group="Trade Management")
tp3Mult  = input.float(5.0, "TP3 25% (x ATR)",   group="Trade Management")
showDash = input.bool(true,  "Show Dashboard",   group="Display")

// ---- INDICATORS ----
e20  = ta.ema(close, emaFast)
e50  = ta.ema(close, emaMid)
e200 = ta.ema(close, emaSlow)
rsi  = ta.rsi(close, rsiLen)
atr  = ta.atr(stLen)
[macdLine, sigLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)
[supertrend, stDir]           = ta.supertrend(stFactor, stLen)
[diPlus, diMinus, adx]        = ta.dmi(adxLen, adxLen)

// ---- CONDITIONS ----
emaBull   = e20 > e50
emaBear   = e20 < e50
stBull    = stDir < 0
stBear    = stDir > 0
macdBull  = macdHist > 0 and macdHist > macdHist[1]
macdBear  = macdHist < 0 and macdHist < macdHist[1]
trendStr  = adx >= adxMin
rsiBuy    = rsi >= rsiBuyLo and rsi <= rsiBuyHi
rsiSell   = rsi >= rsiSlLo  and rsi <= rsiSlHi

buySignal  = emaBull and stBull and macdBull and trendStr and rsiBuy
sellSignal = emaBear and stBear and macdBear and trendStr and rsiSell
canBuy     = buySignal  and strategy.position_size == 0
canSell    = sellSignal and strategy.position_size == 0

// ---- TRADE STATE ----
var float entryRef = na
var float slRef    = na
var float tp1Ref   = na
var float tp2Ref   = na
var float tp3Ref   = na
var int   posPhase = 0
var int   posDir   = 0
var bool  tp1Hit   = false
var bool  tp2Hit   = false
var bool  tp3Hit   = false

// ---- ENTRIES ----
if canBuy
    strategy.entry("Long", strategy.long)
    entryRef := close
    slRef    := close - atr * slMult
    tp1Ref   := close + atr * tp1Mult
    tp2Ref   := close + atr * tp2Mult
    tp3Ref   := close + atr * tp3Mult
    posPhase := 1
    posDir   := 1
    tp1Hit   := false
    tp2Hit   := false
    tp3Hit   := false

if canSell
    strategy.entry("Short", strategy.short)
    entryRef := close
    slRef    := close + atr * slMult
    tp1Ref   := close - atr * tp1Mult
    tp2Ref   := close - atr * tp2Mult
    tp3Ref   := close - atr * tp3Mult
    posPhase := 1
    posDir   := -1
    tp1Hit   := false
    tp2Hit   := false
    tp3Hit   := false

// ---- PHASE 1: full position, original SL, 50% out at TP1 ----
if posPhase == 1
    if posDir == 1
        strategy.exit("TP1-L", from_entry="Long",  qty_percent=50, limit=tp1Ref, stop=slRef)
    if posDir == -1
        strategy.exit("TP1-S", from_entry="Short", qty_percent=50, limit=tp1Ref, stop=slRef)
    p1hit = posDir == 1 ? high >= tp1Ref : low <= tp1Ref
    if p1hit and not tp1Hit
        strategy.cancel("TP1-L")
        strategy.cancel("TP1-S")
        slRef    := entryRef
        posPhase := 2
        tp1Hit   := true

// ---- PHASE 2: 50% remains, SL at breakeven, TP2 + TP3 ----
if posPhase == 2
    if posDir == 1
        strategy.exit("TP2-L", from_entry="Long",  qty_percent=50, limit=tp2Ref, stop=entryRef)
        strategy.exit("TP3-L", from_entry="Long",  limit=tp3Ref, stop=entryRef)
    if posDir == -1
        strategy.exit("TP2-S", from_entry="Short", qty_percent=50, limit=tp2Ref, stop=entryRef)
        strategy.exit("TP3-S", from_entry="Short", limit=tp3Ref, stop=entryRef)
    if (posDir == 1 ? high >= tp2Ref : low <= tp2Ref) and not tp2Hit
        tp2Hit := true
    if (posDir == 1 ? high >= tp3Ref : low <= tp3Ref) and not tp3Hit
        tp3Hit := true

// ---- RESET WHEN FLAT ----
if strategy.position_size == 0 and posPhase != 0
    posPhase := 0
    posDir   := 0
    entryRef := na
    slRef    := na
    tp1Ref   := na
    tp2Ref   := na
    tp3Ref   := na

// ---- PLOTS ----
p20 = plot(e20,  "EMA 20",  color=color.new(#f5a623, 0),  linewidth=1)
p50 = plot(e50,  "EMA 50",  color=color.new(#f5a623, 55), linewidth=1)
plot(e200, "EMA 200", color=color.new(#ffffff, 65), linewidth=1)
fill(p20, p50, emaBull ? color.new(#f5a623, 90) : color.new(#ff524a, 92))
plot(supertrend, "Supertrend", color=stBull ? color.new(#30d158, 0) : color.new(#ff524a, 0), linewidth=2)
plotshape(canBuy,  location=location.belowbar, style=shape.triangleup,   size=size.normal, color=color.new(#f5a623, 0), text="BUY",  textcolor=color.new(#f5a623, 0))
plotshape(canSell, location=location.abovebar, style=shape.triangledown, size=size.normal, color=color.new(#ff524a, 0), text="SELL", textcolor=color.new(#ff524a, 0))
bgcolor(canBuy ? color.new(#f5a623, 88) : canSell ? color.new(#ff524a, 88) : na)

// ---- TP/SL LINES ----
var line lineE  = na
var line lineSL = na
var line lineT1 = na
var line lineT2 = na
var line lineT3 = na

if canBuy or canSell
    line.delete(lineE)
    line.delete(lineSL)
    line.delete(lineT1)
    line.delete(lineT2)
    line.delete(lineT3)
    sl = canBuy ? close - atr*slMult : close + atr*slMult
    t1 = canBuy ? close + atr*tp1Mult : close - atr*tp1Mult
    t2 = canBuy ? close + atr*tp2Mult : close - atr*tp2Mult
    t3 = canBuy ? close + atr*tp3Mult : close - atr*tp3Mult
    lineE  := line.new(bar_index, close, bar_index+50, close, color=color.new(#f5a623, 0),  width=1, style=line.style_solid)
    lineSL := line.new(bar_index, sl,    bar_index+50, sl,    color=color.new(#ff524a, 0),  width=1, style=line.style_dashed)
    lineT1 := line.new(bar_index, t1,    bar_index+50, t1,    color=color.new(#30d158, 40), width=1, style=line.style_dashed)
    lineT2 := line.new(bar_index, t2,    bar_index+50, t2,    color=color.new(#30d158, 20), width=1, style=line.style_dashed)
    lineT3 := line.new(bar_index, t3,    bar_index+50, t3,    color=color.new(#30d158, 0),  width=2, style=line.style_dashed)

// ---- LABELS ----
if canBuy
    label.new(bar_index, low - atr, "BUY | Entry: " + str.tostring(close, format.mintick) + " | SL: " + str.tostring(math.round(close - atr*slMult, 4)) + " | TP1: " + str.tostring(math.round(close + atr*tp1Mult, 4)), style=label.style_label_up,   color=color.new(#f5a623, 8), textcolor=color.white, size=size.small)
if canSell
    label.new(bar_index, high + atr, "SELL | Entry: " + str.tostring(close, format.mintick) + " | SL: " + str.tostring(math.round(close + atr*slMult, 4)) + " | TP1: " + str.tostring(math.round(close - atr*tp1Mult, 4)), style=label.style_label_down, color=color.new(#ff524a, 8), textcolor=color.white, size=size.small)
if tp1Hit and not tp1Hit[1]
    label.new(bar_index, tp1Ref, "TP1 hit | SL -> BE", style=label.style_label_down, color=color.new(#30d158, 10), textcolor=color.white, size=size.tiny)
if tp2Hit and not tp2Hit[1]
    label.new(bar_index, tp2Ref, "TP2 hit | 25% closed", style=label.style_label_down, color=color.new(#30d158, 10), textcolor=color.white, size=size.tiny)
if tp3Hit and not tp3Hit[1]
    label.new(bar_index, tp3Ref, "TP3 hit | Full exit", style=label.style_label_down, color=color.new(#30d158, 5), textcolor=color.white, size=size.tiny)

// ---- DASHBOARD ----
C_BG    = color.new(#0d1117, 10)
C_AMBER = color.new(#f5a623, 0)
C_GREEN = color.new(#30d158, 0)
C_RED   = color.new(#ff524a, 0)
C_MUTED = color.new(#ffffff, 55)

var table dash = table.new(position.top_right, 3, 12, bgcolor=C_BG, border_color=color.new(#ffffff, 80), border_width=1)

if barstate.islast and showDash
    table.cell(dash, 0, 0, "DotVerse",  text_color=C_AMBER, bgcolor=color.new(#f5a623, 88), text_size=size.small)
    table.cell(dash, 1, 0, "STRATEGY",  text_color=C_AMBER, bgcolor=color.new(#f5a623, 88), text_size=size.small)
    table.cell(dash, 2, 0, syminfo.ticker, text_color=color.new(#ffffff, 60), bgcolor=color.new(#f5a623, 88), text_size=size.tiny)
    posLabel = posPhase == 0 ? "FLAT" : posDir == 1 ? "LONG" : "SHORT"
    posCol   = posPhase == 0 ? C_MUTED : posDir == 1 ? C_AMBER : C_RED
