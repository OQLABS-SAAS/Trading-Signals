      <div><div class="wl-symbol">${w.ticker}</div><div class="wl-type">${w.asset_type}</div></div>
      <button onclick="event.stopPropagation();removeFromWatchlist(${i})"
        style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px;padding:2px 4px;">✕</button>
    </div>`
  ).join('');
}
function addToWatchlist() {
  const t = document.getElementById('wlInput').value.trim().toUpperCase();
  const a = document.getElementById('wlAssetType').value;
  if (!t) return;
  if (watchlist.find(w => w.ticker===t && w.asset_type===a)) { showToast(`${t} already in watchlist`); return; }
  watchlist.push({ticker:t, asset_type:a});
  localStorage.setItem('wl', JSON.stringify(watchlist));
  document.getElementById('wlInput').value = '';
  renderWatchlist();
  showToast(`Added ${t}`);
}
function removeFromWatchlist(i) {
  watchlist.splice(i,1);
  localStorage.setItem('wl', JSON.stringify(watchlist));
  renderWatchlist();
}

