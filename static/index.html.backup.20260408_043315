// Stores {x, y, type, payload} for every drawn interactive element
let _priceHits = [];
let _rsiHits   = [];

const _tooltipEl = (() => {
  const el = document.createElement('div');
  el.id = 'chartTooltip';
  document.body.appendChild(el);
  return el;
})();

function _showTooltip(e, html, accentClass) {
  _tooltipEl.innerHTML = html;
  // Border colour per signal type
  const colors = {
    buy:      'rgba(245,166,35,.35)',
    sell:     'rgba(255,82,74,.35)',
    'div-bull':'rgba(0,201,141,.35)',
    'div-bear':'rgba(255,82,74,.35)',
  };
  _tooltipEl.style.borderColor = colors[accentClass] || 'rgba(255,255,255,.13)';
  // Position: follow cursor, keep inside viewport
  const W = window.innerWidth, H = window.innerHeight;
  const tw = 240, th = 130;
  let lx = e.clientX + 14, ly = e.clientY - 14;
  if (lx + tw > W - 10) lx = e.clientX - tw - 14;
  if (ly + th > H - 10) ly = e.clientY - th - 14;
  _tooltipEl.style.left = lx + 'px';
  _tooltipEl.style.top  = ly + 'px';
  _tooltipEl.classList.add('visible');
}

function _hideTooltip() {
  _tooltipEl.classList.remove('visible');
}

function _buildBuyTip(price) {
  const fp = price ? ` @ <b>${fmt(price)}</b>` : '';
  return `<div class="ct-badge buy">▲ Buy Signal</div>
<div class="ct-title">RSI Oversold Crossover</div>
<div class="ct-body">RSI dropped below 40${fp} — selling pressure is exhausting. This bar marks a potential reversal point where buyers may step in.</div>
<div class="ct-action buy">💡 Consider long entry — confirm with price action &amp; volume</div>`;
}

function _buildSellTip(price) {
  const fp = price ? ` @ <b>${fmt(price)}</b>` : '';
  return `<div class="ct-badge sell">▼ Sell Signal</div>
<div class="ct-title">RSI Overbought Crossover</div>
<div class="ct-body">RSI crossed above 60${fp} — momentum is overheating. Bears may push back from this level; reward/risk is narrowing for longs.</div>
<div class="ct-action sell">💡 Tighten stop or take partial profit near this bar</div>`;
}

function _buildDivTip(div, isRsiChart) {
  const isBull   = div.isBull;
  const label    = div.label || (isBull ? 'Bullish Divergence' : 'Bearish Divergence');
  const badge    = isBull ? 'div-bull' : 'div-bear';
  const icon     = isBull ? '〰 ▲' : '〰 ▼';
  // Use backend-generated description if available, else fallback
  const body     = div.desc
    || (isBull
      ? 'Price made a lower low but RSI made a higher low — selling momentum is fading. A reversal higher is possible.'
      : 'Price made a higher high but RSI made a lower high — buying momentum is weakening. Watch for a pullback.');
  const action   = isBull
    ? '💡 Potential reversal up — wait for a bullish close to confirm'
    : '💡 Potential reversal down — consider reducing long exposure';
  // Strength bar
  const pct      = Math.min(100, Math.max(0, div.strength || 0));
  const sColor   = isBull ? '#00c98d' : '#ff524a';
  const strengthBar = pct > 0
    ? `<div style="margin-top:7px;"><div style="display:flex;align-items:center;justify-content:space-between;font-size:9.5px;color:rgba(255,255,255,.38);margin-bottom:3px;"><span>Signal Strength</span><span style="color:${sColor};font-weight:700;">${pct}%</span></div><div style="height:3px;border-radius:2px;background:rgba(255,255,255,.08);"><div style="width:${pct}%;height:100%;border-radius:2px;background:${sColor};"></div></div></div>`
    : '';
  return `<div class="ct-badge ${badge}">${icon} ${label}</div>
<div class="ct-title">${isRsiChart ? 'RSI Sub-Chart' : 'Price Chart'} Divergence</div>
<div class="ct-body">${body}</div>
${strengthBar}
<div class="ct-action div">${action}</div>`;
}

function _hitRadius(canvas) {
  // Slightly larger on mobile / touch screens
  return window.matchMedia('(max-width:600px)').matches ? 18 : 13;
}

function _attachChartHover(canvasId, getHits, isDivOnly) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;

  canvas.addEventListener('mousemove', e => {
    const hits = getHits();
    const rect = canvas.getBoundingClientRect();
    const mx   = e.clientX - rect.left;
    const my   = e.clientY - rect.top;
    const r    = _hitRadius(canvas);

    // For the RSI chart: if divergence exists and cursor is horizontally
    // between the two pivot bars, treat the entire band as a hit zone.
    // This makes divergence much easier to hover without pixel-perfect targeting.
    if (isDivOnly && chartDivergence && hits.length >= 2) {
      const xs  = hits.map(h => h.x);
      const xMin = Math.min(...xs) - 20;
      const xMax = Math.max(...xs) + 20;
      if (mx >= xMin && mx <= xMax) {
        const div = hits[0].div;
        const html = _buildDivTip(div, true);
        const cls  = div.isBull ? 'div-bull' : 'div-bear';
        _showTooltip(e, html, cls);
        canvas.style.cursor = 'pointer';
        return;
      }
    }

    for (const h of hits) {
      // Divergence dots: larger hit radius so easier to target
      const hitR = h.type === 'div' ? r * 1.8 : r;
      const dx = mx - h.x, dy = my - h.y;
      if (dx*dx + dy*dy <= hitR*hitR) {
        let html, cls;
        if      (h.type === 'buy')  { html = _buildBuyTip(h.price);          cls = 'buy'; }
        else if (h.type === 'sell') { html = _buildSellTip(h.price);         cls = 'sell'; }
        else if (h.type === 'div')  { html = _buildDivTip(h.div, isDivOnly); cls = h.div.isBull ? 'div-bull' : 'div-bear'; }
        else continue;
        _showTooltip(e, html, cls);
        canvas.style.cursor = 'pointer';
        return;
      }
    }
    _hideTooltip();
    canvas.style.cursor = 'crosshair';
  });

  canvas.addEventListener('mouseleave', () => { _hideTooltip(); canvas.style.cursor = ''; });
}

// Pass getter functions so closures always read the live arrays
_attachChartHover('priceChart', () => _priceHits, false);
_attachChartHover('rsiChart',   () => _rsiHits,   true);

