function seRenderFootprint(fp) {
  if (!fp) return;
  const panel = document.getElementById('seFootprintPanel');
  if (!panel) return;
  panel.style.display = 'block';

  // Declare noVol first — used throughout this function
  const noVol = fp.volume_available === false;

  // Delta badge
  const badge = document.getElementById('fpDeltaBadge');
  if (badge) {
    const trend = fp.delta_trend || 'MIXED';
    badge.textContent = trend === 'BUYING' ? '▲ BUYING' : trend === 'SELLING' ? '▼ SELLING' : '— MIXED';
    badge.className = 'fp-header-badge ' + (trend === 'BUYING' ? 'fp-badge-buy' : trend === 'SELLING' ? 'fp-badge-sell' : 'fp-badge-mixed');
  }

  // Buy/sell bar — label changes to "Price Action Pressure" when no tick volume
  const buyPct  = fp.buy_pct ?? 50;
  const sellPct = Math.round(100 - buyPct);
  const bpEl = document.getElementById('fpBuyPct');   if (bpEl) bpEl.textContent = noVol ? buyPct + '% BULL pressure' : buyPct + '% BUY';
  const spEl = document.getElementById('fpSellPct');  if (spEl) spEl.textContent = noVol ? sellPct + '% BEAR pressure' : sellPct + '% SELL';
  const fill = document.getElementById('fpVolFill');  if (fill) fill.style.width = buyPct + '%';

  // ── Helpers
  const setText = (id, val, cls) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = val;
    if (cls) el.className = 'fp-stat-val ' + cls;
  };
  const setLabel = (rowId, label) => {
    const row = document.getElementById(rowId);
    if (!row) return;
    const lbl = row.querySelector('.fp-stat-label');
    if (lbl) lbl.textContent = label;
    row.style.display = '';   // always keep visible
  };

  if (noVol) {
    // ── No tick volume (forex, indices from some sources)
    // All rows stay visible — values derived from candle geometry instead of contracts
    const lw = fp.lower_wick_pct ?? 0;
    const uw = fp.upper_wick_pct ?? 0;

    setLabel('fpRowBuyVol',    'BUYERS (price action) ~');
    setLabel('fpRowSellVol',   'SELLERS (price action) ~');
    setLabel('fpRowPoserBuy',  'POSER BUYERS (lower wick) ~');
    setLabel('fpRowPoserSell', 'POSER SELLERS (upper wick) ~');
    setLabel('fpRowVolRatio',  'VOL vs AVG');
    setLabel('fpRowDelta',     'NET DELTA');

    // True buyers/sellers: share of candle range each side captured
    setText('fpBuyVol',  buyPct  + '% of candle range captured', buyPct  >= 50 ? 'green' : 'muted');
    setText('fpSellVol', sellPct + '% of candle range captured', sellPct >= 50 ? 'red'   : 'muted');

    // Poser buyers = lower wick (buyers who pushed price down, then snapped it back)
    const poserBuyPresent  = lw >= 20;
    setText('fpPoserBuy',
      poserBuyPresent
        ? lw + '% lower wick — possible hidden buyers'
        : lw + '% lower wick (minimal)',
      poserBuyPresent ? 'amber' : 'muted');

    // Poser sellers = upper wick (sellers who pushed price up, then dumped it back)
    const poserSellPresent = uw >= 20;
    setText('fpPoserSell',
      poserSellPresent
        ? uw + '% upper wick — possible hidden sellers'
        : uw + '% upper wick (minimal)',
      poserSellPresent ? 'amber' : 'muted');

    // Delta — price action estimate
    const dv = fp.delta ?? 0;
    setText('fpDelta',
      (dv >= 0 ? '+' : '') + dv.toFixed(4) + ' (price action est.)',
      dv >= 0 ? 'green' : 'red');

    // Vol ratio not meaningful without tick data
    setText('fpVolRatio', 'N/A — tick volume unavailable', 'muted');

  } else {
    // ── Tick volume available — restore original labels and show contract counts
    setLabel('fpRowBuyVol',    'TRUE BUYERS ~');
    setLabel('fpRowSellVol',   'TRUE SELLERS ~');
    setLabel('fpRowPoserBuy',  'POSER BUYERS ~');
    setLabel('fpRowPoserSell', 'POSER SELLERS ~');
    setLabel('fpRowVolRatio',  'VOL vs AVG');
    setLabel('fpRowDelta',     'NET DELTA');

    setText('fpBuyVol',   fmtVol(fp.est_buy_vol)   + ' contracts', 'green');
    setText('fpSellVol',  fmtVol(fp.est_sell_vol)  + ' contracts', 'red');
    setText('fpPoserBuy', fmtVol(fp.est_poser_buy)  + ' (lower wick)', fp.hidden_buyers  ? 'amber' : '');
    setText('fpPoserSell',fmtVol(fp.est_poser_sell) + ' (upper wick)', fp.hidden_sellers ? 'amber' : '');

    const dv = fp.delta ?? 0;
    setText('fpDelta', (dv >= 0 ? '+' : '') + fmtVol(dv), dv >= 0 ? 'green' : 'red');

    const vr = fp.vol_ratio ?? 1;
    setText('fpVolRatio', vr + '× avg', vr >= 1.5 ? 'green' : vr < 0.7 ? 'red' : 'amber');
  }

  // ── Source note
  const noteId = 'fpNoVolNote';
  let noteEl = document.getElementById(noteId);
  if (noVol) {
    if (!noteEl) {
      noteEl = document.createElement('div');
      noteEl.id = noteId;
      noteEl.style.cssText = 'font-size:9.5px;color:var(--muted);font-style:italic;margin-top:6px;padding:4px 6px;background:rgba(255,255,255,.03);border-radius:3px;border-left:2px solid rgba(255,255,255,.1);';
      panel.appendChild(noteEl);
    }
    noteEl.textContent = 'ℹ Source: price action — tick volume not available for this instrument. Buyer/seller presence is estimated from candle close position and wick lengths.';
    noteEl.style.display = 'block';
  } else if (noteEl) {
    noteEl.style.display = 'none';
  }

  // Candle anatomy bars
  const uw = fp.upper_wick_pct ?? 0;
  const bw = fp.body_pct       ?? 0;
  const lw = fp.lower_wick_pct ?? 0;
  const ub = document.getElementById('fpUpperBar'); if (ub) { ub.style.width = Math.min(uw,100) + '%'; }
  const bb = document.getElementById('fpBodyBar');  if (bb) { bb.style.width = Math.min(bw,100) + '%'; }
  const lb = document.getElementById('fpLowerBar'); if (lb) { lb.style.width = Math.min(lw,100) + '%'; }
  const upEl = document.getElementById('fpUpperPct'); if (upEl) upEl.textContent = uw + '%';
  const bpEl2 = document.getElementById('fpBodyPct'); if (bpEl2) bpEl2.textContent = bw + '%';
  const lwEl = document.getElementById('fpLowerPct'); if (lwEl) lwEl.textContent = lw + '%';

  // Candle viz proportional heights (total = 60px)
  const total = uw + bw + lw || 1;
  const wt = document.getElementById('fpWickTop'); if (wt) wt.style.height = Math.max(2, uw/total*60) + 'px';
  const cb = document.getElementById('fpCandleBody');
  if (cb) {
    cb.style.height = Math.max(4, bw/total*60) + 'px';
    cb.style.background = fp.delta >= 0 ? '#00c98d' : '#ff4459';
  }
  const wb = document.getElementById('fpWickBot'); if (wb) wb.style.height = Math.max(2, lw/total*60) + 'px';

  // Detected signal pills
  const pills = [];
  if (fp.hidden_buyers)  pills.push({ cls:'green', icon:'🟢', text:'Hidden Buyers — lower wick absorption on volume' });
  if (fp.hidden_sellers) pills.push({ cls:'red',   icon:'🔴', text:'Hidden Sellers — upper wick absorption on volume' });
  if (fp.absorption)     pills.push({ cls:'amber', icon:'⚡', text:'Absorption candle — coiling before explosive move' });
  if (fp.pos_divergence) pills.push({ cls:'green', icon:'📈', text:'Delta divergence — price ↓ but money flowing IN' });
  if (fp.neg_divergence) pills.push({ cls:'red',   icon:'📉', text:'Delta divergence — price ↑ but money flowing OUT' });
  if (!pills.length)     pills.push({ cls:'muted', icon:'·',  text:'No special footprint signals on current candle' });
  const sigEl = document.getElementById('fpSignals');
  if (sigEl) sigEl.innerHTML = pills.map(p =>
    `<div class="fp-signal-pill ${p.cls}"><span>${p.icon}</span><span>${p.text}</span></div>`
  ).join('');

  // CVD
  const cvdEl = document.getElementById('fpCVD');
  if (cvdEl) {
    const cvd = fp.cvd ?? 0;
    cvdEl.textContent = (cvd >= 0 ? '+' : '') + fmtVol(cvd);
    cvdEl.style.color = cvd >= 0 ? '#00c98d' : '#ff4459';
  }
}

// ═══════════════════════════════════════════════════════════
//  ORDER FLOW PANEL RENDERER
// ═══════════════════════════════════════════════════════════
function seRenderOrderFlow(of) {
  if (!of) return;
  const panel = document.getElementById('seOrderFlowPanel');
  if (!panel) return;
  panel.style.display = 'block';

  // Quality badge
  const qb = document.getElementById('ofQualityBadge');
  if (qb) {
    const q = of.vol_quality || 'NORMAL';
    qb.textContent = q + (of.vol_expanding ? ' ↑' : of.vol_contracting ? ' ↓' : '');
    qb.className = 'fp-header-badge ' + (q === 'HIGH' ? 'fp-badge-buy' : q === 'LOW' ? 'fp-badge-sell' : 'fp-badge-mixed');
  }

  // VPoC
  const vpEl = document.getElementById('ofVpoc');
  if (vpEl) vpEl.textContent = of.vpoc ? fmtP(of.vpoc) : 'N/A';
  const vdEl = document.getElementById('ofVpocDir');
  if (vdEl) {
    const dir = of.price_vs_vpoc || 'UNKNOWN';
    vdEl.textContent = dir === 'ABOVE' ? 'ABOVE VPoC ↑' : dir === 'BELOW' ? 'BELOW VPoC ↓' : '—';
    vdEl.style.color = dir === 'ABOVE' ? '#00c98d' : dir === 'BELOW' ? '#ff4459' : '#7a90b0';
    vdEl.style.background = dir === 'ABOVE' ? 'rgba(0,201,141,.12)' : dir === 'BELOW' ? 'rgba(255,68,89,.12)' : 'rgba(122,144,176,.12)';
  }

  // Stack dots
  const renderDots = (containerId, countId, n, total, onCls, offCls) => {
    const el = document.getElementById(containerId);
    if (el) el.innerHTML = Array.from({length: total}, (_, i) =>
      `<div class="of-dot ${i < n ? onCls : offCls}"></div>`
    ).join('');
    const cnt = document.getElementById(countId);
    if (cnt) cnt.textContent = n + ' of ' + total + ' candles';
  };
  renderDots('ofBullDots', 'ofBullCount', of.bull_stack || 0, 5, 'bull-on', 'bull-off');
  renderDots('ofBearDots', 'ofBearCount', of.bear_stack || 0, 5, 'bear-on', 'bear-off');

  // Liquidity pools
  const lhEl = document.getElementById('ofLiqHigh'); if (lhEl) lhEl.textContent = fmtP(of.liq_pool_high);
  const llEl = document.getElementById('ofLiqLow');  if (llEl) llEl.textContent = fmtP(of.liq_pool_low);
  const lhnEl = document.getElementById('ofLiqHighNear'); if (lhnEl) lhnEl.style.display = of.near_liq_high ? 'inline' : 'none';
  const llnEl = document.getElementById('ofLiqLowNear');  if (llnEl) llnEl.style.display = of.near_liq_low  ? 'inline' : 'none';

  // Volume quality tags
  const tags = [];
  tags.push({ text: 'Vol: ' + (of.vol_quality||'?'), ok: of.vol_quality === 'HIGH' });
  if (of.vol_expanding)   tags.push({ text: 'Expanding ↑',  ok: true  });
  if (of.vol_contracting) tags.push({ text: 'Contracting ↓', ok: false });
  if (of.stacked_bull)    tags.push({ text: '●●● Bull Stack', ok: true  });
  if (of.stacked_bear)    tags.push({ text: '●●● Bear Stack', ok: false });
  if (of.near_liq_high)   tags.push({ text: '⚠ At HIGH pool', ok: null });
  if (of.near_liq_low)    tags.push({ text: '⚠ At LOW pool',  ok: null });
  const tagsEl = document.getElementById('ofVolTags');
  if (tagsEl) tagsEl.innerHTML = tags.map(t =>
    `<span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;
      background:${t.ok === true ? 'rgba(0,201,141,.12)' : t.ok === false ? 'rgba(255,68,89,.12)' : 'rgba(245,166,35,.12)'};
      color:${t.ok === true ? '#00c98d' : t.ok === false ? '#ff4459' : '#f5a623'};
      border:1px solid ${t.ok === true ? 'rgba(0,201,141,.25)' : t.ok === false ? 'rgba(255,68,89,.25)' : 'rgba(245,166,35,.25)'};"
    >${t.text}</span>`
  ).join('');
}

// ═══════════════════════════════════════════════════════════
//  MAIN RESULT RENDERER
// ═══════════════════════════════════════════════════════════
function seRenderResult(d) {
  // ── Verdict badge
  const badge = document.getElementById('seVerdictBadge');
  if (badge) {
    badge.textContent = d.verdict;
    badge.style.background = d.go_long  ? 'rgba(34,197,94,.18)'  :
                             d.go_short ? 'rgba(239,68,68,.18)'  : 'rgba(122,144,176,.12)';
    badge.style.color      = d.go_long  ? '#22C55E' :
                             d.go_short ? '#EF4444' : '#7a90b0';
  }

  // ── Plain English summary (beginner view)
  const plainEl = document.getElementById('sePlainSummary');
  if (plainEl) {
    plainEl.innerHTML = buildPlainSummary(d);
    plainEl.style.display = 'block';
  }
  const toggleBtn = document.getElementById('seDetailsToggle');
  if (toggleBtn) toggleBtn.style.display = 'block';

  // ── Engine gate rows (hidden by default — revealed via toggle)
  const eng = d.engine || {};
  const rows = [
    { label:'MTF Trend',    val: eng.mtf_bull ? 'BULL ▲' : eng.mtf_bear ? 'BEAR ▼' : 'MIXED', ok: eng.mtf_bull || eng.mtf_bear },
    { label:'ADX Strength', val: eng.adx + (eng.trend_strong ? ' ✓' : ' ✗'),                  ok: eng.trend_strong },
    { label:'RSI',          val: String(eng.rsi),                                               ok: eng.rsi_ok_long || eng.rsi_ok_short },
    { label:'Volume',       val: eng.vol_spike ? 'SPIKE ✓ (' + eng.vol_ratio + '×)' : eng.vol_ratio + '× avg', ok: eng.vol_spike },
    { label:'Gate LONG',    val: eng.gate_long  ? 'OPEN ✓' : 'CLOSED ✗', ok: eng.gate_long  },
    { label:'Gate SHORT',   val: eng.gate_short ? 'OPEN ✓' : 'CLOSED ✗', ok: eng.gate_short },
  ];
  const gateRows = document.getElementById('seGateRows');
  if (gateRows) gateRows.innerHTML = rows.map(r =>
    `<div class="se-gate-row">
      <span class="se-gate-label">${r.label}</span>
      <span class="se-gate-val ${r.ok ? 'se-gate-ok' : 'se-gate-fail'}">${r.val}</span>
    </div>`
  ).join('');
  // Keep gate panel hidden — user opens it via toggle
  document.getElementById('seGateStatus').style.display = 'none';

  // ── Footprint + OrderFlow panels (hidden by default)
  seRenderFootprint(d.footprint);
  seRenderOrderFlow(d.orderflow);
  // Keep these hidden — toggle reveals them
  const fpEl = document.getElementById('seFootprintPanel');
  const ofEl = document.getElementById('seOrderFlowPanel');
  if (fpEl) fpEl.style.display = 'none';
  if (ofEl) ofEl.style.display = 'none';

  // ── Signal cards with confidence + fp/of alignment
  const signals = d.signals || [];
  if (signals.length > 0) {
    const cards = signals.map(s => {
      const dirClass = s.direction === 'LONG' ? 'LONG' : 'SHORT';
      const icon     = s.direction === 'LONG'  ? '▲' : '▼';
      const conf     = s.confidence ?? 0;
      const confCls  = conf >= 70 ? 'high' : conf >= 45 ? 'mid' : 'low';

      // Alignment pills
      const pills = [];
      if (s.fp_boost)   pills.push({ cls:'fp-ok',   text:'FP ↑ Hidden momentum' });
      if (s.fp_aligned && !s.fp_boost) pills.push({ cls:'fp-ok', text:'FP aligned' });
      if (s.fp_warning) pills.push({ cls:'fp-warn', text:'⚠ FP counter-signal' });
      if (s.of_aligned) pills.push({ cls:'of-ok',   text:'OF aligned' });
      if (s.liq_sweep)  pills.push({ cls:'liq',     text:'At liq pool' });

      return `<div class="se-signal-card">
        <div class="se-signal-dir ${dirClass}">${icon} ${s.strategy} — ${s.direction}</div>
        <div class="se-signal-row"><span>Entry</span><span class="se-signal-val">${fmtP(s.entry)}</span></div>
        <div class="se-signal-row"><span>Stop Loss</span><span class="se-signal-val" style="color:#EF4444">${fmtP(s.sl)}</span></div>
        <div class="se-signal-row"><span>Take Profit</span><span class="se-signal-val" style="color:#22C55E">${fmtP(s.tp)}</span></div>
        <div class="se-signal-row"><span>R:R</span><span class="se-signal-val" style="color:#F59E0B">1 : ${s.rr}</span></div>
        ${s.pos_size != null ? `<div class="se-signal-row"><span>Position Size</span><span class="se-signal-val">${fmtP(s.pos_size)}</span></div>` : ''}
        ${s.risk_amt != null ? `<div class="se-signal-row"><span>Risk / Reward</span><span class="se-signal-val">$${s.risk_amt} / $${s.reward_amt}</span></div>` : ''}
        <div class="se-conf-wrap">
          <div class="se-conf-label"><span>CONFIDENCE</span><span>${conf}/100</span></div>
          <div class="se-conf-track"><div class="se-conf-fill ${confCls}" style="width:${conf}%"></div></div>
        </div>
        ${pills.length ? `<div class="se-align-pills">${pills.map(p=>`<span class="se-align-pill se-pill-${p.cls}">${p.text}</span>`).join('')}</div>` : ''}
        <div style="font-size:9.5px;color:var(--text2);margin-top:4px;font-style:italic;">${s.note || ''}</div>
      </div>`;
    }).join('');
    document.getElementById('seSignalCards').innerHTML = cards;
    document.getElementById('seResults').style.display = 'block';
    document.getElementById('sePineBtn').style.display = 'block';
  }

  // ── No-go reasons — now handled in plain English inside buildPlainSummary.
  // The raw technical block is kept hidden to keep the UI beginner-friendly.
  // Power users can see the reason checklist by clicking "Show technical details".
}

function seShowError(msg) {
  const badge = document.getElementById('seVerdictBadge');
  if (badge) { badge.textContent = 'ERROR'; badge.style.background = 'rgba(239,68,68,.18)'; badge.style.color = '#EF4444'; }
  const noGo = document.getElementById('seNoGo');
  noGo.innerHTML = msg;
  noGo.style.display = 'block';
}

// ═══════════════════════════════════════════════════════════
//  PLAIN ENGLISH HELPERS
// ═══════════════════════════════════════════════════════════
function seToggleDetails() {
  const panels = ['seGateStatus','seFootprintPanel','seOrderFlowPanel'];
  const btn    = document.getElementById('seDetailsToggle');
  const first  = document.getElementById(panels[0]);
  const open   = first && first.style.display !== 'none';
  panels.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = open ? 'none' : 'block';
  });
  if (btn) btn.textContent = open ? 'Show technical details ▼' : 'Hide technical details ▲';
}

function buildPlainSummary(d) {
  const eng     = d.engine     || {};
  const fp      = d.footprint  || {};
  const signals = d.signals    || [];
  const reasons = d.reasons_blocked || [];

  // ── Verdict headline
  let headline = '', headColor = '#7a90b0';
  if (d.go_long) {
    headline  = '✅ Conditions look good — potential BUY opportunity';
    headColor = '#22C55E';
  } else if (d.go_short) {
    headline  = '🔴 Conditions lean bearish — potential SELL / Short opportunity';
    headColor = '#EF4444';
  } else {
    headline  = '⏳ Not the right time — better to wait';
    headColor = '#F59E0B';
  }

  // ── Checklist rows
  const trendDir   = eng.mtf_bull ? 'Market is trending UP' : eng.mtf_bear ? 'Market is trending DOWN' : 'Market direction is unclear (mixed signals)';
  const trendOk    = eng.mtf_bull || eng.mtf_bear;
  const strengthOk = eng.trend_strong;
  const strengthTxt = strengthOk
    ? `Trend is strong enough to trade (ADX ${eng.adx})`
    : `Trend is too weak right now (ADX ${eng.adx} — needs to be higher)`;
  const volOk  = eng.vol_spike;
  const volTxt = volOk
    ? `Good trading activity — volume is ${eng.vol_ratio}× the normal level`
    : `Trading activity is quiet — volume is only ${eng.vol_ratio}× normal (low interest)`;
  const rsi    = eng.rsi;
  const rsiOk  = eng.rsi_ok_long || eng.rsi_ok_short;
  let rsiTxt = '';
  if (rsi >= 70)      rsiTxt = `Market may be overbought (RSI ${rsi}) — could be due for a pullback`;
  else if (rsi <= 30) rsiTxt = `Market may be oversold (RSI ${rsi}) — could be due for a bounce`;
  else                rsiTxt = `RSI is in a healthy zone (${rsi}) — not overheated`;

  const checks = [
    { ok: trendOk,    text: trendDir },
    { ok: strengthOk, text: strengthTxt },
    { ok: volOk,      text: volTxt },
    { ok: rsiOk,      text: rsiTxt },
  ];
  const checklistHtml = checks.map(c =>
    `<div style="display:flex;gap:8px;align-items:flex-start;margin:4px 0;font-size:11px;color:var(--text2);">
      <span style="min-width:16px;color:${c.ok ? '#22C55E' : '#EF4444'}">${c.ok ? '✅' : '❌'}</span>
      <span>${c.text}</span>
    </div>`
  ).join('');

  // ── Momentum block (always shown)
  const deltaT    = fp.delta_trend || 'MIXED';
  const buyPct    = fp.buy_pct ?? 50;
  const sellPct   = Math.round(100 - buyPct);
  const momBull   = deltaT === 'BUYING'  || eng.mtf_bull;
  const momBear   = deltaT === 'SELLING' || eng.mtf_bear;
  const momIcon   = momBull ? '🟢' : momBear ? '🔴' : '🟡';
  const momColor  = momBull ? '#22C55E' : momBear ? '#EF4444' : '#F59E0B';

  let momDesc = '';
  if (deltaT === 'BUYING')       momDesc = `Buying pressure is dominant — ${buyPct}% of recent price action favors buyers`;
  else if (deltaT === 'SELLING') momDesc = `Selling pressure is building — ${sellPct}% of recent price action favors sellers`;
  else                           momDesc = `Momentum is mixed — buyers at ${buyPct}% vs sellers at ${sellPct}% (no clear winner yet)`;

  const adxDesc = eng.trend_strong
    ? `Trend force is STRONG (ADX ${eng.adx}) — momentum has conviction`
    : `Trend force is WEAK (ADX ${eng.adx}) — momentum could reverse easily`;

  const momentumHtml = `
    <div style="margin-top:10px;padding:8px 10px;background:rgba(255,255,255,.03);border-left:2px solid ${momColor};border-radius:4px;">
      <div style="font-size:10px;font-weight:600;color:${momColor};letter-spacing:.5px;margin-bottom:6px;">MOMENTUM</div>
      <div style="font-size:11px;color:var(--text2);margin:3px 0;">${momIcon} ${momDesc}</div>
      <div style="font-size:11px;color:var(--text2);margin:3px 0;">📊 ${adxDesc}</div>
    </div>`;

  // ── Price levels helper (used in both GO and WAIT cases)
  function levelsHtml(sig, label, labelColor, isConfirmed) {
    const noteText = isConfirmed
      ? '⚠ This is for educational purposes only. Always manage your own risk.'
      : '⏳ These levels are not yet confirmed — only enter if all checklist conditions turn green.';
    const bgAlpha   = isConfirmed ? '.06' : '.04';
    const bgColor   = isConfirmed ? (d.go_long ? '34,197,94' : '239,68,68') : '122,144,176';
    return `
      <div style="margin-top:10px;padding:8px 10px;background:rgba(${bgColor},${bgAlpha});border-left:2px solid ${labelColor};border-radius:4px;">
        <div style="font-size:10px;font-weight:600;color:${labelColor};letter-spacing:.5px;margin-bottom:8px;">${label}</div>
        <div style="display:grid;gap:5px;">
          <div style="display:flex;justify-content:space-between;font-size:11px;">
            <span style="color:var(--muted)">${isConfirmed ? 'Enter trade at' : 'Watch for entry near'}</span>
            <span style="color:var(--text1);font-weight:600">${fmtP(sig.entry)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;">
            <span style="color:var(--muted)">Exit if wrong (stop loss)</span>
            <span style="color:#EF4444;font-weight:600">${fmtP(sig.sl)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;">
            <span style="color:var(--muted)">${isConfirmed ? 'Take profit at' : 'Target price'}</span>
            <span style="color:#22C55E;font-weight:600">${fmtP(sig.tp)}</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;">
            <span style="color:var(--muted)">Reward vs Risk</span>
            <span style="color:#F59E0B;font-weight:600">1 : ${sig.rr}</span>
          </div>
          ${sig.pos_size != null ? `<div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Suggested position size</span><span style="color:var(--text1);font-weight:600">${fmtP(sig.pos_size)}</span></div>` : ''}
          ${sig.risk_amt != null ? `<div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Max you could lose / gain</span><span style="color:var(--text1);font-weight:600">$${sig.risk_amt} / $${sig.reward_amt}</span></div>` : ''}
        </div>
        <div style="margin-top:8px;font-size:10px;color:var(--muted);font-style:italic;">${noteText}</div>
      </div>`;
  }

  // ── Action block
  let actionHtml = '';

  if (d.go_long || d.go_short) {
    // ── GO signal — confirmed levels
    if (signals.length > 0) {
      const best     = signals.reduce((a, b) => (b.confidence ?? 0) > (a.confidence ?? 0) ? b : a, signals[0]);
      const dir      = d.go_long ? 'BUY' : 'SELL';
      const dirColor = d.go_long ? '#22C55E' : '#EF4444';
      actionHtml = levelsHtml(best, `WHAT TO DO — ${dir} SETUP`, dirColor, true);
    }
  } else {
    // ── WAIT — show what to watch for
    if (reasons.length > 0) {
      const plain = reasons.map(r => {
        if (/mtf/i.test(r))             return 'Wait for a clearer trend direction across timeframes';
        if (/adx/i.test(r))             return 'Wait for the trend to strengthen before entering';
        if (/volume/i.test(r))          return 'Wait for more traders to be active (higher volume)';
        if (/rsi.*overbought/i.test(r)) return 'RSI is overheated — better to wait for it to cool down';
        if (/rsi.*oversold/i.test(r))   return 'RSI is very low — wait to see if a real bounce confirms';
        if (/gate/i.test(r))            return 'Not all conditions are met yet — be patient';
        return r;
      });
      actionHtml += `
        <div style="margin-top:10px;padding:8px 10px;background:rgba(239,68,68,.07);border-left:2px solid #EF4444;border-radius:4px;">
          <div style="font-size:10px;font-weight:600;color:#EF4444;letter-spacing:.5px;margin-bottom:6px;">WHAT TO WATCH FOR</div>
          ${plain.map(p => `<div style="font-size:11px;color:var(--text2);margin:3px 0;">• ${p}</div>`).join('')}
        </div>`;
    }

    // ── WAIT — always show both BUY and SELL price levels
    // Use confirmed signals first, fall back to ATR-based potential_levels
    const pl = d.potential_levels || {};

    if (signals.length > 0) {
      // Strategy signal fired but gate blocked it — still show as "forming"
      const best     = signals.reduce((a, b) => (b.confidence ?? 0) > (a.confidence ?? 0) ? b : a, signals[0]);
      const potDir   = best.direction === 'LONG' ? 'BUY' : 'SELL';
      const potColor = best.direction === 'LONG' ? '#22C55E' : '#EF4444';
      actionHtml += levelsHtml(best, `LEVELS TO WATCH — Potential ${potDir} setup forming`, potColor, false);
    }

    // Always show ATR-based BUY and SELL potential levels
    if (pl.buy && pl.sell) {
      const atrNote = `Based on 1.5× ATR (${fmtP(pl.buy.atr)}) — these are calculated reference prices, not confirmed signals.`;
      actionHtml += `
        <div style="margin-top:10px;padding:8px 10px;background:rgba(34,197,94,.04);border-left:2px solid #22C55E;border-radius:4px;">
          <div style="font-size:10px;font-weight:600;color:#22C55E;letter-spacing:.5px;margin-bottom:8px;">IF MARKET TURNS BUY — Reference Prices</div>
          <div style="display:grid;gap:4px;">
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Buy near</span><span style="color:var(--text1);font-weight:600">${fmtP(pl.buy.entry)}</span></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Exit if wrong (stop)</span><span style="color:#EF4444;font-weight:600">${fmtP(pl.buy.sl)}</span></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Target profit</span><span style="color:#22C55E;font-weight:600">${fmtP(pl.buy.tp)}</span></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Reward vs Risk</span><span style="color:#F59E0B;font-weight:600">1 : ${pl.buy.rr}</span></div>
            ${pl.buy.risk_amt != null ? `<div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Max lose / gain</span><span style="color:var(--text1);font-weight:600">$${pl.buy.risk_amt} / $${pl.buy.reward_amt}</span></div>` : ''}
          </div>
        </div>
        <div style="margin-top:6px;padding:8px 10px;background:rgba(239,68,68,.04);border-left:2px solid #EF4444;border-radius:4px;">
          <div style="font-size:10px;font-weight:600;color:#EF4444;letter-spacing:.5px;margin-bottom:8px;">IF MARKET TURNS SELL — Reference Prices</div>
          <div style="display:grid;gap:4px;">
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Sell near</span><span style="color:var(--text1);font-weight:600">${fmtP(pl.sell.entry)}</span></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Exit if wrong (stop)</span><span style="color:#EF4444;font-weight:600">${fmtP(pl.sell.sl)}</span></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Target profit</span><span style="color:#22C55E;font-weight:600">${fmtP(pl.sell.tp)}</span></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Reward vs Risk</span><span style="color:#F59E0B;font-weight:600">1 : ${pl.sell.rr}</span></div>
            ${pl.sell.risk_amt != null ? `<div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--muted)">Max lose / gain</span><span style="color:var(--text1);font-weight:600">$${pl.sell.risk_amt} / $${pl.sell.reward_amt}</span></div>` : ''}
          </div>
        </div>
        <div style="margin-top:5px;font-size:9.5px;color:var(--muted);font-style:italic;">⏳ ${atrNote}</div>`;
    }
  }

  return `
    <div style="padding:10px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:6px;">
      <div style="font-size:12px;font-weight:700;color:${headColor};margin-bottom:10px;">${headline}</div>
      <div style="font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.5px;margin-bottom:6px;">QUICK CHECKLIST</div>
      ${checklistHtml}
      ${momentumHtml}
      ${actionHtml}
    </div>`;
}

function downloadPine(e) {
  e.preventDefault();
  // Read the pre-built Pine Script file path via a simple fetch of the static asset
  // We serve the .pine file content inline as a download
  const filename = 'DotVerse_Strategies.pine';
  fetch('/static/DotVerse_Strategies.pine')
    .then(r => r.text())
    .then(text => {
      const blob = new Blob([text], { type: 'text/plain' });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    })
    .catch(() => {
      // fallback: open the Pine Script file directly
      window.open('/static/DotVerse_Strategies.pine', '_blank');
    });
}
</script>
