// Find most recent pivot in a series within \`lookback\` bars
// Returns [bar_index, value] or [na, na]
findLastPivot(src, maxBars) =>
    foundIdx = int(na)
    foundVal = float(na)
    for i = 1 to maxBars
        if not na(src[i])
            foundIdx := bar_index - i
            foundVal := src[i]
            break
