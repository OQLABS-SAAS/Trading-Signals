async function runTradePlan() {
  const style  = document.getElementById('tpStyle')?.value || 'daytrader';
  const minWR  = parseFloat(document.getElementById('tpMinWRInput')?.value || 60) / 100;

  document.getElementById('tpResult').style.display = 'none';
  document.getElementById('tpError').style.display  = 'none';
  document.getElementById('tpResult').innerHTML = '<div style="font-size:10px;color:var(--muted);padding:8px;">Generating plan…</div>';
  document.getElementById('tpResult').style.display = 'block';

  try {
    const res  = await fetch('/api/trade-plan', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ period: _tpPeriod, style, min_wr: minWR })
    });
    const data = await res.json();
    if (data.error) {
      document.getElementById('tpResult').style.display = 'none';
      document.getElementById('tpError').textContent = data.error;
      document.getElementById('tpError').style.display = 'block';
      return;
    }
    tpRenderPlan(data);
  } catch (e) {
    document.getElementById('tpResult').innerHTML = '';
    document.getElementById('tpResult').style.display = 'none';
    document.getElementById('tpError').textContent = 'Network error — ' + e.message;
    document.getElementById('tpError').style.display = 'block';
  }
}

function tpRenderPlan(d) {
  const el = document.getElementById('tpResult');
  if (!el) return;

  const wrBadge = s => {
    const wr = Math.round(s.win_rate * 100);
    const clr = wr >= 68 ? '#00c98d' : wr >= 62 ? '#f5a623' : '#7a90b0';
    return `<span style="font-family:var(--mono);font-size:9px;font-weight:700;color:${clr};background:rgba(255,255,255,.05);padding:1px 6px;border-radius:10px;border:1px solid rgba(255,255,255,.1);">${wr}% WR · ${s.avg_rr}R</span>`;
  };

  const stratCard = s => `
    <div style="padding:7px 9px;background:rgba(77,159,255,.06);border:1px solid rgba(77,159,255,.18);border-radius:5px;margin-bottom:5px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;">
