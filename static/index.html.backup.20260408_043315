/* ── Use current signal in calculator ── */
function useSignalForCalc() {
  const d = currentData;
  const hasSignal = d && (d.signal === 'BUY' || d.signal === 'SELL') && d.entry != null;

  // Always open the panel — even without a full signal
  const panel = document.getElementById('calcPanelCard');
  const arrow = document.getElementById('calcPosArrow');
  if (panel) {
    panel.style.display = 'block';
    if (arrow) { arrow.style.transform = 'rotate(90deg)'; arrow.style.transition = 'transform .2s'; }
    setTimeout(() => panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  }
  if (!hasSignal) return;

  // 1. Set direction
  setCalcDir(d.signal);

  // 2. Ensure auto mode is ON for both entry and SL
  if (!riskAutoState.entry) toggleRiskAuto('entry');
  if (!riskAutoState.sl)    toggleRiskAuto('sl');

  // 3. Refresh auto values from signal
  updateRiskAutoValues(d);

  // 4. Show the signal context badge in the calculator
  const badge = document.getElementById('calcSignalBadge');
  if (badge) {
    const tf  = (d.timeframe || '').toUpperCase();
    const dir = d.signal === 'BUY' ? '▲ BUY' : '▼ SELL';
    badge.style.display = 'flex';
    badge.innerHTML = `
      <span class="calc-sp ${d.signal}">${d.signal}</span>
      <span class="calc-st">${d.ticker || ''}</span>
      <span style="color:rgba(255,255,255,.16);">·</span>
      <span class="calc-stf">${tf} · auto-filled from analysis</span>
      <button style="margin-left:auto;background:none;border:none;color:rgba(255,255,255,.3);cursor:pointer;font-size:11px;padding:0;" title="Clear" onclick="clearCalcSignal()">✕</button>`;
  }

  // 5. (Panel already opened above) Auto-calculate so results show immediately
  setTimeout(() => {
    const acct = parseFloat(document.getElementById('riskAccount').value);
    if (acct > 0) calcRisk();
  }, 80);

  showToast(`📐 Calculator loaded — ${d.ticker} ${d.signal}`);
}

