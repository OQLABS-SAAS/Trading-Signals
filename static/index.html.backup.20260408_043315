/* ── Manual lot size override ── */
function recalcManualLot() {
  const lotType = (document.getElementById('manualLotType')?.value) || 'std';
  const lotVal  = parseFloat(document.getElementById('manualLotVal')?.value);
  const resultEl = document.getElementById('manualLotResult');
  if (!resultEl) return;
  if (!lotVal || isNaN(lotVal) || lotVal <= 0) { resultEl.style.display = 'none'; return; }

  // Convert entered lot value to units
  const unitsPerLot = { std: 100000, mini: 10000, micro: 1000 };
  const manualUnits = lotVal * (unitsPerLot[lotType] || 100000);

  // Pip value rates (USD pairs standard)
  const pipValPerLot = { std: 10.00, mini: 1.00, micro: 0.10 };

  // Need entry, SL, account from current state
  const acct  = parseFloat(document.getElementById('riskAccount').value) || 0;
  const cur   = document.getElementById('riskCurrency').value;
  const sym   = _curSym(cur);
  const assetType = currentData ? currentData.asset_type : 'forex';
  const ticker    = currentData ? (currentData.ticker||'').toUpperCase() : '';

  let entry = riskAutoState.entry
    ? parseFloat(currentData?.entry ?? currentData?._autoEntry)
    : parseFloat(document.getElementById('riskEntry').value);
  let sl = riskAutoState.sl
    ? parseFloat(currentData?.stop_loss ?? currentData?._autoSL)
    : parseFloat(document.getElementById('riskSL').value);

  if (isNaN(entry) || isNaN(sl) || !entry || !sl) {
    resultEl.style.display = 'block';
    resultEl.innerHTML = '⚠ Run a signal first to set entry &amp; SL prices.';
    return;
  }

  let pipSize = 1, pipLabel = 'pts';
  if (assetType === 'forex') { pipSize = ticker.includes('JPY') ? 0.01 : 0.0001; pipLabel = 'pips'; }

  const riskPerUnit = Math.abs(entry - sl);
  const slPips      = (riskPerUnit / pipSize);
  const isBuy       = calcDirection === 'BUY';

  // Risk calculation: for forex use pip-value method; for crypto/stocks use unit method
  let manualRisk;
  let pipValueTotal = 0;
  if (assetType === 'forex') {
    // pip value per lot type × number of lots × SL distance in pips
    pipValueTotal = lotVal * (pipValPerLot[lotType] || 10);  // $/pip for this position
    manualRisk    = pipValueTotal * slPips;
  } else {
    manualRisk = manualUnits * riskPerUnit;
  }

  const manualRiskPct = acct > 0 ? (manualRisk / acct * 100).toFixed(2) : '—';

  // Equivalent lots in all 3 types
  const stdEq   = (manualUnits / 100000).toFixed(2);
  const miniEq  = (manualUnits / 10000).toFixed(2);
  const microEq = (manualUnits / 1000).toFixed(2);

  // TP profits — also use pip-value method for forex
  const tpLines = ['tp1','tp2','tp3'].map((k,i) => {
    const tpPrice = parseFloat(currentData?.[k]);
    if (!tpPrice) return '';
    const tpPips = Math.abs(tpPrice - entry) / pipSize;
    const prof   = assetType === 'forex'
      ? pipValueTotal * tpPips
      : manualUnits * Math.abs(tpPrice - entry);
    const rr     = (Math.abs(tpPrice - entry) / riskPerUnit).toFixed(1);
    return `<span style="color:#00c98d;">TP${i+1} +${sym}${prof.toFixed(2)} (${rr}:1)</span>`;
  }).filter(Boolean).join(' &nbsp;·&nbsp; ');

  // 5% cap warning
  const pctNum  = parseFloat(manualRiskPct);
  const capNote = acct > 0 && pctNum > 5
    ? `<div style="color:#ff6b7a;margin-top:4px;">⚠ This lot size risks ${manualRiskPct}% — exceeds the 5% safe limit.</div>`
    : '';

  // Pip value line (forex only)
  const pipValLine = assetType === 'forex'
    ? `<span>📈 Pip value: <strong style="color:rgba(245,190,80,0.9);">$${pipValueTotal.toFixed(2)}/pip</strong> &nbsp;(${lotType}: $${pipValPerLot[lotType]}/pip × ${lotVal} lots)</span>`
    : '';

  resultEl.style.display = 'block';
  resultEl.innerHTML = `
    <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:6px;margin-bottom:5px;">
      <span>📊 <strong style="color:var(--orange);">${lotVal} ${lotType} lot${lotVal!==1?'s':''}</strong> = ${manualUnits.toLocaleString()} units</span>
      <span style="opacity:.65;">${stdEq} std / ${miniEq} mini / ${microEq} micro</span>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:4px;">
      <span>💰 Risk: <strong style="color:#ff6b7a;">${sym}${manualRisk.toFixed(2)}</strong>${acct>0?' ('+manualRiskPct+'% of acct)':''}</span>
      <span>📏 SL: <strong>${slPips.toFixed(1)} ${pipLabel}</strong></span>
    </div>
    ${pipValLine ? `<div style="margin-bottom:4px;">${pipValLine}</div>` : ''}
    ${tpLines ? `<div style="margin-top:3px;">${tpLines}</div>` : ''}
    ${capNote}`;
}

