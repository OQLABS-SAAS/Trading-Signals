function renderSentiment(d) {
  const wrap = document.getElementById('sentimentWrap');
  if (!wrap) return;
  // Compute a weighted sentiment score from indicators
  let score = 50;
  if (d.rsi != null) {
    if (d.rsi < 30) score += 18;
    else if (d.rsi > 70) score -= 18;
    else score += (50 - d.rsi) * 0.4;
  }
  if (d.macd_hist != null) score += d.macd_hist > 0 ? 10 : -10;
  if (d.supertrend === 'BULLISH') score += 10;
  else if (d.supertrend === 'BEARISH') score -= 10;
  if ((d.ema_trend || '').includes('BULL')) score += 10;
  else if ((d.ema_trend || '').includes('BEAR')) score -= 10;
  if (d.bb_pos != null) score += d.bb_pos < 0.3 ? 8 : d.bb_pos > 0.7 ? -8 : 0;
  const bull = Math.max(10, Math.min(90, Math.round(score)));
  const bear = 100 - bull;
  wrap.style.display = 'block';
  document.getElementById('sentBull').style.width  = bull + '%';
  document.getElementById('sentBear').style.width  = bear + '%';
  document.getElementById('sentBullLbl').textContent = bull + '% Buyers';
  document.getElementById('sentBearLbl').textContent = bear + '% Sellers';
}

