.ind-name{font-size:9px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:rgba(245,190,80,0.50);}
.ind-badge{font-size:10px;font-weight:700;padding:3px 8px;border-radius:5px;text-transform:uppercase;letter-spacing:.5px;}
.ind-badge.bull{background:rgba(0,201,141,.12);color:#00c98d;border:1px solid rgba(0,201,141,.26);}
.ind-badge.bear{background:rgba(255,68,89,.12);color:#ff6b7a;border:1px solid rgba(255,68,89,.24);}
