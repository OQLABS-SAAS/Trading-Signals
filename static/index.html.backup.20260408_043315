  </div>

  <!-- LOADING -->
  <div class="loading-state hidden" id="loadingState">
    <div class="spinner"></div>
    <div class="loading-label" id="loadingLabel">Fetching market data…</div>
  </div>

  <!-- EMPTY STATE -->
  <div id="emptyState">
    <div class="empty-state">
      <div class="empty-icon">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="es-glow" x="-80%" y="-80%" width="260%" height="260%">
              <feGaussianBlur stdDeviation="4" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <circle cx="28" cy="28" r="26" stroke="#f5a623" stroke-width="0.6" opacity="0.15"/>
          <circle cx="28" cy="28" r="19" stroke="#f5a623" stroke-width="0.8" opacity="0.28"/>
          <circle cx="28" cy="28" r="12" stroke="#f5a623" stroke-width="1" opacity="0.5"/>
          <circle cx="28" cy="28" r="6" fill="#f5a623" opacity="0.35" filter="url(#es-glow)"/>
          <circle cx="28" cy="28" r="4" fill="#ffffff"/>
        </svg>
      </div>
      <div class="empty-title">Trade Like You Already Know.</div>
      <div class="empty-sub">Enter any ticker for instant AI signals with entry, stop-loss, and 3 take-profit targets. RSI, MACD, Bollinger Bands, Supertrend — all in one tap.</div>
      <div style="margin-top:20px;max-width:680px;margin-left:auto;margin-right:auto;width:100%;">
        <div class="inst-tabs">
          <div class="inst-tab active" data-tab="crypto"      onclick="switchTab('crypto')">Crypto</div>
