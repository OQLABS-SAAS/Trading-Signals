/* ════════════════════════════════════════════
   PINE SCRIPT v5 — TP/SL BACKTEST STRATEGY
════════════════════════════════════════════ */
function copyStrategy() {
  const d = currentData;
  if (!d) { alert('Run an analysis first.'); return; }
  if (d.signal === 'HOLD' || d.entry == null) {
    alert('Strategy only available for BUY or SELL signals.'); return;
  }
  const sig    = d.signal;
  const isLong = (sig === 'BUY');
  const dir    = isLong ? 'strategy.long' : 'strategy.short';
  const ticker = d.ticker;
  const tf     = d.timeframe.toUpperCase();

  // Compute % distances from current signal entry — same methodology as DotVerse backtest
  const entry   = parseFloat(d.entry);
  const sl      = parseFloat(d.stop_loss);
  const tp1v    = parseFloat(d.tp1);
  const riskPct = Math.abs(sl   - entry) / entry;
  const tp1Pct  = Math.abs(tp1v - entry) / entry;
  const tp2Pct  = d.tp2 != null ? Math.abs(parseFloat(d.tp2) - entry) / entry : null;
  const tp3Pct  = d.tp3 != null ? Math.abs(parseFloat(d.tp3) - entry) / entry : null;
  const fmt6    = n => n.toFixed(6);
  const fmtPct  = n => (n * 100).toFixed(2);

  let lines = [];
  lines.push('//@version=5');
  lines.push('strategy("DotVerse ' + sig + ' \u2014 ' + ticker + ' ' + tf + '", overlay=true,');
  lines.push('         default_qty_type=strategy.percent_of_equity, default_qty_value=10,');
  lines.push('         commission_type=strategy.commission.percent, commission_value=0.1,');
  lines.push('         initial_capital=10000)');
  lines.push('');
  lines.push('// Signal reference — Entry: ' + d.entry + ' | SL: ' + d.stop_loss + ' | TP1: ' + d.tp1);
  lines.push('// Exits use %-based levels so each historical trade gets its own correct TP/SL');
  lines.push('');
  lines.push('// Percentage distances derived from current signal entry');
  lines.push('risk_pct = ' + fmt6(riskPct) + '  // ' + fmtPct(riskPct) + '% risk');
  lines.push('tp1_pct  = ' + fmt6(tp1Pct)  + '  // ' + fmtPct(tp1Pct)  + '% to TP1');
  if (tp2Pct != null) lines.push('tp2_pct  = ' + fmt6(tp2Pct) + '  // ' + fmtPct(tp2Pct) + '% to TP2');
  if (tp3Pct != null) lines.push('tp3_pct  = ' + fmt6(tp3Pct) + '  // ' + fmtPct(tp3Pct) + '% to TP3');
  lines.push('');
  lines.push('// Window: only trade the last 200 bars — same lookback as DotVerse app');
  lines.push('inWindow = bar_index >= (last_bar_index - 200)');
  lines.push('');
  lines.push('// Entry: RSI ' + (isLong ? 'crossunder 40 (oversold) — matches DotVerse BUY condition' : 'crossover 60 (overbought) — matches DotVerse SELL condition'));
  lines.push('rsi14 = ta.rsi(close, 14)');
  if (isLong) {
    lines.push('entryCondition = ta.crossunder(rsi14, 40) and strategy.position_size == 0 and inWindow');
  } else {
    lines.push('entryCondition = ta.crossover(rsi14, 60)  and strategy.position_size == 0 and inWindow');
  }
  lines.push('if entryCondition');
  lines.push('    strategy.entry("' + sig + '", ' + dir + ')');
  lines.push('');
  lines.push('// Exits — %-based TP/SL applied to each trade\'s actual historical entry price');
  lines.push('if strategy.position_size != 0');
  lines.push('    e    = strategy.position_avg_price');
  if (isLong) {
    lines.push('    h_sl = e * (1 - risk_pct)');
    lines.push('    h_t1 = e * (1 + tp1_pct)');
    if (tp2Pct != null) lines.push('    h_t2 = e * (1 + tp2_pct)');
    if (tp3Pct != null) lines.push('    h_t3 = e * (1 + tp3_pct)');
  } else {
    lines.push('    h_sl = e * (1 + risk_pct)');
    lines.push('    h_t1 = e * (1 - tp1_pct)');
    if (tp2Pct != null) lines.push('    h_t2 = e * (1 - tp2_pct)');
    if (tp3Pct != null) lines.push('    h_t3 = e * (1 - tp3_pct)');
  }
  lines.push('    strategy.exit("SL",  from_entry="' + sig + '", stop=h_sl)');
  lines.push('    strategy.exit("TP1", from_entry="' + sig + '", limit=h_t1' + (tp2Pct != null ? ', qty_percent=50' : '') + ')');
  if (tp2Pct != null) lines.push('    strategy.exit("TP2", from_entry="' + sig + '", limit=h_t2, qty_percent=' + (tp3Pct != null ? '25' : '50') + ')');
  if (tp3Pct != null) lines.push('    strategy.exit("TP3", from_entry="' + sig + '", limit=h_t3, qty_percent=100)');
  lines.push('');
  lines.push('// Level lines — drawn relative to open trade\'s actual entry price');
  lines.push('e_now = strategy.position_size != 0 ? strategy.position_avg_price : na');
  lines.push('plot(e_now, "Entry", color.orange, 2, plot.style_linebr)');
  if (isLong) {
    lines.push('plot(e_now != na ? e_now * (1 - risk_pct) : na, "SL",  color.red,   2, plot.style_linebr)');
    lines.push('plot(e_now != na ? e_now * (1 + tp1_pct)  : na, "TP1", color.green, 2, plot.style_linebr)');
    if (tp2Pct != null) lines.push('plot(e_now != na ? e_now * (1 + tp2_pct) : na, "TP2", color.teal, 1, plot.style_linebr)');
    if (tp3Pct != null) lines.push('plot(e_now != na ? e_now * (1 + tp3_pct) : na, "TP3", color.lime, 1, plot.style_linebr)');
  } else {
    lines.push('plot(e_now != na ? e_now * (1 + risk_pct) : na, "SL",  color.red,   2, plot.style_linebr)');
    lines.push('plot(e_now != na ? e_now * (1 - tp1_pct)  : na, "TP1", color.green, 2, plot.style_linebr)');
    if (tp2Pct != null) lines.push('plot(e_now != na ? e_now * (1 - tp2_pct) : na, "TP2", color.teal, 1, plot.style_linebr)');
    if (tp3Pct != null) lines.push('plot(e_now != na ? e_now * (1 - tp3_pct) : na, "TP3", color.lime, 1, plot.style_linebr)');
  }

  const pine = lines.join('\n');
  const pre = document.getElementById('pineCodePre');
  if (pre) pre.textContent = pine;

  const wrap = document.getElementById('pineCodeWrap');
  const btn2 = document.getElementById('pineToggleBtn');
  if (wrap) wrap.style.display = '';
  if (btn2) btn2.textContent = 'Hide Indicator \u25b2';

  _clipWrite(pine);
  _btnFeedback('copyStratBtn', '\u2713 Copied!', '\u26a1 TP/SL Backtest Strategy');
  showCopyCheck();
  showToast('📋 Strategy copied — paste into TradingView Pine Editor to backtest');
}

/* ════════════════════════════════════════════
