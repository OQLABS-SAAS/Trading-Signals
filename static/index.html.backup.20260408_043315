.pct-btn.on{background:var(--orange-bg);border-color:rgba(245,166,35,.42);color:var(--orange);}
.pct-custom{width:42px;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:6px;font-size:11px;font-family:var(--mono);padding:4px 5px;text-align:center;outline:none;flex-shrink:0;}
