// ===============================================================
C_REG_BULL  = color.new(#f5a623, 0)    // Regular bullish  - amber
C_REG_BEAR  = color.new(#ff524a, 0)    // Regular bearish  - red
C_HID_BULL  = color.new(#30d158, 0)    // Hidden bullish   - green
