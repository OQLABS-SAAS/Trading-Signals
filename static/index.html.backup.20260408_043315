/* ── Send SMS via backend ── */
async function sendSMS() {
  const d      = currentData;
  if (!d) return;
  const phone  = (document.getElementById('smsPhone')?.value || '').trim();
  const status = document.getElementById('smsStatus');
  if (!phone) { if (status) status.textContent = '⚠ Enter phone number'; return; }
  if (status) status.textContent = 'Sending…';
  const sig = d.signal || 'HOLD';
  let msg = 'DotVerse: ' + d.ticker + ' ' + d.timeframe.toUpperCase() + ' — ' + sig +
            ' | Confidence: ' + (d.confidence||'—') + ' | Price: ' + d.price;
  if (sig !== 'HOLD' && d.entry != null) {
    msg += ' | Entry: ' + d.entry + ' SL: ' + d.stop_loss + ' TP1: ' + d.tp1;
  }
  try {
    const r = await fetch('/api/send-sms', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ phone, message: msg })
    });
    const res = await r.json();
    if (status) status.textContent = res.error ? '⚠ ' + res.error : '✓ Sent!';
  } catch(e) {
    if (status) status.textContent = '⚠ Send failed';
  }
}

