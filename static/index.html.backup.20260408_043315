C_RSI       = color.new(#f5a623, 0)    // RSI line
C_OB        = color.new(#ff524a, 75)   // Overbought fill
C_OS        = color.new(#30d158, 75)   // Oversold fill
C_MID       = color.new(#ffffff, 88)   // Midline
C_MUTED     = color.new(#ffffff, 60)
C_BG        = color.new(#0d1117, 10)


