async function openSimulate() {
  if (!currentData) return;
  const modal = document.getElementById('simModal');
  const content = document.getElementById('simContent');
  modal.style.display = 'flex';
  content.innerHTML = '<div class="sim-loading">Running simulation…</div>';

  const d = currentData;
  const btn = document.getElementById('simulateBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Simulating…';

  // For HOLD signals, fall back to potential_levels (ATR-based reference prices)
  const pl = d.potential_levels || {};
  const plBuy  = pl.buy  || {};
  const plSell = pl.sell || {};
  const simEntry    = d.entry     ?? plBuy.entry  ?? plSell.entry  ?? null;
  const simSL       = d.stop_loss ?? plBuy.sl     ?? plSell.sl     ?? null;
  const simTP1      = d.tp1       ?? plBuy.tp     ?? plSell.tp     ?? null;
  // Build extra context for HOLD what-if
  const isHold = (d.signal || '').toUpperCase() === 'HOLD';
  const holdCtx = isHold
    ? ` [WHAT-IF SCENARIO: signal is HOLD. Potential BUY at ${fmt(plBuy.entry)} SL ${fmt(plBuy.sl)} TP ${fmt(plBuy.tp)} | Potential SELL at ${fmt(plSell.entry)} SL ${fmt(plSell.sl)} TP ${fmt(plSell.tp)}]`
    : '';

  try {
    const r = await fetch('/api/simulate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ticker:    d.ticker,
        asset_type: d.asset_type,
        timeframe: d.timeframe,
        signal:    d.signal,
        price:     d.price,
        entry:     simEntry,
        stop_loss: simSL,
        tp1: simTP1, tp2: d.tp2, tp3: d.tp3,
        narrative: (d.narrative || d.summary || '') + holdCtx,
      }),
    });
    const j = await r.json();
    if (j.error) throw new Error(j.error);
    const sim = j.simulation;

    const pathHTML = (key, cls) => {
      const p = sim[key];
      if (!p) return '';
      const prob = (p.probability || '').toString().replace(/[^0-9%]/g,'') || '—';
      const title = (p.title || key).toUpperCase().replace(/[^A-Z\s]/g,'').trim();
      return `<div class="sim-path ${cls}">
        <div class="sim-path-left">
          <div class="sim-path-prob">${prob}</div>
          <div class="sim-path-prob-lbl">probability</div>
          <div class="sim-path-title">${title}</div>
        </div>
        <div class="sim-path-right">
          <div class="sim-path-text">${p.path || ''}</div>
          ${(p.key_level || p.exit) ? `<div class="sim-path-meta">
            ${p.key_level ? `<div class="sim-meta-row"><span class="sim-meta-label watch">Watch</span><span class="sim-meta-text">${p.key_level}</span></div>` : ''}
            ${p.exit      ? `<div class="sim-meta-row"><span class="sim-meta-label manage">Manage</span><span class="sim-meta-text">${p.exit}</span></div>` : ''}
          </div>` : ''}
        </div>
      </div>`;
    };

    content.innerHTML = `<div class="sim-paths">
      ${pathHTML('success', 'success')}
      ${pathHTML('consolidation', 'consolidation')}
      ${pathHTML('reversal', 'reversal')}
    </div>`;

  } catch(e) {
    content.innerHTML = `<div class="sim-loading" style="color:var(--red);">⚠ Simulation failed: ${e.message}</div>`;
  } finally {
    btn.disabled = false;
    btn.textContent = isHold ? 'Simulate What-If' : 'Simulate Trade';
  }
}

