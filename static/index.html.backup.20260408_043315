function buildTape() {
  const track = document.getElementById('tapeTrack');
  const sid = s => s.replace(/[^a-zA-Z0-9]/g, '_');
  // Double the items for seamless loop
  const makeItems = () => TAPE_ASSETS.map(([disp, tick]) =>
    `<span class="tape-item">
      <span class="tape-symbol">${disp}</span>
      <span class="tape-price" id="tp-${sid(tick)}">—</span>
      <span class="tape-chg" id="tc-${sid(tick)}">—</span>
     </span>`
  ).join('');
  track.innerHTML = makeItems() + makeItems();
}

async function loadTape() {
  const tickers = TAPE_ASSETS.map(([,t]) => t);
  const sid = s => s.replace(/[^a-zA-Z0-9]/g, '_');
  try {
    const r = await fetch('/api/prices',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tickers})});
    const data = await r.json();
    TAPE_ASSETS.forEach(([,sym]) => {
      const d = data[sym];
      if (!d || d.price === null) return;
      const cls = d.chg >= 0 ? 'up' : 'down';
      const chgStr = (d.chg >= 0 ? '▲' : '▼') + Math.abs(d.chg).toFixed(2) + '%';
      document.querySelectorAll(`[id="tp-${sid(sym)}"]`).forEach(el => el.textContent = fmt(d.price));
      document.querySelectorAll(`[id="tc-${sid(sym)}"]`).forEach(el => { el.textContent = chgStr; el.className = `tape-chg ${cls}`; });
    });
  } catch(e) { console.warn('Tape error', e); }
}

