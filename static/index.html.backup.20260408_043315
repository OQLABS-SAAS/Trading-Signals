.calc-st{font-weight:700;font-family:var(--mono);}
.calc-stf{color:var(--muted);font-size:10px;}
.calc-2col{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;}
.calc-field{display:flex;flex-direction:column;gap:3px;margin-bottom:8px;}
.calc-lbl-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:1px;}
