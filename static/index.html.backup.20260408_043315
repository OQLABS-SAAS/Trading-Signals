/* ── currency symbol helper ── */
function _curSym(cur) {
  return {USD:'$',AED:'AED ',SAR:'SAR ',EUR:'€',GBP:'£',KWD:'KWD ',QAR:'QAR '}[cur] || '$';
}

/* ── live risk amount display ── */
function liveRiskAmt() {
  const acct = parseFloat(document.getElementById('riskAccount').value);
  const pct  = parseFloat(document.getElementById('riskPct').value);
  const cur  = document.getElementById('riskCurrency').value;
  const sym  = _curSym(cur);
  const el   = document.getElementById('calcRiskAmt');
  const pctInput = document.getElementById('riskPct');
  if (acct > 0 && pct > 0) {
    const effectivePct = Math.min(pct, 5);
    const amt = acct * effectivePct / 100;
    el.textContent = sym + amt.toLocaleString(undefined,{maximumFractionDigits:2});
    // Warn live if over 5%
    if (pct > 5) {
      pctInput.style.borderColor = 'rgba(255,68,89,.6)';
      pctInput.title = 'Risk capped at 5% — max safe limit';
    } else {
      pctInput.style.borderColor = '';
      pctInput.title = '';
    }
  } else {
    el.textContent = '—';
  }
}

/* ── risk % preset buttons ── */
function setRiskPct(pct) {
  document.getElementById('riskPct').value = pct;
  document.querySelectorAll('.pct-btn').forEach(b => {
    b.classList.toggle('on', parseFloat(b.textContent) === pct);
  });
  liveRiskAmt();
}

function calcRisk() {
  const acct = parseFloat(document.getElementById('riskAccount').value);
  const pct  = parseFloat(document.getElementById('riskPct').value) / 100;
  const cur  = document.getElementById('riskCurrency').value;
  const sym  = _curSym(cur);

  // Resolve entry & SL (auto or manual)
  let entry, sl;
  if (riskAutoState.entry) {
    if (!currentData) { showToast('Run a signal first to use Auto entry'); return; }
    entry = parseFloat(currentData.entry ?? currentData._autoEntry);
    if (isNaN(entry)) { showToast('No entry value — run a signal first'); return; }
  } else {
    entry = parseFloat(document.getElementById('riskEntry').value);
  }
  if (riskAutoState.sl) {
    if (!currentData) { showToast('Run a signal first to use Auto SL'); return; }
    sl = parseFloat(currentData.stop_loss ?? currentData._autoSL);
    if (isNaN(sl)) { showToast('No stop-loss value — run a signal first'); return; }
  } else {
    sl = parseFloat(document.getElementById('riskSL').value);
  }

  if (!acct || !pct)        { showToast('Enter account size and risk %'); return; }
  if (isNaN(entry)||!entry) { showToast('Entry price missing'); return; }
  if (isNaN(sl)   || !sl)  { showToast('Stop loss price missing'); return; }
  if (calcDirection === null) { showToast('Select BUY or SELL direction first'); return; }

  // ── 5% capital cap ──
  const MAX_RISK_PCT = 0.05;
  const wasCapped    = pct > MAX_RISK_PCT;
  const effectivePct = wasCapped ? MAX_RISK_PCT : pct;
  const riskAmt      = acct * effectivePct;

  const riskPerUnit = Math.abs(entry - sl);
  if (!riskPerUnit) { showToast('Entry and SL must differ'); return; }

  const isBuy  = calcDirection === 'BUY';
  const units  = riskAmt / riskPerUnit;
  const posVal = units * entry;

  // ── Pip/point calculation ──
  const assetType = currentData ? currentData.asset_type : 'crypto';
  const ticker    = currentData ? (currentData.ticker||'').toUpperCase() : '';
  let pipSize = 1, pipLabel = 'pts';
  if (assetType === 'forex') {
    pipSize  = ticker.includes('JPY') ? 0.01 : 0.0001;
    pipLabel = 'pips';
  }
  const slPips = riskPerUnit / pipSize;

  // ── Primary position size label ──
  let lotLabel;
  if (assetType === 'forex') {
    const stdLots = units / 100000;
    lotLabel = stdLots >= 0.1 ? stdLots.toFixed(2) + ' std lots' : (units/1000).toFixed(2) + ' micro lots';
  } else if (assetType === 'crypto') {
    lotLabel = units >= 1 ? units.toFixed(4) + ' coins' : units.toFixed(6) + ' coins';
  } else {
    lotLabel = units.toFixed(2) + ' shares';
  }

  // ── Render core results ──
  const el = document.getElementById('riskResult');
  el.style.display = 'block';

  document.getElementById('calcRiskAmt').textContent =
    sym + riskAmt.toLocaleString(undefined,{maximumFractionDigits:2});

  document.getElementById('riskVal').textContent    = lotLabel;
  document.getElementById('riskLots').textContent   = lotLabel;
  document.getElementById('riskPips').textContent   = slPips.toFixed(1) + ' ' + pipLabel + ' to SL';
  document.getElementById('riskDollar').textContent = sym + riskAmt.toFixed(2);

  // ── 5% cap warning ──
  const capWarnEl = document.getElementById('calcCapWarn');
  if (capWarnEl) {
    if (wasCapped) {
      capWarnEl.style.display = 'block';
      capWarnEl.innerHTML = `<div class="calc-cap-warn"><span class="calc-cap-warn-icon">⚠️</span><span>Risk capped at <strong>5% (${sym}${(acct*MAX_RISK_PCT).toFixed(2)})</strong> — your input of ${(pct*100).toFixed(1)}% was reduced. Never risk more than 5% per trade to protect your capital.</span></div>`;
    } else {
      capWarnEl.style.display = 'none';
    }
  }

