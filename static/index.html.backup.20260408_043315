function seSetInstrumentMode(mode) {
  _seMode = mode;
  const chips    = document.getElementById('seTickerChips');
  const addBtn   = document.getElementById('seAddTickerBtn');
  const scanBtn  = document.getElementById('seScanBtn');
  const runBtn   = document.getElementById('seRunBtn');
  const singleB  = document.getElementById('seModeBtn_single');
  const multiB   = document.getElementById('seModeBtn_multi');

  const isSingle = mode === 'single';
  if (chips)   chips.style.display    = isSingle ? 'none' : 'flex';
  if (addBtn)  addBtn.style.display   = isSingle ? 'none' : '';
  if (scanBtn) scanBtn.style.display  = isSingle ? 'none' : '';
  if (runBtn)  runBtn.style.display   = isSingle ? ''     : 'none';

  if (singleB) {
    singleB.style.background    = isSingle ? 'rgba(245,158,11,.18)' : 'rgba(255,255,255,.04)';
    singleB.style.color         = isSingle ? '#F59E0B' : 'var(--text2)';
    singleB.style.borderColor   = isSingle ? 'rgba(245,158,11,.4)' : 'rgba(255,255,255,.1)';
  }
  if (multiB) {
    multiB.style.background     = !isSingle ? 'rgba(139,92,246,.16)' : 'rgba(255,255,255,.04)';
    multiB.style.color          = !isSingle ? '#8B5CF6' : 'var(--text2)';
    multiB.style.borderColor    = !isSingle ? 'rgba(139,92,246,.4)' : 'rgba(255,255,255,.1)';
  }
}

function seQPCategory(cat) {
  _seQPCat = cat;
  const cats = ['crypto','forex','stocks','indices'];
  cats.forEach(c => {
    const btn = document.getElementById('seQP_' + c);
    if (!btn) return;
    const active = c === cat;
    btn.style.background  = active ? 'rgba(245,158,11,.12)' : 'rgba(255,255,255,.03)';
    btn.style.color       = active ? '#F59E0B' : 'var(--text2)';
    btn.style.borderColor = active ? 'rgba(245,158,11,.35)' : 'rgba(255,255,255,.08)';
    btn.style.fontWeight  = active ? '700' : '500';
  });
  const wrap = document.getElementById('seQPSymbols');
  if (!wrap) return;
  const symbols = SE_QP_SYMBOLS[cat] || [];
  const labels  = SE_QP_LABELS[cat]  || symbols;
  wrap.innerHTML = symbols.map((sym, i) => {
    const ticker = document.getElementById('seTicker')?.value?.trim().toUpperCase() || '';
    const isActive = sym === ticker || (_seMode === 'multi' && _seTickerList.includes(sym));
    return `<button onclick="sePickSymbol('${sym}')" class="se-qp-sym${isActive?' active-sym':''}">${labels[i]}</button>`;
  }).join('');
}

function sePickSymbol(sym) {
  const input = document.getElementById('seTicker');
  if (input) input.value = sym;
  if (_seMode === 'multi') {
    seAddToMultiList(sym);
  }
  // Refresh quick-pick to highlight active
  seQPCategory(_seQPCat);
}

function seInstrumentEnter() {
  const sym = (document.getElementById('seTicker')?.value || '').trim().toUpperCase();
  if (!sym) return;
  if (_seMode === 'multi') seAddToMultiList(sym);
}

function seAddToMultiList(sym) {
  if (!sym || _seTickerList.includes(sym)) return;
  _seTickerList.push(sym);
  _seRenderChips();
}

function seRemoveTicker(sym) {
  _seTickerList = _seTickerList.filter(s => s !== sym);
  _seRenderChips();
  seQPCategory(_seQPCat); // refresh highlights
}

function _seRenderChips() {
  const wrap = document.getElementById('seTickerChips');
  if (!wrap) return;
  if (_seTickerList.length === 0) {
    wrap.innerHTML = '<span style="font-size:8.5px;color:var(--muted);align-self:center;padding:0 2px;">No instruments added — pick above or type + Add</span>';
    return;
  }
  wrap.innerHTML = _seTickerList.map(sym =>
    `<span class="se-ticker-chip">${sym}<button onclick="seRemoveTicker('${sym}')">✕</button></span>`
  ).join('');
}

function seSelectTab(idx) {
  _seActiveTab = idx;
  SE_STRATEGIES.forEach((_, i) => {
    const btn = document.getElementById('seTab' + i);
    if (btn) btn.classList.toggle('active', i === idx);
  });
  const desc = document.getElementById('seDesc');
  if (desc) desc.textContent = SE_STRATEGIES[idx]?.desc || '';
}

function _seGetStrategies() {
  const filter = document.getElementById('seStratFilter')?.value || 'ALL';
  if (filter === 'TOP5') return TOP5_STRATEGIES;
  if (filter !== 'ALL')  return [filter];
  return ['FCR','MSL','LF','FVG','FF','RW','DC','QFVG','BFR','BR3','SWP','ENG'];
}

// ═══════════════════════════════════════════════════════════
//  AUTO-REFRESH + STATE PERSISTENCE
// ═══════════════════════════════════════════════════════════
let _seRefreshTimer   = null;
let _seRefreshSecs    = 0;
let _seLastRunTime    = null;
let _seCountdownTimer = null;

function seSetRefresh(secs) {
  _seRefreshSecs = secs;
  // Update button styles
  [0, 60, 300, 900].forEach(s => {
    const btn = document.getElementById('seRef' + s);
    if (btn) btn.className = 'se-ref-btn' + (s === secs ? ' se-ref-active' : '');
  });
  // Clear existing timer
  if (_seRefreshTimer) { clearInterval(_seRefreshTimer); _seRefreshTimer = null; }
  if (_seCountdownTimer) { clearInterval(_seCountdownTimer); _seCountdownTimer = null; }
  const lu = document.getElementById('seLastUpdated');
  if (secs === 0) {
    if (lu) lu.style.display = 'none';
    localStorage.setItem('seRefreshSecs', '0');
    return;
  }
  localStorage.setItem('seRefreshSecs', String(secs));
  if (lu) lu.style.display = 'inline';
  // Auto-run immediately then on interval
  runStrategyEngine();
  _seRefreshTimer = setInterval(() => runStrategyEngine(), secs * 1000);
  // Countdown display
  _seCountdownTimer = setInterval(() => {
    if (!_seLastRunTime || !lu) return;
    const elapsed = Math.round((Date.now() - _seLastRunTime) / 1000);
    const remaining = Math.max(0, secs - elapsed);
    const mm = String(Math.floor(remaining / 60)).padStart(2, '0');
    const ss = String(remaining % 60).padStart(2, '0');
    lu.textContent = `🕐 Updated ${elapsed}s ago · next in ${mm}:${ss}`;
  }, 1000);
}

function _seRestoreState() {
  // Restore saved ticker / TF / HTF
  const saved = JSON.parse(localStorage.getItem('seState') || '{}');
  if (saved.ticker) {
    const el = document.getElementById('seTicker');
    if (el) el.value = saved.ticker;
  }
  if (saved.tf) {
    const el = document.getElementById('seTf');
    if (el) el.value = saved.tf;
  }
  if (saved.htf) {
    const el = document.getElementById('seHtf');
    if (el) el.value = saved.htf;
  }
  if (saved.minRR) {
    const el = document.getElementById('seMinRR');
    if (el) el.value = saved.minRR;
  }
  // Restore refresh rate (but don't auto-start — user must interact)
  const savedRefresh = parseInt(localStorage.getItem('seRefreshSecs') || '0', 10);
  if (savedRefresh > 0) {
    // Set button active state only — don't auto-run silently
    [0, 60, 300, 900].forEach(s => {
      const btn = document.getElementById('seRef' + s);
      if (btn) btn.className = 'se-ref-btn' + (s === savedRefresh ? ' se-ref-active' : '');
    });
    _seRefreshSecs = savedRefresh;
  }
}

function _seSaveState() {
  const state = {
    ticker: (document.getElementById('seTicker')?.value || '').trim().toUpperCase(),
    tf:     document.getElementById('seTf')?.value     || '1h',
    htf:    document.getElementById('seHtf')?.value    || '1d',
    minRR:  document.getElementById('seMinRR')?.value  || '2.0',
  };
  localStorage.setItem('seState', JSON.stringify(state));
}

async function runStrategyEngine() {
  const ticker  = (document.getElementById('seTicker')?.value || '').trim().toUpperCase() || 'BTC-USD';
  const tf      = document.getElementById('seTf')?.value     || '1h';
  const htf     = document.getElementById('seHtf')?.value    || '1d';
  const minRR   = parseFloat(document.getElementById('seMinRR')?.value) || 2.0;
  const acct    = parseFloat(document.getElementById('seAcct')?.value)  || 10000;
  const riskPct = parseFloat(document.getElementById('seRisk')?.value)  || 1.0;

  // Save state and record run time
  _seSaveState();
  _seLastRunTime = Date.now();
  const lu = document.getElementById('seLastUpdated');
  if (lu && _seRefreshSecs > 0) { lu.style.display = 'inline'; lu.textContent = '🕐 Updating…'; }

  const badge = document.getElementById('seVerdictBadge');
  if (badge) { badge.textContent = '…'; badge.style.background = 'rgba(122,144,176,.12)'; badge.style.color = '#7a90b0'; }
  ['seGateStatus','seResults','seNoGo','sePineBtn','seFootprintPanel','seOrderFlowPanel','seScanSummary','sePlainSummary','seDetailsToggle'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });

  const runBtn = document.getElementById('seRunBtn');
  if (runBtn) { runBtn.disabled = true; runBtn.textContent = '⏳ Running…'; }

  try {
    const res = await fetch('/api/strategy-engine', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ticker, timeframe: tf, htf, min_rr: minRR, acct, risk_pct: riskPct,
        strategies: _seGetStrategies()
      })
    });
    const data = await res.json();
    if (data.error) { seShowError(data.error); return; }
    _seLastResult = data;
    seRenderResult(data);
    // Refresh quick-pick highlights with active ticker
    seQPCategory(_seQPCat);
    // Update last-updated label
    const lu2 = document.getElementById('seLastUpdated');
    if (lu2 && _seRefreshSecs > 0) {
      const t = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      lu2.style.display = 'inline';
      lu2.textContent = `🕐 Updated at ${t}`;
    }
  } catch (e) {
    seShowError('Network error — ' + e.message);
  } finally {
    if (runBtn) { runBtn.disabled = false; runBtn.textContent = '▶ RUN ENGINE'; }
  }
}

// ── Multi-ticker batch scan
async function runStrategyEngineScan() {
  if (_seTickerList.length === 0) {
    alert('Add at least one instrument to the multi-scan list first.');
    return;
  }
  const tf      = document.getElementById('seTf')?.value  || '1h';
  const htf     = document.getElementById('seHtf')?.value || '1d';
  const minRR   = parseFloat(document.getElementById('seMinRR')?.value) || 2.0;
  const acct    = parseFloat(document.getElementById('seAcct')?.value)  || 10000;
  const riskPct = parseFloat(document.getElementById('seRisk')?.value)  || 1.0;
  const strats  = _seGetStrategies();

  const scanBtn = document.getElementById('seScanBtn');
  const summary = document.getElementById('seScanSummary');
  const badge   = document.getElementById('seVerdictBadge');
  if (scanBtn) { scanBtn.disabled = true; scanBtn.textContent = '⏳ Scanning…'; }
  if (badge)   { badge.textContent = 'SCANNING'; badge.style.background='rgba(139,92,246,.15)'; badge.style.color='#8B5CF6'; }
  if (summary) { summary.style.display='block'; summary.innerHTML='<div style="font-size:9.5px;color:var(--muted);padding:4px 0;">Scanning ' + _seTickerList.length + ' instruments…</div>'; }

  const results = [];
  for (const ticker of _seTickerList) {
    if (summary) summary.innerHTML = `<div style="font-size:9.5px;color:var(--muted);padding:4px 0;">⏳ Scanning ${ticker}…</div>`;
    try {
      const res = await fetch('/api/strategy-engine', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ticker, timeframe: tf, htf, min_rr: minRR, acct, risk_pct: riskPct, strategies: strats })
      });
      const data = await res.json();
      results.push({ ticker, data, error: data.error || null });
    } catch(e) {
      results.push({ ticker, data: null, error: e.message });
    }
  }

  if (scanBtn) { scanBtn.disabled = false; scanBtn.textContent = '⚡ SCAN ALL'; }
  _seScanRenderSummary(results);
}

function _seScanRenderSummary(results) {
  const summary = document.getElementById('seScanSummary');
  const badge   = document.getElementById('seVerdictBadge');
  if (!summary) return;
  summary.style.display = 'block';

  const goList   = results.filter(r => !r.error && r.data?.verdict === 'GO');
  const nogoList = results.filter(r => !r.error && r.data?.verdict !== 'GO');
  const errList  = results.filter(r => r.error);

  if (badge) {
    const goCount = goList.length;
    badge.textContent = goCount > 0 ? `${goCount} GO` : 'NO GO';
    badge.style.background = goCount > 0 ? 'rgba(0,201,141,.15)' : 'rgba(239,68,68,.12)';
    badge.style.color      = goCount > 0 ? '#00c98d' : '#ff4459';
  }

  let html = `<div style="font-size:9px;font-weight:700;letter-spacing:.8px;color:var(--text2);margin-bottom:5px;">
    SCAN RESULTS <span style="color:var(--muted);font-weight:400;">(${results.length} instruments · ${goList.length} GO · ${nogoList.length} NO-GO)</span>
  </div>`;

  if (goList.length > 0) {
    html += `<div style="font-size:8.5px;color:#00c98d;letter-spacing:.5px;margin-bottom:3px;">✅ OPPORTUNITIES</div>`;
    goList.forEach(r => {
      const d = r.data;
      const sigs = d.signals || [];
      const topSig = sigs.sort((a,b) => (b.confidence||0) - (a.confidence||0))[0];
      const conf = topSig?.confidence ?? d.confidence ?? 0;
      const dir  = topSig?.direction || d.signal || '—';
      html += `<div class="se-scan-card se-scan-go" onclick="seLoadScanResult('${r.ticker}')" style="cursor:pointer;">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:10.5px;font-weight:700;color:var(--text);">${r.ticker}</span>
          <span style="font-size:9px;padding:2px 7px;border-radius:10px;background:${dir==='BUY'?'rgba(0,201,141,.15)':'rgba(255,68,89,.12)'};color:${dir==='BUY'?'#00c98d':'#ff4459'};font-weight:700;">${dir}</span>
        </div>
        <div style="display:flex;gap:8px;margin-top:3px;">
          <span style="font-size:9px;color:var(--muted);">Conf: <span style="color:#F59E0B;font-weight:700;">${conf}%</span></span>
          <span style="font-size:9px;color:var(--muted);">R:R <span style="color:var(--text2);font-weight:600;">${topSig?.rr || d.rr || '—'}</span></span>
          <span style="font-size:9px;color:var(--muted);">Strat: <span style="color:var(--text2);">${topSig?.strategy || '—'}</span></span>
        </div>
      </div>`;
    });
  }

  if (nogoList.length > 0) {
    html += `<div style="font-size:8.5px;color:var(--muted);letter-spacing:.5px;margin:5px 0 3px;">⛔ NO-GO</div>`;
    nogoList.forEach(r => {
      const reasons = r.data?.gate_reasons?.slice(0,2).join(', ') || 'Gate failed';
      html += `<div class="se-scan-card se-scan-nogo">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:10px;font-weight:600;color:var(--text2);">${r.ticker}</span>
          <span style="font-size:8.5px;color:rgba(239,68,68,.7);">NO-GO</span>
        </div>
        <div style="font-size:8.5px;color:var(--muted);margin-top:2px;">${reasons}</div>
      </div>`;
    });
  }

  if (errList.length > 0) {
    html += `<div style="font-size:8.5px;color:rgba(255,68,89,.7);margin-top:4px;">⚠ Failed: ${errList.map(r=>r.ticker).join(', ')}</div>`;
  }

  // "Load result" hint
  if (goList.length > 0) {
    html += `<div style="font-size:8.5px;color:var(--muted);margin-top:5px;text-align:center;">Click a GO instrument to load full analysis</div>`;
    // Auto-store all results for loading
    window._seScanResults = Object.fromEntries(results.filter(r=>!r.error).map(r=>[r.ticker, r.data]));
  }

  summary.innerHTML = html;
}

// ── Matrix Scan ──────────────────────────────────────────────────────────────
let _seMatrixData = [];

async function runStrategyMatrix() {
  const ticker = (document.getElementById('seTicker')?.value || '').trim().toUpperCase() || 'BTC-USD';
  const acct   = parseFloat(document.getElementById('seAcct')?.value) || 10000;
  const btn    = document.getElementById('seMatrixBtn');
  const wrap   = document.getElementById('seMatrixWrap');

  if (btn) { btn.disabled = true; btn.textContent = '⏳ Scanning all TF × HTF × R:R × Risk%…'; }
  if (wrap) wrap.style.display = 'none';

  try {
    const res  = await fetch('/api/strategy-matrix', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ticker, acct, strategies: _seGetStrategies() })
    });
    const data = await res.json();
    if (data.error) { alert('Matrix error: ' + data.error); return; }
    _seMatrixData = data.results || [];
    seMatrixRender();
    if (wrap) wrap.style.display = 'block';
  } catch(e) {
    alert('Matrix scan failed: ' + e.message);
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = '📊 MATRIX SCAN — ALL TF × HTF × R:R × RISK%'; }
  }
}

function seMatrixRender() {
  const tbody   = document.getElementById('seMatrixBody');
  const counter = document.getElementById('seMatrixCount');
  if (!tbody) return;

  const sortKey = document.getElementById('seMatrixSort')?.value || 'confidence';
  const dirFilt = document.getElementById('seMatrixDirFilter')?.value || 'ALL';

  let rows = [..._seMatrixData];
  if (dirFilt !== 'ALL') rows = rows.filter(r => r.direction === dirFilt);
  rows.sort((a, b) => {
    if (sortKey === 'rr')        return b.rr - a.rr;
    if (sortKey === 'tf')        return a.tf.localeCompare(b.tf);
    if (sortKey === 'direction') return a.direction.localeCompare(b.direction);
    return b.confidence - a.confidence;  // default
  });

  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="14" style="padding:12px;text-align:center;color:var(--muted);font-size:9.5px;">No signals found across all timeframes. Market may be in a consolidation phase.</td></tr>';
    if (counter) counter.textContent = '0 signals';
    return;
  }

  const fmt = v => v == null ? '—' : typeof v === 'number' ? v.toLocaleString(undefined, {maximumFractionDigits: 6}) : v;
  const gateColor = g => g === 'GO' ? '#00c98d' : g === 'GO LONG' ? '#00c98d' : g === 'GO SHORT' ? '#ff4459' : '#7a90b0';
  const dirColor  = d => d === 'LONG' ? '#00c98d' : '#ff4459';
  const confColor = c => c >= 70 ? '#00c98d' : c >= 50 ? '#F59E0B' : '#7a90b0';

  tbody.innerHTML = rows.map((r, i) => `
    <tr style="border-bottom:1px solid rgba(255,255,255,.04);background:${i%2===0?'transparent':'rgba(255,255,255,.015)'};">
      <td style="padding:4px 4px;font-weight:700;color:#F59E0B;">${r.tf}</td>
      <td style="padding:4px 4px;color:var(--muted);">${r.htf}</td>
      <td style="padding:4px 4px;" title="${r.note || ''}">${r.code} <span style="color:var(--muted);font-size:8px;">${r.strategy.replace(/ /g,'&nbsp;')}</span></td>
      <td style="padding:4px 4px;text-align:center;font-weight:700;color:${dirColor(r.direction)};">${r.direction === 'LONG' ? '▲ L' : '▼ S'}</td>
      <td style="padding:4px 4px;text-align:center;font-weight:700;">${r.rr}:1</td>
      <td style="padding:4px 4px;text-align:center;font-size:8px;color:${gateColor(r.gate)};">${r.gate}</td>
      <td style="padding:4px 4px;text-align:center;font-weight:700;color:${confColor(r.confidence)};">${r.confidence}%</td>
      <td style="padding:4px 4px;text-align:right;">${fmt(r.entry)}</td>
      <td style="padding:4px 4px;text-align:right;color:#ff4459;">${fmt(r.sl)}</td>
      <td style="padding:4px 4px;text-align:right;color:#00c98d;">${fmt(r.tp)}</td>
      <td style="padding:4px 4px;text-align:center;color:var(--muted);">${r.risk_pct}%</td>
      <td style="padding:4px 4px;text-align:right;color:#ff4459;">$${fmt(r.risk_amt)}</td>
      <td style="padding:4px 4px;text-align:right;color:#00c98d;">$${fmt(r.reward_amt)}</td>
      <td style="padding:4px 4px;text-align:right;color:var(--muted);">${r.pos_size != null ? r.pos_size : '—'}</td>
    </tr>`).join('');

  if (counter) counter.textContent = `${rows.length} signal rows across all combinations`;
}

function seLoadScanResult(ticker) {
  const data = window._seScanResults?.[ticker];
  if (!data) return;
  const input = document.getElementById('seTicker');
  if (input) input.value = ticker;
  _seLastResult = data;
  seRenderResult(data);
  seQPCategory(_seQPCat);
  // Scroll to engine panel
  document.getElementById('stratEnginePanel')?.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

// ── Format price
function fmtP(v) {
  if (v == null) return '—';
  const n = parseFloat(v);
  if (isNaN(n)) return String(v);
  return n >= 100 ? n.toFixed(2) : n >= 1 ? n.toFixed(4) : n.toFixed(6);
}

// ── Format volume numbers
function fmtVol(v) {
  if (v == null || isNaN(v)) return '—';
  const n = Number(v);
  if (n >= 1e9) return (n/1e9).toFixed(2) + 'B';
  if (n >= 1e6) return (n/1e6).toFixed(2) + 'M';
  if (n >= 1e3) return (n/1e3).toFixed(1) + 'K';
  return n.toFixed(0);
}

