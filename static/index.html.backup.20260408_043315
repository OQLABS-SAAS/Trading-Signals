.ind-val{font-family:var(--mono);font-size:19px;font-weight:700;color:rgba(255,255,255,0.92);margin-bottom:5px;}
.ind-desc{font-size:12px;color:rgba(255,255,255,0.82);line-height:1.55;margin-bottom:4px;}
.ind-raw{font-family:var(--mono);font-size:11px;color:var(--text2);margin-top:3px;}
.ind-lbl{color:rgba(245,190,80,.5);font-size:10px;font-weight:700;letter-spacing:.4px;}
.bar-track{background:var(--surface3);border-radius:4px;height:4px;overflow:hidden;margin-top:6px;}
.bar-fill{height:100%;border-radius:4px;transition:width .8s;}

/* RIGHT SIDEBAR */
.sidebar-right{border-left:1px solid var(--border);background:var(--bg2);overflow-y:auto;display:flex;flex-direction:column;}
.panel-card{padding:14px 16px;border-bottom:1px solid var(--border);}
.panel-title{font-size:12px;font-weight:700;color:var(--text);margin-bottom:10px;display:flex;align-items:center;gap:6px;justify-content:space-between;}

